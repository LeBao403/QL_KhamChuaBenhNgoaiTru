@model QL_KhamChuaBenhNgoaiTru.Models.GioiThieuViewModel
@{
    ViewBag.Title = "Về chúng tôi - MedicHub";
    Layout = "~/Views/Shared/_Layout_Client.cshtml";
}

<style>
    /* 1. HERO PARALLAX (HÌNH LOCAL) */
    .about-hero {
        background: linear-gradient(135deg, rgba(10, 88, 202, 0.85) 0%, rgba(5, 44, 101, 0.9) 100%),
                    url('/Images/about/about-hero.jpg') no-repeat center center;
        background-attachment: fixed; /* Parallax siêu mượt */
        background-size: cover;
        padding: 180px 0 120px 0;
        color: white;
    }

    /* 2. CHỮ GRADIENT TỐI TÂN */
    .text-gradient {
        background: linear-gradient(45deg, #0d6efd, #0dcaf0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* 3. THẺ 3D HOVER */
    .card-3d {
        border: none;
        border-radius: 1.5rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 100%;
    }
    .card-3d:hover {
        transform: translateY(-15px);
        box-shadow: 0 20px 40px rgba(13, 110, 253, 0.15);
    }
    .icon-wrapper {
        width: 80px; height: 80px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.5rem; margin-bottom: 1.5rem;
    }

    /* 4. LỜI NGỎ BAN GIÁM ĐỐC */
    .director-img {
        width: 100%; max-width: 400px;
        border-radius: 2rem;
        box-shadow: 20px 20px 0px rgba(13, 110, 253, 0.1);
        object-fit: cover;
    }
    .quote-icon {
        font-size: 4rem; color: rgba(13, 110, 253, 0.2);
        position: absolute; top: -20px; left: -20px; z-index: -1;
    }

    /* 5. TIMELINE LỊCH SỬ */
    .timeline { position: relative; border-left: 3px solid #e9ecef; margin-left: 20px; padding-left: 30px; }
    .timeline-item { position: relative; margin-bottom: 3rem; }
    .timeline-item::before {
        content: ''; position: absolute; left: -42px; top: 0;
        width: 20px; height: 20px; border-radius: 50%;
        background: #0d6efd; border: 4px solid #fff; box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.2);
    }
    .timeline-year { font-size: 1.5rem; font-weight: 800; color: #0d6efd; margin-bottom: 0.5rem; }

    /* 6. HÌNH ẢNH MASONRY / LƯỚI */
    .img-rounded-lg { border-radius: 1.5rem; object-fit: cover; width: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }

    /* 7. INFINITE SCROLL LOGO */
    .marquee-container { overflow: hidden; white-space: nowrap; width: 100%; background: #fff; padding: 2rem 0; }
    .marquee-content { display: inline-block; animation: marquee 20s linear infinite; }
    .marquee-content img { height: 60px; margin: 0 40px; filter: grayscale(100%); transition: all 0.3s ease; opacity: 0.6; object-fit: contain; }
    .marquee-content img:hover { filter: grayscale(0%); opacity: 1; }
    @@keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* Fix Content cho dễ đọc */
    p.text-muted, p.fs-5 { line-height: 1.9 !important; text-align: justify; }
</style>

<section class="about-hero text-center">
