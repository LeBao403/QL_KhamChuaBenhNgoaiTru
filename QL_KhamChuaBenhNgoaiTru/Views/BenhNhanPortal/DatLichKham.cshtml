@{
    ViewBag.Title = "Đặt lịch khám";
    Layout = "~/Views/Shared/_Layout_Client.cshtml";

    // Lấy danh sách dịch vụ từ ViewBag
    var listDichVu = ViewBag.ListDichVu as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">

<style>
    /* CSS TRƯỞNG THÀNH, TỐI GIẢN, CHUYÊN NGHIỆP */
    body {
        background-color: #f4f7f6;
    }

    .hero-section {
        background-color: #ffffff;
        padding: 2.5rem 0;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 2.5rem;
    }

    .booking-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.03);
        background: #ffffff;
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.85rem 1.2rem;
        font-size: 1rem;
        color: #1e293b;
        background-color: #f8fafc;
        transition: border-color 0.2s, box-shadow 0.2s, background-color 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
    /* Tinh chỉnh riêng cho ô Input Lịch để xóa border trái */
    .input-date-flatpickr {
        border-left: none !important;
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
    }
    /* --- FIX LỖI FLATPICKR BỊ MẤT NĂM DO XUNG ĐỘT BOOTSTRAP 5 --- */
    .flatpickr-current-month {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

        .flatpickr-current-month .flatpickr-monthDropdown-months {
            width: auto !important;
            margin-right: 5px !important;
            background: transparent !important;
            color: inherit !important;
        }

        .flatpickr-current-month .numInputWrapper {
            width: 60px !important; /* Ép độ rộng cho ô chứa Năm */
            display: inline-block !important;
        }

        .flatpickr-current-month input.cur-year {
            background: transparent !important;
            color: #ffffff !important; /* Ép màu trắng cho nổi trên nền xanh */
            font-weight: 700 !important;
            border: none !important;
            box-shadow: none !important;
            padding: 0 !important;
        }
        /* Ẩn cái mũi tên tăng giảm năm cho nó tinh tế */
        .flatpickr-current-month .numInputWrapper span.arrowUp,
        .flatpickr-current-month .numInputWrapper span.arrowDown {
            display: none !important;
        }

    .input-group-text.cal-icon {
        border-right: none;
        background-color: #ffffff;
        border-color: #cbd5e1;
        color: #64748b;
        border-top-left-radius: 8px;
        border-bottom-left-radius: 8px;
    }

    .info-box {
        background-color: #f0fdf4;
        border-left: 4px solid #22c55e;
        border-radius: 6px;
        color: #166534;
        padding: 1rem 1.25rem;
    }

    .warning-box {
        background-color: #fefce8;
        border: 1px solid #fef08a;
        border-radius: 6px;
        color: #854d0e;
        padding: 1rem;
        font-size: 0.9rem;
    }

    .btn-submit {
        background-color: #0f172a;
        border-color: #0f172a;
        color: #ffffff;
        border-radius: 8px;
        padding: 0.85rem 2rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-submit:hover:not(:disabled) {
            background-color: #334155;
            transform: translateY(-1px);
        }

    .btn-cancel {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #475569;
        border-radius: 8px;
        padding: 0.85rem 2rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background-color: #f1f5f9;
            color: #0f172a;
        }
</style>

<div class="hero-section">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="fw-bold text-dark mb-1" style="letter-spacing: -0.5px;">Đăng ký lịch khám</h2>
                <p class="text-muted mb-0">Hệ thống đặt lịch hẹn trực tuyến MEDICHUB</p>
            </div>
            <a href="@Url.Action("LichKham", "BenhNhanPortal")" class="btn btn-cancel shadow-sm py-2">
                <i class="bi bi-arrow-left me-2"></i> Trở về
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-7 col-xl-6">
            <div class="booking-card p-4 p-md-5">

                <h4 class="fw-bold text-dark mb-4 border-bottom pb-3">Thông tin đăng ký</h4>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger fw-bold d-flex align-items-center rounded border-0 bg-danger bg-opacity-10 text-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill fs-5 me-3"></i>
                        <div>@TempData["Error"]</div>
                    </div>
                }

                <div class="info-box mb-4 d-flex gap-3 align-items-start">
                    <i class="bi bi-info-circle-fill fs-5 mt-1"></i>
                    <div>
                        Mã đặt lịch trực tuyến của bạn <strong>chỉ có hiệu lực trong ngày khám đã chọn</strong>. Vui lòng mang theo mã phiếu và giấy tờ tùy thân đến viện vào đúng ngày để làm thủ tục.
                    </div>
                </div>

                @using (Html.BeginForm("DatLichKham", "BenhNhanPortal", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="ngayKham" class="form-label">Ngày muốn đến khám <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text cal-icon"><i class="bi bi-calendar-check fs-5 text-primary"></i></span>
                            <input type="text" name="ngayKham" id="ngayKham" class="form-control fw-bold text-primary bg-white" placeholder="Chọn ngày khám..." required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="maDV" class="form-label">Dịch vụ khám <span class="text-danger">*</span></label>
                        <select name="maDV" id="maDV" class="form-select fw-medium" required>
                            <option value="" disabled selected>-- Vui lòng chọn dịch vụ --</option>
                            @foreach (var dv in listDichVu)
                            {
                                <option value="@dv.Value">@dv.Text</option>
                            }
                        </select>
                        @if (!listDichVu.Any())
                        {
                            <div class="form-text text-danger mt-2"><i class="bi bi-x-circle me-1"></i>Hệ thống chưa có dịch vụ nào.</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label for="lyDo" class="form-label">Triệu chứng / Lý do đến khám <span class="text-danger">*</span></label>
                        <textarea name="lyDo" id="lyDo" class="form-control" style="height: 120px" placeholder="Mô tả ngắn gọn tình trạng sức khỏe của bạn..." required></textarea>
                    </div>

                    <div class="warning-box mb-5">
                        <i class="bi bi-shield-check text-warning me-1"></i>
                        Thông tin của bạn được bảo mật. Bạn có thể theo dõi tiến trình tại mục <a href="@Url.Action("LichKham", "BenhNhanPortal")" class="fw-bold text-dark">Lịch khám của tôi</a>.
                    </div>

                    <div class="d-flex justify-content-end gap-3 pt-2">
                        <a href="@Url.Action("Index", "BenhNhanPortal")" class="btn btn-cancel">Hủy bỏ</a>
                        <button type="submit" class="btn btn-submit shadow-sm" @(listDichVu.Any() ? "" : "disabled")>
                            Gửi yêu cầu
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/vn.js"></script>

    <script>
        $(document).ready(function () {

            // --- KHỞI TẠO LỊCH CAO CẤP FLATPICKR ---
            flatpickr("#ngayKham", {
                locale: "vn",
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                altInputClass: "form-control input-date-flatpickr fw-bold text-primary bg-white cursor-pointer",
                minDate: "today",
                defaultDate: "today",
                disableMobile: "true"
            });

            // --- LẤY DATA TỪ CONTROLLER TRUYỀN SANG ---
            var successMessage = '@Html.Raw(TempData["Success"])';
            var maPhieu = '@Html.Raw(TempData["MaPhieu"])';
            var tenQuay = '@Html.Raw(TempData["TenQuay"])';

            if (successMessage && successMessage.trim() !== '') {

                // NẾU CÓ ĐỦ DATA, VẼ "VÉ ĐIỆN TỬ" RA MÀN HÌNH
                let htmlTicket = '';
                if(maPhieu) {
                    htmlTicket = `
                        <div class="text-start bg-white p-4 rounded-4 border border-2 border-success shadow-sm mt-3 position-relative overflow-hidden">
                            <div class="position-absolute top-0 start-0 w-100 bg-success" style="height: 6px;"></div>

                            <div class="d-flex justify-content-between align-items-center border-bottom border-dashed pb-3 mb-3">
                                <span class="text-muted"><i class="bi bi-qr-code me-2"></i>Mã phiếu ĐK:</span>
                                <strong class="text-dark fs-5">#${maPhieu}</strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center border-bottom border-dashed pb-3 mb-3">
                                <span class="text-muted"><i class="bi bi-globe me-2"></i>Hình thức:</span>
                                <strong class="text-success fs-5">Đặt trước Online</strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pb-1">
                                <span class="text-muted"><i class="bi bi-signpost-split me-2"></i>Khu vực trực:</span>
                                <strong class="text-primary fs-5 text-uppercase text-end">${tenQuay || 'Quầy Tiếp Tân'}</strong>
                            </div>
                        </div>
                        <p class="text-muted mt-3 mb-0 fs-7"><i class="bi bi-info-circle me-1 text-primary"></i> Vui lòng chụp màn hình vé này và đến đúng quầy để làm thủ tục.</p>
                    `;
                } else {
                    htmlTicket = `<p class="fs-5 mt-2">${successMessage}</p>`;
                }

                Swal.fire({
                    title: 'ĐẶT LỊCH THÀNH CÔNG!',
                    html: htmlTicket,
                    icon: 'success',
                    showCancelButton: true, // Mở thêm nút Hủy/Đóng
                    confirmButtonText: '<i class="bi bi-calendar-check me-2"></i>Xem lịch khám',
                    cancelButtonText: 'Đóng', // Nút tắt
                    allowOutsideClick: true,  // Cho phép click ra ngoài viền để tắt
                    customClass: {
                        confirmButton: 'btn btn-submit px-4 py-2 mt-2 shadow-sm',
                        cancelButton: 'btn btn-light border px-4 py-2 mt-2 shadow-sm ms-2 fw-bold text-secondary'
                    },
                    buttonsStyling: false
                }).then((result) => {
                    // Chỉ khi nào click vô nút "Xem lịch khám" mới redirect
                    if (result.isConfirmed) {
                        window.location.href = '@Url.Action("LichKham", "BenhNhanPortal")';
                    }
                });
            }
        });
    </script>
}