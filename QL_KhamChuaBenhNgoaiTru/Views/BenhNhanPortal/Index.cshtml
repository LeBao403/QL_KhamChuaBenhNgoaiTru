@model QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.DashboardBenhNhan
@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Layout_Client.cshtml";
    var profile = ViewBag.Profile as QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.BenhNhanProfile;
}

<div class="page-hero">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="hero-title">Xin chào, @(profile?.HoTen ?? "Bệnh nhân")!</div>
                <div class="hero-subtitle mt-1">
                    <i class="bi bi-calendar3 me-1"></i> Hôm nay @DateTime.Now.ToString("dddd, dd/MM/yyyy")
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("DatLichKham", "BenhNhanPortal")" class="btn btn-warning rounded-pill fw-bold px-4">
                    <i class="bi bi-calendar-plus me-1"></i> Đặt lịch khám
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">
    @if (profile != null)
    {
        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="patient-card">
                    <div class="card-header d-flex align-items-center gap-3">
                        <div class="profile-avatar" style="width:48px;height:48px;font-size:1.2rem;background:linear-gradient(135deg,#0d6efd,#198754);color:white;border:none;">
                            @(profile.HoTen?.Length > 0 ? profile.HoTen[0].ToString().ToUpper() : "B")
                        </div>
                        <div>
                            <div class="fw-bold" style="font-size:1.1rem;">@profile.HoTen</div>
                            <div class="small text-muted">@profile.MaBN</div>
                        </div>
                        <div class="ms-auto">
                            <a href="@Url.Action("ThongTinCaNhan", "BenhNhanPortal")" class="btn btn-outline-primary rounded-pill btn-sm">
                                <i class="bi bi-pencil me-1"></i> Cập nhật
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <div class="small text-muted">Ngày sinh</div>
                                <div class="fw-semibold">@(profile.NgaySinh?.ToString("dd/MM/yyyy") ?? "—")</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="small text-muted">Giới tính</div>
                                <div class="fw-semibold">@profile.GioiTinh</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="small text-muted">Điện thoại</div>
                                <div class="fw-semibold">@(string.IsNullOrEmpty(profile.SDT) ? "—" : profile.SDT)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="small text-muted">Email</div>
                                <div class="fw-semibold" style="font-size:0.8rem;">@(string.IsNullOrEmpty(profile.Email) ? "—" : profile.Email)</div>
                            </div>
                        </div>
                        @if (profile.BHYT == true)
                        {
                            <div class="alert alert-success mt-3 mb-0 py-2 px-3" style="border-radius:10px;">
                                <i class="bi bi-shield-check me-1"></i>
                                <strong>BHYT:</strong> @profile.SoTheBHYT
                                @if (profile.HanSuDungBHYT.HasValue)
                                {
                                    <span class="ms-2 text-muted">| Hạn: @profile.HanSuDungBHYT.Value.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="patient-stat-card h-100">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center text-center py-4">
                        <div class="profile-avatar mb-3" style="width:72px;height:72px;font-size:1.8rem;background:linear-gradient(135deg,#0d6efd,#198754);color:white;border:none;">
                            @(profile.HoTen?.Length > 0 ? profile.HoTen[0].ToString().ToUpper() : "B")
                        </div>
                        <div class="fw-bold mb-1" style="font-size:1.1rem;">@(profile.MaBN)</div>
                        <div class="text-muted small mb-3">Mã bệnh nhân</div>
                        <div class="d-flex gap-2 flex-wrap justify-content-center">
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                <i class="bi bi-calendar-check me-1"></i> @Model.SoLichKhamDaXacNhan lịch đã duyệt
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
            <div class="patient-stat-card text-center py-4 px-3">
                <div class="mb-3">
                    <div style="width:56px;height:56px;border-radius:16px;background:#dbeafe;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                        <i class="bi bi-hourglass-split" style="font-size:1.5rem;color:#1e40af;"></i>
                    </div>
                </div>
                <div class="display-6 fw-bold" style="color:#1e40af;">@Model.SoLichKhamChoDuyet</div>
                <div class="small text-muted fw-semibold mt-1">Lịch chờ duyệt</div>
            </div>
        </div>
        <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
            <div class="patient-stat-card text-center py-4 px-3">
                <div class="mb-3">
                    <div style="width:56px;height:56px;border-radius:16px;background:#d1fae5;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                        <i class="bi bi-check-circle" style="font-size:1.5rem;color:#065f46;"></i>
                    </div>
                </div>
                <div class="display-6 fw-bold" style="color:#065f46;">@Model.SoLichKhamDaXacNhan</div>
                <div class="small text-muted fw-semibold mt-1">Lịch đã xác nhận</div>
            </div>
        </div>
        <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
            <div class="patient-stat-card text-center py-4 px-3">
                <div class="mb-3">
                    <div style="width:56px;height:56px;border-radius:16px;background:#fef3c7;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                        <i class="bi bi-activity" style="font-size:1.5rem;color:#92400e;"></i>
                    </div>
                </div>
                <div class="display-6 fw-bold" style="color:#92400e;">@Model.TongSoLanKham</div>
                <div class="small text-muted fw-semibold mt-1">Tổng lần khám</div>
            </div>
        </div>
        <div class="col-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
            <div class="patient-stat-card text-center py-4 px-3">
                <div class="mb-3">
                    <div style="width:56px;height:56px;border-radius:16px;background:#fee2e2;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                        <i class="bi bi-prescription2" style="font-size:1.5rem;color:#991b1b;"></i>
                    </div>
                </div>
                <div class="display-6 fw-bold" style="color:#991b1b;">@Model.TongDonThuoc</div>
                <div class="small text-muted fw-semibold mt-1">Đơn thuốc đã kê</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <a href="@Url.Action("DatLichKham", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#dbeafe;color:#1e40af;">
                    <i class="bi bi-calendar-plus"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Đặt lịch khám</div>
                    <div class="desc">Đăng ký khám online</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <a href="@Url.Action("LichKham", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#d1fae5;color:#065f46;">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Lịch khám của tôi</div>
                    <div class="desc">Xem & quản lý lịch hẹn</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <a href="@Url.Action("TrangThaiKham", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#fef3c7;color:#92400e;">
                    <i class="bi bi-activity"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Trạng thái khám</div>
                    <div class="desc">Theo dõi tiến trình</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
            <a href="@Url.Action("LichSuKham", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#ede9fe;color:#5b21b6;">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Lịch sử khám bệnh</div>
                    <div class="desc">Xem lại các lần đã khám</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="500">
            <a href="@Url.Action("DonThuoc", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#fee2e2;color:#991b1b;">
                    <i class="bi bi-prescription2"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Đơn thuốc</div>
                    <div class="desc">@Model.TongDonThuoc đơn đã kê</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="600">
            <a href="@Url.Action("HoaDon", "BenhNhanPortal")" class="quick-action-card">
                <div class="quick-action-icon" style="background:#f0fdf4;color:#15803d;">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
                <div class="quick-action-text">
                    <div class="title">Hóa đơn</div>
                    <div class="desc">@Model.TongHoaDon hóa đơn</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </a>
        </div>
    </div>
</div>
