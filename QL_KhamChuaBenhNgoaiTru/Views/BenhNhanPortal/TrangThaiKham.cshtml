@model List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.TrangThaiKhamItem>
@{
    ViewBag.Title = "Trạng thái khám";
    Layout = "~/Views/Shared/_Layout_Client.cshtml";
}

<div class="page-hero" style="background:linear-gradient(135deg,#065f46 0%,#198754 100%);">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="hero-title"><i class="bi bi-activity me-2"></i>Trạng thái các lần khám</div>
                <div class="hero-subtitle">Theo dõi tiến trình khám bệnh của bạn</div>
            </div>
            <a href="@Url.Action("LichSuKham", "BenhNhanPortal")" class="btn btn-light rounded-pill fw-bold">
                <i class="bi bi-clock-history me-1"></i> Lịch sử khám
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="patient-card">
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-clipboard-x"></i></div>
                <div class="empty-state-title">Chưa có lịch sử khám</div>
                <div class="empty-state-desc">Thông tin trạng thái khám sẽ hiển thị sau khi bạn hoàn tất đặt lịch.</div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="patient-card">
                        <div class="card-header">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="fw-bold" style="font-size:0.95rem;">Phiếu #@item.MaPhieuKhamBenh</div>
                                    <div class="small text-muted mt-1">
                                        <i class="bi bi-calendar3 me-1"></i>@item.NgayLap.ToString("dd/MM/yyyy")
                                        <span class="mx-2">|</span>
                                        <i class="bi bi-geo-alt me-1"></i>@(item.TenKhoa ?? "—")
                                    </div>
                                </div>
                                @if (item.TrangThai == "Đang khám")
                                {
                                    <span class="badge badge-pending rounded-pill px-3 py-2">
                                        <i class="bi bi-hourglass-split me-1"></i>Đang khám
                                    </span>
                                }
                                else if (item.TrangThai == "Hoàn thành")
                                {
                                    <span class="badge badge-done rounded-pill px-3 py-2">
                                        <i class="bi bi-check-circle me-1"></i>Hoàn thành
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill px-3 py-2">@item.TrangThai</span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(item.TenPhong))
                            {
                                <div class="mb-2">
                                    <span class="small text-muted fw-semibold">Phòng:</span>
                                    <span class="fw-semibold ms-1">@item.TenPhong</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.TenBacSi))
                            {
                                <div class="mb-2">
                                    <span class="small text-muted fw-semibold">Bác sĩ:</span>
                                    <span class="fw-semibold ms-1">BS. @item.TenBacSi</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.LyDoDenKham))
                            {
                                <div class="mb-2">
                                    <span class="small text-muted fw-semibold">Lý do:</span>
                                    <span class="ms-1">@item.LyDoDenKham</span>
                                </div>
                            }
                            @if (item.STT.HasValue)
                            {
                                <div class="alert alert-warning mb-0 py-2 px-3 mt-2" style="border-radius:10px;">
                                    <i class="bi bi-list-ol me-1"></i>Số thứ tự hiện tại:
                                    <strong class="ms-1">@item.STT</strong>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
