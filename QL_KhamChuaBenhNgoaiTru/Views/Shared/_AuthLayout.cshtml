﻿
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - VNVC</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* CSS BẠN CUNG CẤP (giữ nguyên) */
        :root {
            --primary-color: #00a0e3;
            --secondary-color: #0056b3;
            --accent-color: #ff6b35;
            --light-bg: #f8f9fa;
            --dark-text: #2c3e50;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--light-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 2rem 0;
        }

        .auth-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            max-width: 900px;
            width: 100%;
        }

        .auth-graphic {
            background: linear-gradient(135deg, rgba(0, 160, 227, 0.8), rgba(0, 86, 179, 0.9)), url('https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=800&q=80') center center;
            background-size: cover;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
        }

        .auth-graphic-link {
            color: white;
            text-decoration: none;
            transition: transform 0.3s ease;
        }

            .auth-graphic-link:hover {
                color: white;
                transform: scale(1.05);
            }

        .auth-graphic .icon-brand {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .auth-graphic h2 {
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .auth-graphic p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .auth-form {
            padding: 3rem;
        }

            .auth-form .brand-logo {
                font-size: 2.5rem;
                color: var(--primary-color);
                text-align: center;
                margin-bottom: 1.5rem;
            }

        .brand-logo a {
            color: var(--primary-color);
            text-decoration: none;
            transition: opacity 0.3s ease;
        }

            .brand-logo a:hover {
                opacity: 0.8;
            }

        .auth-form .form-title {
            text-align: center;
            font-weight: 700;
            color: var(--dark-text);
            margin-bottom: 2rem;
        }

        .form-floating > .form-control {
            border-radius: 0.5rem;
        }

            .form-floating > .form-control:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 0.25rem rgba(0, 160, 227, 0.25);
            }

        .password-toggle-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            cursor: pointer;
            color: #aaa;
            z-index: 10;
        }

            .password-toggle-icon:hover {
                color: var(--primary-color);
            }

        .form-floating > input[type="password"], .form-floating > input[type="text"], .form-floating > input[type="tel"], .form-floating > input[type="email"] {
            padding-right: 3.5rem;
        }

        .btn-submit {
            background: var(--accent-color);
            border: none;
            color: white;
            font-weight: 600;
            padding: 0.85rem;
            border-radius: 0.5rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
        }

            .btn-submit:hover {
                background: #ff5522;
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
            }

        .toggle-link a {
            color: var(--primary-color);
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: color 0.3s ease;
        }

            .toggle-link a:hover {
                text-decoration: underline;
                color: var(--secondary-color);
            }

        .back-to-home-link a {
            color: var(--secondary-color);
            text-decoration: none;
            font-weight: 500;
        }

            .back-to-home-link a:hover {
                color: var(--primary-color);
                text-decoration: underline;
            }

        #form-register, #form-forgot-password {
            display: none;
        }

        /* 🟢 CSS MỚI: Dùng cho thông báo lỗi Validation Summary */
        .validation-alert ul {
            list-style-type: none; /* Loại bỏ dấu chấm */
            padding-left: 0; /* Đảm bảo lỗi căn lề sát bên trái */
            margin-bottom: 0;
        }
        /* Tùy chỉnh màu sắc alert cho giống hình ảnh (nếu cần) */
        .alert-danger {
            color: #721c24; /* Màu chữ đậm */
            background-color: #f8d7da; /* Màu nền đỏ nhạt */
            border-color: #f5c6cb; /* Màu viền */
            border-radius: 0.5rem;
            font-weight: 500;
        }

        @@media (max-width: 991.98px) {
            .auth-graphic {
                display: none;
            }

            .auth-card {
                max-width: 450px;
            }

            .auth-form {
                padding: 2rem;
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="container">
        <div class="row auth-card mx-auto">
            <div class="col-lg-6 auth-graphic">
                <a href="@Url.Action("Index", "Home")" class="auth-graphic-link">
                    <i class="fas fa-syringe icon-brand"></i>
                    <h2>Chào mừng đến với VNVC</h2>
                    <p>Quản lý lịch sử tiêm chủng và đặt lịch hẹn an toàn, tiện lợi cho cả gia đình.</p>
                </a>
            </div>

            <div class="col-lg-6 auth-form">
                <div class="brand-logo d-lg-none">
                    <a href="@Url.Action("Index", "Home")">
                        <i class="fas fa-syringe"></i>
                    </a>
                </div>

                <div style="position: absolute; top: 20px; left: 20px;">
                    @RenderSection("TopLeftActions", required: false)
                </div>

                @RenderBody()

                <hr class="my-4" style="display:none;">
                <div class="toggle-link" style="display:none;"></div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            /* Logic cho việc hiện/ẩn mật khẩu */
            function setupPasswordToggle(inputId, toggleId) {
                const passwordInput = document.getElementById(inputId);
                const toggleIconContainer = document.getElementById(toggleId);

                if (passwordInput && toggleIconContainer) {
                    const iconElement = toggleIconContainer.querySelector('i');

                    toggleIconContainer.addEventListener('click', function () {
                        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                        passwordInput.setAttribute('type', type);

                        if (type === 'password') {
                            iconElement.classList.remove('fa-eye-slash');
                            iconElement.classList.add('fa-eye');
                        } else {
                            iconElement.classList.remove('fa-eye');
                            iconElement.classList.add('fa-eye-slash');
                        }
                    });
                }
            }

            setupPasswordToggle('loginPassword', 'toggleLoginPassword');
            setupPasswordToggle('regPassword', 'toggleRegPassword');
            setupPasswordToggle('regConfirmPassword', 'toggleRegConfirmPassword');
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>