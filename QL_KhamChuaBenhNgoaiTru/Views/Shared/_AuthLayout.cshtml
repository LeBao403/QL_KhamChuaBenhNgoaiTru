<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DigiMed Clinic</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/favicon.png")?v=2" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-blue: #0d6efd;
            --dark-blue: #0a58ca;
            --light-blue: #f0f9ff;
            --accent-green: #198754;
            --accent-warm: #ffc107;
            --text-main: #2c3e50;
            --text-muted: #64748b;
            --border-soft: rgba(148, 163, 184, 0.2);
            --shadow-soft: 0 20px 60px rgba(15, 23, 42, 0.14);
            --transition-fast: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Quicksand', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-main);
            min-height: 100vh;
            margin: 0;
            background:
                radial-gradient(circle at top left, rgba(13, 110, 253, 0.18), transparent 32%),
                radial-gradient(circle at bottom right, rgba(25, 135, 84, 0.16), transparent 28%),
                linear-gradient(180deg, #f7fbff 0%, #eef5ff 52%, #f7fafc 100%);
        }

        .auth-shell {
            position: relative;
            min-height: 100vh;
            padding: 16px 0;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .auth-shell::before,
        .auth-shell::after {
            content: "";
            position: absolute;
            border-radius: 999px;
            filter: blur(10px);
            opacity: 0.45;
            z-index: 0;
        }

        .auth-shell::before {
            width: 300px;
            height: 300px;
            top: -80px;
            left: -70px;
            background: rgba(13, 110, 253, 0.18);
        }

        .auth-shell::after {
            width: 260px;
            height: 260px;
            right: -80px;
            bottom: -60px;
            background: rgba(25, 135, 84, 0.15);
        }

        .auth-card {
            position: relative;
            z-index: 1;
            background: rgba(255, 255, 255, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 24px;
            box-shadow: var(--shadow-soft);
            overflow: hidden;
            max-width: 1060px;
            backdrop-filter: blur(18px);
        }

        .auth-showcase {
            position: relative;
            min-height: 100%;
            padding: 26px 28px;
            color: #fff;
            background:
                linear-gradient(155deg, rgba(10, 88, 202, 0.96) 0%, rgba(13, 110, 253, 0.92) 58%, rgba(13, 202, 240, 0.82) 100%);
        }

        .auth-showcase::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                linear-gradient(0deg, rgba(10, 88, 202, 0.2), rgba(10, 88, 202, 0.2)),
                url('@Url.Content("~/Images/banner-slide-1.jpg")') center center / cover no-repeat;
            mix-blend-mode: soft-light;
            opacity: 0.38;
        }

        .auth-showcase > * {
            position: relative;
            z-index: 1;
        }

        .showcase-brand {
            display: flex;
            align-items: center;
            gap: 20px;
            color: #fff;
            text-decoration: none;
            margin-bottom: 0;
            padding: 24px 28px;
            min-height: 148px;
            width: 100%;
            border-radius: 22px;
            background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
        }

        .showcase-brand:hover {
            color: #fff;
            opacity: 0.95;
        }

        .showcase-brand-badge {
            width: 102px;
            height: 102px;
            border-radius: 50%;
            background: #ffffff;
            border: 2px solid rgba(13, 110, 253, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 24px rgba(10, 88, 202, 0.22);
            flex-shrink: 0;
            overflow: hidden;
            padding: 10px;
        }

        .showcase-brand-badge img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .showcase-brand-text {
            flex: 1;
            min-width: 0;
        }

        .showcase-brand-name {
            display: block;
            font-size: clamp(2.2rem, 4vw, 3.15rem);
            font-weight: 700;
            line-height: 1;
            letter-spacing: -0.03em;
        }

        .showcase-brand-sub {
            display: block;
            margin-top: 12px;
            letter-spacing: 0.38em;
            text-transform: uppercase;
            font-size: 1rem;
            font-weight: 700;
            color: rgba(255,255,255,0.78);
        }

        .showcase-copy {
            max-width: 360px;
            margin-top: 26px;
        }

        .showcase-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 7px 14px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.14);
            border: 1px solid rgba(255, 255, 255, 0.18);
            font-weight: 700;
            margin-bottom: 14px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
            font-size: 0.82rem;
        }

        .auth-showcase h1 {
            font-size: clamp(1.55rem, 2.6vw, 2.15rem);
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 10px;
        }

        .auth-showcase p.lead-text {
            font-size: 0.9rem;
            line-height: 1.65;
            color: rgba(255, 255, 255, 0.84);
            margin-bottom: 0;
        }

        .auth-panel {
            position: relative;
            padding: 22px 28px;
            background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, #ffffff 100%);
        }

        .auth-topbar {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 16px;
        }

        .back-link a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            border-radius: 999px;
            text-decoration: none;
            color: var(--dark-blue);
            background: var(--light-blue);
            font-weight: 700;
            transition: var(--transition-fast);
        }

        .back-link a:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.14);
        }

        .auth-mini-brand {
            display: none;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: var(--primary-blue);
        }

        .auth-mini-brand:hover {
            color: var(--dark-blue);
        }

        .auth-mini-brand img {
            width: 46px;
            height: 46px;
            object-fit: contain;
        }

        .auth-mini-brand strong {
            display: block;
            font-size: 1.05rem;
            line-height: 1;
        }

        .auth-mini-brand span {
            font-size: 0.78rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .auth-form-wrap {
            max-width: 430px;
            margin: 0 auto;
        }

        .auth-form-header {
            margin-bottom: 16px;
        }

        .form-title {
            font-size: clamp(1.65rem, 2.4vw, 2rem);
            font-weight: 700;
            line-height: 1.15;
            margin-bottom: 8px;
            color: #0f172a;
        }

        .form-description {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.6;
            margin-bottom: 0;
        }

        .auth-info-strip {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            margin-bottom: 14px;
            border-radius: 16px;
            background: linear-gradient(135deg, rgba(13, 110, 253, 0.08), rgba(25, 135, 84, 0.08));
            border: 1px solid rgba(13, 110, 253, 0.08);
        }

        .auth-info-strip .icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: #fff;
            color: var(--primary-blue);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 18px rgba(13, 110, 253, 0.1);
        }

        .auth-info-strip strong {
            display: block;
            font-size: 0.9rem;
            color: #0f172a;
        }

        .auth-info-strip span {
            color: var(--text-muted);
            font-size: 0.82rem;
        }

        .auth-surface {
            padding: 18px;
            border-radius: 20px;
            background: #fff;
            border: 1px solid rgba(226, 232, 240, 0.9);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
        }

        .auth-section-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.76rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 12px;
        }

        .form-floating > .form-control {
            min-height: 52px;
            height: calc(3rem + 10px);
            border-radius: 14px;
            border: 1.5px solid #dbe4f0;
            background: #f8fbff;
            color: var(--text-main);
            padding-right: 3.6rem;
            transition: var(--transition-fast);
        }

        .form-floating > label {
            padding: 0.85rem 0.95rem;
            color: #64748b;
            font-size: 0.92rem;
        }

        .form-floating > .form-control:focus {
            border-color: var(--primary-blue);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
        }

        .password-toggle-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            cursor: pointer;
            color: #94a3b8;
            z-index: 10;
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition-fast);
        }

        .password-toggle-icon:hover {
            color: var(--primary-blue);
            background: rgba(13, 110, 253, 0.08);
        }

        .form-check-input {
            border-radius: 6px;
            border-color: #cbd5e1;
        }

        .form-check-input:checked {
            background-color: var(--primary-blue);
            border-color: var(--primary-blue);
        }

        .form-check-label,
        .auth-inline-link,
        .auth-text-muted {
            color: var(--text-muted);
            font-size: 0.92rem;
        }

        .auth-inline-link {
            text-decoration: none;
            font-weight: 700;
            color: var(--primary-blue);
            transition: var(--transition-fast);
        }

        .auth-inline-link:hover {
            color: var(--dark-blue);
            text-decoration: underline;
        }

        .btn-submit {
            border: 0;
            width: 100%;
            min-height: 50px;
            border-radius: 14px;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(135deg, var(--primary-blue), var(--dark-blue));
            box-shadow: 0 16px 28px rgba(13, 110, 253, 0.24);
            transition: var(--transition-fast);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 36px rgba(13, 110, 253, 0.28);
            color: #fff;
        }

        .btn-submit i {
            margin-left: 8px;
        }

        .auth-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.35), transparent);
            margin: 16px 0 12px;
        }

        .toggle-link {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .toggle-link a {
            color: var(--primary-blue);
            text-decoration: none;
            font-weight: 700;
            margin-left: 4px;
        }

        .toggle-link a:hover {
            color: var(--dark-blue);
            text-decoration: underline;
        }

        .validation-alert ul {
            list-style: none;
            padding-left: 0;
            margin-bottom: 0;
        }

        .alert {
            border: 0;
            border-radius: 18px;
            padding: 14px 16px;
            font-weight: 600;
        }

        .alert-success {
            color: #0f5132;
            background: #d1fae5;
        }

        .alert-danger {
            color: #991b1b;
            background: #fee2e2;
        }

        .auth-footnote {
            margin-top: 10px;
            text-align: center;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        @@media (max-width: 991.98px) {
            .auth-showcase {
                display: none;
            }

            .auth-card {
                max-width: 620px;
                border-radius: 22px;
            }

            .auth-panel {
                padding: 20px;
            }

            .auth-mini-brand {
                display: inline-flex;
            }
        }

        @@media (max-width: 575.98px) {
            .auth-shell {
                padding: 10px 0;
            }

            .auth-panel {
                padding: 16px;
            }

            .auth-surface {
                padding: 16px 14px;
                border-radius: 18px;
            }

            .auth-topbar {
                flex-direction: column;
                align-items: stretch;
                margin-bottom: 18px;
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="auth-shell">
        <div class="container">
            <div class="row auth-card mx-auto g-0">
                <div class="col-lg-6 auth-showcase">
                    <a href="@Url.Action("Index", "Home")" class="showcase-brand">
                        <span class="showcase-brand-badge">
                            <img src="@Url.Content("~/Images/Logo/app_favicon.png")" alt="DigiMed Clinic" />
                        </span>
                        <span class="showcase-brand-text">
                            <span class="showcase-brand-name">DigiMed</span>
                            <span class="showcase-brand-sub">Clinic</span>
                        </span>
                    </a>

                    <div class="showcase-copy">
                        <div class="showcase-pill">
                            <i class="fas fa-shield-heart"></i>
                            <span>Không gian bệnh nhân hiện đại</span>
                        </div>

                        <h1>Truy cập hồ sơ và lịch khám trong giao diện gọn, rõ và đồng bộ.</h1>
                        <p class="lead-text">Khung giới thiệu được giữ tối giản để tập trung vào thao tác đăng nhập, đăng ký nhưng vẫn cùng phong cách với trang chủ DigiMed.</p>
                    </div>
                </div>

                <div class="col-lg-6 auth-panel">
                    <div class="auth-topbar">
                        <div class="back-link">
                            @RenderSection("TopLeftActions", required: false)
                        </div>

                        <a href="@Url.Action("Index", "Home")" class="auth-mini-brand">
                            <img src="@Url.Content("~/Images/Logo/app_favicon.png")" alt="DigiMed Clinic" />
                            <span>
                                <strong>DigiMed</strong>
                                <span>Clinic</span>
                            </span>
                        </a>
                    </div>

                    <div class="auth-form-wrap">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function setupPasswordToggle(inputId, toggleId) {
                const passwordInput = document.getElementById(inputId);
                const toggleIconContainer = document.getElementById(toggleId);

                if (passwordInput && toggleIconContainer) {
                    const iconElement = toggleIconContainer.querySelector('i');

                    toggleIconContainer.addEventListener('click', function () {
                        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                        passwordInput.setAttribute('type', type);

                        if (type === 'password') {
                            iconElement.classList.remove('fa-eye-slash');
                            iconElement.classList.add('fa-eye');
                        } else {
                            iconElement.classList.remove('fa-eye');
                            iconElement.classList.add('fa-eye-slash');
                        }
                    });
                }
            }

            setupPasswordToggle('loginPassword', 'toggleLoginPassword');
            setupPasswordToggle('regPassword', 'toggleRegPassword');
            setupPasswordToggle('regConfirmPassword', 'toggleRegConfirmPassword');
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
