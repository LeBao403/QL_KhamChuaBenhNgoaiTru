@{
    Layout = null;
    var detail = ViewBag.ErrorMessage as string;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Error</title>
    <style>
        body { font-family: Segoe UI, sans-serif; padding: 24px; max-width: 720px; margin: 0 auto; }
        .detail { background: #fff3cd; border: 1px solid #ffc107; padding: 12px 16px; margin-top: 16px; border-radius: 6px; white-space: pre-wrap; word-break: break-word; }
    </style>
</head>
<body>
    <hgroup>
        <h1>Error.</h1>
        <h2>An error occurred while processing your request.</h2>
    </hgroup>
    @if (!string.IsNullOrWhiteSpace(detail))
    {
        <div class="detail"><strong>Chi tiết:</strong><br />@detail</div>
    }
</body>
</html>
