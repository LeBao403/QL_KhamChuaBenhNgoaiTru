@{
    ViewBag.Title = "Kết quả thanh toán";
    Layout = "~/Views/Shared/_Layout_Client.cshtml"; // Thay đúng layout của bác nếu cần
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0 rounded-4 p-5">
                @if (ViewBag.Status == "success")
                {
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    <h2 class="fw-bold mt-4 text-success">Giao dịch thành công!</h2>
                    <p class="text-muted fs-5">@ViewBag.Message</p>
                    <p>Cảm ơn quý khách đã sử dụng dịch vụ của DIGIMED CLINIC.</p>
                }
                else
                {
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 5rem;"></i>
                    <h2 class="fw-bold mt-4 text-danger">Giao dịch thất bại</h2>
                    <p class="text-muted fs-5">@ViewBag.Message</p>
                    <p>Vui lòng kiểm tra lại số dư thẻ hoặc liên hệ bộ phận hỗ trợ.</p>
                }

                <div class="mt-4">
                    <a href="@Url.Action("LichKham", "BenhNhanPortal")" class="btn btn-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Quay lại Lịch Khám
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>