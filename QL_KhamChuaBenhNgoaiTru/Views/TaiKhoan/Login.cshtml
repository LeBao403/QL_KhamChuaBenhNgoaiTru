@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section TopLeftActions {
    <a href="@Url.Action("Index", "Home")">
        <i class="fas fa-arrow-left"></i>
        <span>Quay về trang chủ</span>
    </a>
}

<div class="auth-form-header">
    <h2 class="form-title">Đăng nhập tài khoản</h2>
    <p class="form-description">Tiếp tục theo dõi lịch khám và hồ sơ cá nhân trong giao diện đồng bộ với trang chủ.</p>
</div>

<div class="auth-info-strip">
    <span class="icon"><i class="fas fa-shield-halved"></i></span>
    <div>
        <strong>Đăng nhập an toàn và nhanh chóng</strong>
        <span>Dùng số điện thoại hoặc username đã đăng ký.</span>
    </div>
</div>

<div class="auth-surface">
    <div class="auth-section-label">
        <i class="fas fa-user-circle"></i>
        <span>Thông tin truy cập</span>
    </div>

    <form action="@Url.Action("Login", "TaiKhoan")" method="post" id="form-login">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-3 text-center">@TempData["SuccessMessage"]</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mb-3 validation-alert text-center">@ViewBag.Error</div>
        }

        <div class="form-floating mb-3">
            <input type="text" name="username" class="form-control" id="loginUsername" placeholder="SĐT hoặc username" required autofocus />
            <label for="loginUsername">SĐT hoặc username</label>
        </div>

        <div class="form-floating mb-3 position-relative">
            <input type="password" name="password" class="form-control" id="loginPassword" placeholder="Mật khẩu" required />
            <label for="loginPassword">Mật khẩu</label>
            <span class="password-toggle-icon" id="toggleLoginPassword">
                <i class="fas fa-eye"></i>
            </span>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                <label class="form-check-label" for="rememberMe">
                    Ghi nhớ tôi
                </label>
            </div>
            <a href="#" class="auth-inline-link">Quên mật khẩu?</a>
        </div>

        <button type="submit" class="btn btn-submit">
            Đăng nhập
            <i class="fas fa-arrow-right"></i>
        </button>
    </form>

    <div class="auth-divider"></div>

    <div class="toggle-link">
        Chưa có tài khoản?
        <a href="@Url.Action("Register", "TaiKhoan")">Đăng ký ngay</a>
    </div>
</div>

<div class="auth-footnote">
    Bằng việc đăng nhập, bạn tiếp tục sử dụng hệ thống DigiMed Clinic.
</div>
