@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section TopLeftActions {
    <div class="mb-3">
        <a href="@Url.Action("Index", "Home")" style="color:var(--dark-text); text-decoration:none; font-weight:500;">
            <i class="fas fa-arrow-left me-1"></i> Quay về Trang chủ
        </a>
    </div>
}

<h2 class="form-title">Đăng nhập</h2>

<form action="@Url.Action("Login", "TaiKhoan")" method="post" id="form-login">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success p-2 mb-3 text-center">@TempData["SuccessMessage"]</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger p-2 mb-3 validation-alert text-center">@ViewBag.Error</div>
    }

    <div class="form-floating mb-3">
        <input type="text" name="username" class="form-control" id="loginUsername" placeholder="SĐT (Hoặc Username)" required autofocus />
        <label for="loginUsername">SĐT (Hoặc Username)</label>
    </div>

    <div class="form-floating mb-3 position-relative">
        <input type="password" name="password" class="form-control" id="loginPassword" placeholder="Mật khẩu" required />
        <label for="loginPassword">Mật khẩu</label>
        <span class="password-toggle-icon" id="toggleLoginPassword" style="position: absolute; right: 15px; top: 18px; cursor: pointer; z-index: 10;">
            <i class="fas fa-eye"></i>
        </span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" value="" id="rememberMe">
            <label class="form-check-label" for="rememberMe">
                Ghi nhớ tôi
            </label>
        </div>
        <a href="#" class="toggle-link p-0" style="text-align: right;">Quên mật khẩu?</a>
    </div>

    <button type="submit" class="btn btn-submit w-100">Đăng nhập</button>
</form>

<div class="toggle-link mt-3 text-center">
    <span id="toggle-text">Chưa có tài khoản?</span>
    <a href="@Url.Action("Register", "TaiKhoan")">Đăng ký ngay</a>
</div>