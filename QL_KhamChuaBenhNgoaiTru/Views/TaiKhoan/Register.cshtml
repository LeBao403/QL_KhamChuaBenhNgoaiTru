@{
    ViewBag.Title = "Đăng ký";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section TopLeftActions {
    <div class="mb-3">
        <a href="@Url.Action("Index", "Home")" style="color:var(--dark-text); text-decoration:none; font-weight:500;">
            <i class="fas fa-arrow-left me-1"></i> Quay về Trang chủ
        </a>
    </div>
}

<h2 class="form-title">Tạo tài khoản</h2>

<form action="@Url.Action("Register", "TaiKhoan")" method="post" id="form-register-razor">

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger p-2 mb-3 validation-alert text-center">@ViewBag.Error</div>
    }

    <div class="form-floating mb-3">
        <input type="text" name="hoTen" class="form-control" id="regName" placeholder="Họ và tên" required />
        <label for="regName">Họ và tên</label>
    </div>

    <div class="form-floating mb-3">
        <input type="tel" name="username" class="form-control" id="regPhone" placeholder="Số điện thoại" required />
        <label for="regPhone">Số điện thoại (Tên đăng nhập)</label>
    </div>

    <div class="form-floating mb-3">
        <input type="email" name="email" class="form-control" id="regEmail" placeholder="Email" required />
        <label for="regEmail">Email <span class="text-danger">*</span></label>
    </div>

    <div class="form-floating mb-3 position-relative">
        <input type="password" name="password" class="form-control" id="regPassword" placeholder="Mật khẩu" required />
        <label for="regPassword">Mật khẩu</label>
        <span class="password-toggle-icon" id="toggleRegPassword" style="position: absolute; right: 15px; top: 18px; cursor: pointer; z-index: 10;">
            <i class="fas fa-eye"></i>
        </span>
    </div>

    <div class="form-floating mb-4 position-relative">
        <input type="password" name="confirmPassword" class="form-control" id="regConfirmPassword" placeholder="Nhập lại mật khẩu" required />
        <label for="regConfirmPassword">Nhập lại mật khẩu</label>
        <span class="password-toggle-icon" id="toggleRegConfirmPassword" style="position: absolute; right: 15px; top: 18px; cursor: pointer; z-index: 10;">
            <i class="fas fa-eye"></i>
        </span>
    </div>

    <button type="submit" class="btn btn-submit w-100">Tạo tài khoản</button>

    <div class="toggle-link mt-3 text-center">
        <span id="toggle-text">Đã có tài khoản?</span>
        <a href="@Url.Action("Login", "TaiKhoan")">Đăng nhập</a>
    </div>
</form>

@section Scripts {
    <script>
        // Script hỗ trợ ẩn/hiện con mắt mật khẩu (nếu project chưa tích hợp sẵn)
        document.querySelectorAll('.password-toggle-icon').forEach(function(icon) {
            icon.addEventListener('click', function() {
                var input = this.previousElementSibling.previousElementSibling;
                var i = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    i.classList.remove('fa-eye');
                    i.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    i.classList.remove('fa-eye-slash');
                    i.classList.add('fa-eye');
                }
            });
        });
    </script>
}