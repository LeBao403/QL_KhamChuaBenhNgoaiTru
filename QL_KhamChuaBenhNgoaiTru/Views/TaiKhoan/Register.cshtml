@{
    ViewBag.Title = "Đăng ký";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@section TopLeftActions {
    <a href="@Url.Action("Index", "Home")">
        <i class="fas fa-arrow-left"></i>
        <span>Quay về trang chủ</span>
    </a>
}

<div class="auth-form-header">
    <h2 class="form-title">Đăng ký tài khoản mới</h2>
    <p class="form-description">Tạo tài khoản để đặt lịch trực tuyến và quản lý thông tin cá nhân trên hệ thống DigiMed.
    </p>
</div>

<div class="auth-info-strip">
    <span class="icon"><i class="fas fa-notes-medical"></i></span>
    <div>
        <strong>Thiết lập tài khoản trong vài bước</strong>
    </div>
</div>

<div class="auth-surface">
    <div class="auth-section-label">
        <i class="fas fa-address-card"></i>
        <span>Thông tin cơ bản</span>
    </div>

    <form action="@Url.Action("Register", "TaiKhoan")" method="post" id="form-register-razor">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mb-3 validation-alert text-center">@ViewBag.Error</div>
        }

        <div class="form-floating mb-3">
            <input type="text" name="hoTen" class="form-control" id="regName" placeholder="Họ và tên" required />
            <label for="regName">Họ và tên</label>
        </div>

        <div class="form-floating mb-3">
            <input type="tel" name="username" class="form-control" id="regPhone" placeholder="Số điện thoại" required />
            <label for="regPhone">Số điện thoại (Tên đăng nhập)</label>
        </div>

        <div class="form-floating mb-3">
            <input type="email" name="email" class="form-control" id="regEmail" placeholder="Email" required />
            <label for="regEmail">Email <span class="text-danger">*</span></label>
        </div>

        <div class="form-floating mb-3 position-relative">
            <input type="password" name="password" class="form-control" id="regPassword" placeholder="Mật khẩu"
                   required />
            <label for="regPassword">Mật khẩu</label>
            <span class="password-toggle-icon" id="toggleRegPassword">
                <i class="fas fa-eye"></i>
            </span>
        </div>

        <div class="form-floating mb-4 position-relative">
            <input type="password" name="confirmPassword" class="form-control" id="regConfirmPassword"
                   placeholder="Nhập lại mật khẩu" required />
            <label for="regConfirmPassword">Nhập lại mật khẩu</label>
            <span class="password-toggle-icon" id="toggleRegConfirmPassword">
                <i class="fas fa-eye"></i>
            </span>
        </div>

        <button type="submit" class="btn btn-submit">
            Tạo tài khoản
            <i class="fas fa-arrow-right"></i>
        </button>
    </form>

    <div class="auth-divider"></div>

    <div class="toggle-link">
        Đã có tài khoản?
        <a href="@Url.Action("Login", "TaiKhoan")">Đăng nhập</a>
    </div>
</div>

<div class="auth-footnote">
    Thông tin đăng ký được dùng cho chức năng đăng nhập và đặt lịch khám.
</div>

<script>