<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Kho Dược</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f4f6f9; }
        .sidebar {
            min-height: 100vh;
            background-color: #1a252f;
            color: white;
        }
        .sidebar .nav-link {
            color: #c2c7d0;
            padding: 12px 18px;
            border-radius: 8px;
            margin: 3px 10px;
            transition: all 0.2s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }
        .sidebar .nav-link i { width: 22px; text-align: center; }
        .sidebar .sidebar-brand {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            text-align: center;
            letter-spacing: 0.5px;
        }
        .top-navbar {
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .card-stat {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card-stat:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        }
        .stat-icon { font-size: 2rem; opacity: 0.9; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar col-md-2 p-0">
            <div class="sidebar-brand">
                <i class="bi bi-hospital-fill me-2 text-primary"></i>QUẢN LÝ KHO
            </div>
            <nav class="nav flex-column mt-2">
                <a href="@Url.Action("Index", "Dashboard", new { area = "NhanVienKho" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a href="@Url.Action("Index", "PhieuNhap", new { area = "NhanVienKho" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PhieuNhap" ? "active" : "")">
                    <i class="bi bi-file-earmark-plus"></i> Phiếu nhập kho
                </a>
                <a href="@Url.Action("Index", "TonKho", new { area = "NhanVienKho" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "TonKho" ? "active" : "")">
                    <i class="bi bi-box-seam"></i> Tồn kho
                </a>
                <a href="@Url.Action("Index", "Thuoc", new { area = "NhanVienKho" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Thuoc" ? "active" : "")">
                    <i class="bi bi-capsule"></i> Tra cứu thuốc
                </a>
                <a href="@Url.Action("Index", "NhaCungCap", new { area = "NhanVienKho" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhaCungCap" ? "active" : "")">
                    <i class="bi bi-truck"></i> Nhà cung cấp
                </a>

                <div class="mt-4 border-top border-secondary mx-3 pt-3">
                    <a href="@Url.Action("Logout", "TaiKhoan", new { area = "" })"
                       class="nav-link text-danger">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </a>
                </div>
            </nav>
        </div>

        <!-- Main content -->
        <div class="col-md-10">
            <!-- Top Navbar -->
            <div class="top-navbar d-flex justify-content-between align-items-center px-4 py-3 mb-3">
                <h4 class="mb-0 text-dark fw-bold">@ViewBag.Title</h4>
                <div class="user-info d-flex align-items-center gap-3">
                    <div class="text-end">
                        <div class="fw-bold text-dark">@(Session["HoTenNV"] ?? "Nhân viên kho")</div>
                        <small class="text-muted"><i class="bi bi-person-badge me-1"></i>Nhân viên kho</small>
                    </div>
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;">
                        <i class="bi bi-person-circle fs-4 text-secondary"></i>
                    </div>
                </div>
            </div>

            <!-- Alert messages -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mx-4" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mx-4" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Page content -->
            <div class="container-fluid px-4 pb-4">
                @RenderBody()
            </div>
        </div>
    </div>

    @* jQuery phải có trước các view dùng $ (vd: PhieuNhap/Create) — Bootstrap 5 không kèm jQuery *@
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
