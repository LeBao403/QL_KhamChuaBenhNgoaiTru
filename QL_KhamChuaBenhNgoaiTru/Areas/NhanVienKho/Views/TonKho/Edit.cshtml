@model QL_KhamChuaBenhNgoaiTru.DBContext.KhoNhapDB.TonKhoViewModel
@{
    Layout = "~/Areas/NhanVienKho/Views/Shared/_Layout_NhanVienKho.cshtml";
    ViewBag.Title = "Điều chỉnh số lượng tồn kho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-dark mb-0">
        <i class="bi bi-pencil-square text-warning me-2"></i>Điều chỉnh số lượng tồn kho
    </h4>
    <a href="@Url.Action("Index", "TonKho", new { area = "NhanVienKho" })" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row g-4">
    <!-- Form điều chỉnh -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">
                <i class="bi bi-pencil text-warning me-2"></i>Cập nhật số lượng
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Edit", "TonKho", new { area = "NhanVienKho" }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.MaTonKho)

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mã thuốc</label>
                        <input type="text" class="form-control" value="@Model.MaThuoc" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên thuốc</label>
                        <input type="text" class="form-control" value="@Model.TenThuoc" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mã lô</label>
                        <input type="text" class="form-control" value="@Model.MaLo" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số lượng hiện tại</label>
                        <input type="text" class="form-control" value="@Model.SoLuongTon @Model.DonViCoBan" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger">Số lượng mới <span class="text-danger">*</span></label>
                        <input type="number" name="SoLuongMoi" class="form-control" min="0"
                               value="@Model.SoLuongTon" required />
                        <div class="form-text">Nhập số nguyên >= 0</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i> Lưu thay đổi
                        </button>
                        <a href="@Url.Action("Index", "TonKho", new { area = "NhanVienKho" })" class="btn btn-outline-secondary">
                            Hủy
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Thông tin hiện tại -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">
                <i class="bi bi-info-circle text-primary me-2"></i>Thông tin lô thuốc
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:160px">Kho:</td>
                        <td><span class="badge bg-secondary">@Model.TenKho</span></td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.TenPhong))
                    {
                        <tr>
                            <td class="text-muted">Phòng:</td>
                            <td>@Model.TenPhong</td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted">Đơn vị:</td>
                        <td>@Model.DonViCoBan</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ngày sản xuất:</td>
                        <td>@(Model.NgaySanXuat?.ToString("dd/MM/yyyy") ?? "-")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Hạn sử dụng:</td>
                        <td>
                            @if (Model.HanSuDung.HasValue)
                            {
                                var daysLeft = (Model.HanSuDung.Value - DateTime.Now).Days;
                                <span>@Model.HanSuDung.Value.ToString("dd/MM/yyyy")</span>
                                if (daysLeft < 0)
                                {
                                    <span class="badge bg-danger ms-2">Đã hết hạn</span>
                                }
                                else if (daysLeft <= 30)
                                {
                                    <span class="badge bg-warning text-dark ms-2">Còn @daysLeft ngày</span>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Giá nhập:</td>
                        <td>@((Model.GiaNhap ?? 0).ToString("N0")) đ</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Thành tiền:</td>
                        <td class="fw-bold text-primary">@((Model.ThanhTien ?? 0).ToString("N0")) đ</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ngày cập nhật:</td>
                        <td>@(Model.NgayCapNhat?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
