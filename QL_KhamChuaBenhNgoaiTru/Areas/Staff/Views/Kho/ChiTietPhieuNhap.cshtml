@{
    ViewBag.Title = "Chi tiết phiếu nhập kho";
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";

    var phieu = Model as QL_KhamChuaBenhNgoaiTru.DBContext.PhieuNhapViewModel;
    var chiTiet = ViewBag.ChiTiet as List<QL_KhamChuaBenhNgoaiTru.DBContext.CT_PhieuNhapViewModel>;
}

<!-- CSS riêng -->
@section Styles {
    <style>
        .info-card {
            border-radius: 16px;
            border: none;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }
        .badge-trangthai {
            font-size: 13px;
            padding: 6px 14px;
            border-radius: 20px;
        }
    </style>
}

<!-- THÔNG BÁO -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ===================== 1. THÔNG TIN PHIẾU ===================== -->
<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="card info-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-file-earmark-text text-primary me-2"></i>Phiếu nhập kho #@phieu.MaPhieuNhap
                    </h5>
                    <small class="text-muted">Ngày lập: @phieu.NgayLapDisplay</small>
                </div>
                <div>
                    @{
                        string badgeClass = phieu.TrangThai switch
                        {
                            "Chờ duyệt" => "bg-warning text-dark",
                            "Đã duyệt" => "bg-success",
                            "Đã hủy" => "bg-secondary",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass badge-trangthai">@phieu.TrangThai</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label small text-muted">Kho nhập hàng</label>
                            <div><span class="badge bg-info text-dark fs-6">@(string.IsNullOrEmpty(phieu.TenKho) ? "—" : phieu.TenKho)</span></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Nhà cung cấp</label>
                            <div class="fw-semibold">@phieu.TenNSX</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Người lập phiếu</label>
                            <div class="fw-semibold">@phieu.TenNguoiLap</div>
                        </div>
                        @if (!string.IsNullOrEmpty(phieu.GhiChu))
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted">Ghi chú</label>
                                <div>@phieu.GhiChu</div>
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        @if (!string.IsNullOrEmpty(phieu.TenNguoiDuyet))
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted">Người duyệt</label>
                                <div class="fw-semibold text-success">@phieu.TenNguoiDuyet</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted">Ngày duyệt</label>
                                <div>@phieu.NgayDuyetDisplay</div>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label small text-muted">Tổng tiền nhập</label>
                            <div class="fs-5 fw-bold text-primary">@phieu.TongTienNhap.ToString("N0") đ</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <!-- Hành động -->
        <div class="card info-card">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold"><i class="bi bi-gear me-2"></i>Hành động</h6>
            </div>
            <div class="card-body">
                @if (phieu.TrangThai == "Chờ duyệt")
                {
                    <div class="alert alert-info mb-3 text-center">
                        <i class="bi bi-hourglass-split me-1"></i>
                        Phiếu đang chờ Admin duyệt
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-3 text-center">
                        <i class="bi bi-info-circle me-1"></i>
                        Phiếu này đã được xử lý
                    </div>
                    if (phieu.TrangThai == "Đã duyệt")
                    {
                        <a href="@Url.Action("PrintPhieuNhap", new { id = phieu.MaPhieuNhap })" target="_blank" class="btn btn-primary w-100 mb-3">
                            <i class="bi bi-printer me-1"></i>In phiếu nhập
                        </a>
                    }
                }
                <hr />
                <a href="@Url.Action("DanhSachPhieuNhap", "Kho")" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

<!-- ===================== 2. BẢNG CHI TIẾT THUỐC ===================== -->
<div class="card info-card">
    <div class="card-header bg-white">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-list-columns text-primary me-2"></i>Chi tiết thuốc nhập (@(chiTiet?.Count ?? 0) mặt hàng)
        </h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Mã thuốc</th>
                        <th>Tên thuốc</th>
                        <th>Số lô</th>
                        <th>Ngày SX</th>
                        <th>Hạn SD</th>
                        <th class="text-end">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                        @if (phieu.TrangThai == "Chờ duyệt")
                        {
                            <th class="text-center" style="width: 50px;"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (chiTiet == null || chiTiet.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">Không có chi tiết</td>
                        </tr>
                    }
                    else
                    {
                        int stt = 1;
                        foreach (var ct in chiTiet)
                        {
                            <tr>
                                <td>@stt</td>
                                <td><code>@ct.MaThuoc</code></td>
                                <td>
                                    <div class="fw-semibold">@ct.TenThuoc</div>
                                    <small class="text-muted">@ct.DonViCoBan</small>
                                </td>
                                <td><code>@ct.MaLo</code></td>
                                <td>@ct.NgaySanXuatDisplay</td>
                                <td>
                                    <span class="badge bg-light text-dark">@ct.HanSuDungDisplay</span>
                                </td>
                                <td class="text-end">@ct.SoLuongNhap.ToString("N0") @ct.DonViCoBan</td>
                                <td class="text-end">@ct.DonGiaNhap.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@ct.ThanhTien.ToString("N0") đ</td>
                                @if (phieu.TrangThai == "Chờ duyệt")
                                {
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger" onclick="xoaChiTiet(@ct.MaCTPN)" title="Loại bỏ chi tiết này">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </td>
                                }
                            </tr>
                            stt++;
                        }
                        <tr class="table-primary fw-bold">
                            <td colspan="8" class="text-end">Tổng cộng:</td>
                            <td class="text-end">@phieu.TongTienNhap.ToString("N0") đ</td>
                            @if (phieu.TrangThai == "Chờ duyệt")
                            {
                                <td></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>


        function xoaChiTiet(maCTPN) {
            Swal.fire({
                title: 'Xóa chi tiết?',
                text: 'Bạn có chắc muốn loại bỏ mặt hàng này khỏi phiếu nhập?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Có, xóa!',
                cancelButtonText: 'Đóng'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("XoaChiTietPhieuNhap", "Kho")',
                        type: 'POST',
                        data: { id: maCTPN },
                        success: function (res) {
                            if (res.success) {
                                location.reload();
                            } else {
                                Swal.fire('Lỗi', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Lỗi', 'Đã xảy ra lỗi khi xóa chi tiết!', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
