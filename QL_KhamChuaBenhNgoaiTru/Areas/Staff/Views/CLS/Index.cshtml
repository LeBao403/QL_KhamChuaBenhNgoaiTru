@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.KetQuaCLS>
@using QL_KhamChuaBenhNgoaiTru.Models
@{
    ViewBag.Title = "Phòng Cận Lâm Sàng";
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";
}

<style>
    :root {
        --primary-blue: #0d6efd;
        --dark-blue: #0a58ca;
        --soft-bg: #f8f9fa;
    }

    body {
        background-color: #f4f7f6;
    }

    .page-header-card {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        border: none;
        border-radius: 15px;
        margin-bottom: 1.5rem;
    }

    .cls-page .card {
        border: 0;
        border-radius: 14px;
        box-shadow: 0 6px 20px rgba(20,40,80,0.08);
    }

    .cls-page .card-header {
        border-radius: 14px 14px 0 0 !important;
        font-weight: 700;
        font-size: .85rem;
        text-transform: uppercase;
        letter-spacing: .3px;
    }

    .queue-table thead th {
        background-color: var(--soft-bg);
        color: #495057;
        font-weight: 700;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #e9ecef;
        padding: .9rem 1rem;
    }

    .queue-table tbody tr {
        transition: background-color .15s ease;
    }

        .queue-table tbody tr:hover {
            background: #f7fbff;
        }

        .queue-table tbody tr.active {
            background: #eaf4ff;
            border-left: 4px solid #0d6efd;
        }

    .patient-link {
        border: 0;
        background: transparent;
        color: #0d6efd;
        font-weight: 700;
        text-align: left;
        padding: 0;
    }

        .patient-link:hover {
            text-decoration: underline;
            color: #0a58ca;
        }

    .patient-info-bar {
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 5px solid #198754;
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
    }

    .info-label {
        color: #6c757d;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 2px;
    }

    .info-value {
        color: #212529;
        font-weight: 700;
        font-size: .9rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        font-size: .95rem;
        padding: .4rem 0;
        border-bottom: 2px solid #e9ecef;
        margin-bottom: .75rem;
    }

        .section-header.green {
            color: #198754;
            border-color: #198754;
        }

        .section-header.blue {
            color: #0d6efd;
            border-color: #0d6efd;
        }

    .btn-action {
        border-radius: 8px;
        transition: all .25s;
        font-weight: 600;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

    .cls-media-panel {
        display: none;
        background: linear-gradient(180deg, #f9fbff 0%, #f4f8ff 100%);
        border: 1px dashed #b9d4ff;
        border-radius: 14px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .cls-media-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(13, 110, 253, 0.08);
        padding: .75rem;
        height: 100%;
    }

    .cls-media-card img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: 10px;
        background: #eef3fb;
    }

    .cls-media-title {
        font-weight: 700;
        color: #0d6efd;
        margin-top: .75rem;
    }

    .cls-media-caption {
        color: #6c757d;
        font-size: .82rem;
        line-height: 1.5;
        margin-top: .25rem;
    }

    @@media screen {
        #print-section {
            display: none;
        }
    }

    @@media print {
        @@page {
            size: A5 landscape;
            margin: 1cm;
        }

        body * {
            visibility: hidden !important;
        }

        #print-section, #print-section * {
            visibility: visible !important;
        }

        #print-section {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            font-family: 'Times New Roman', serif;
            color: #000;
        }

        .print-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
        }

            .print-table th, .print-table td {
                border: 1px solid #000;
                padding: 6px;
                text-align: left;
            }

            .print-table th {
                text-align: center;
                background-color: #f1f1f1;
            }

        .stamp {
            border: 2px solid #0d6efd;
            color: #0d6efd;
            padding: 2px 6px;
            display: inline-block;
            font-weight: 700;
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="cls-page container-fluid py-4">
    <div class="card page-header-card shadow-sm mb-4">
        <div class="card-body text-white p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h3 class="mb-1 fw-bold"><i class="fas fa-vials me-2"></i> TRUNG TÂM CẬN LÂM SÀNG</h3>
                    <p class="mb-0 opacity-75">Tiếp nhận, xử lý và trả kết quả xét nghiệm cho bác sĩ khám.</p>
                </div>
                <div class="text-end">
                    <div class="small opacity-75">Đang chờ</div>
                    <div class="fs-3 fw-bold" id="lblSoCho">@(Model?.Count() ?? 0)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-5">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-list-ol me-2"></i>Hàng Chờ Xét Nghiệm</span>
                    <span class="badge bg-light text-primary rounded-pill" id="lblQueueCount">@(Model?.Count() ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                        <table class="table table-hover queue-table mb-0" id="table-cls">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="text-center" style="width: 56px;">#</th>
                                    <th>Bệnh nhân</th>
                                    <th>Dịch vụ CLS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    var stt = 1;
                                    foreach (var item in Model)
                                    {
                                        <tr id="row-@item.MaKetQua" data-id="@item.MaKetQua" class="cls-row">
                                            <td class="text-center fw-bold">@(stt++)</td>
                                            <td>
                                                <button type="button" class="patient-link cls-select-case" data-id="@item.MaKetQua" onclick="loadCase('@item.MaKetQua', false)">@item.TenBenhNhan</button>
                                                <div class="small text-muted">PKB: @item.MaPhieuKhamBenh</div>
                                            </td>
                                            <td>
                                                <div class="fw-semibold">@item.TenDichVu</div>
                                                <span class="badge bg-warning text-dark">@item.TrangThai</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr id="empty-row"><td colspan="3" class="text-center text-muted py-4">Không có bệnh nhân đang chờ xét nghiệm.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-check-circle me-2"></i>Đã Hoàn Thành (Hôm nay)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-hover queue-table mb-0" id="table-done">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="text-center" style="width: 56px;">#</th>
                                    <th>Bệnh nhân</th>
                                    <th>Dịch vụ CLS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.DanhSachDaXong != null)
                                {
                                    var sttDone = 1;
                                    foreach (var item in ViewBag.DanhSachDaXong)
                                    {
                                        <tr class="cls-row bg-light" id="row-done-@item.MaKetQua" data-id="@item.MaKetQua">
                                            <td class="text-center fw-bold text-success">@(sttDone++)</td>
                                            <td>
                                                <button type="button" class="patient-link cls-history-view" data-id="@item.MaKetQua" onclick="loadCase('@item.MaKetQua', true)">@item.TenBN <i class="fas fa-check-circle text-success ms-1"></i></button>
                                                <div class="small text-muted">@item.Tuoi tuổi | @item.GioiTinh</div>
                                            </td>
                                            <td>
                                                <div class="fw-semibold text-secondary">@item.TenDV</div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">Chưa có xét nghiệm nào hoàn thành.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="card" id="detail-card" style="display:none;">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-flask me-2"></i>Chi Tiết Tiếp Nhận &amp; Trả Kết Quả
                </div>
                <div class="card-body">
                    <input type="hidden" id="hdnMaKetQua" />
                    <input type="hidden" id="hdnMaPhieuKham" />

                    <div class="patient-info-bar">
                        <div class="row g-2">
                            <div class="col-md-5">
                                <div class="info-label">Bệnh nhân</div>
                                <div class="fs-5 fw-bold text-danger" id="lblTenBN"></div>
                                <div class="text-muted small mb-1" id="lblTuoiGT"></div>
                                <div class="text-muted small mb-1"><i class="fas fa-id-badge"></i> CCCD: <span id="lblCCCD" class="fw-bold text-dark"></span></div>
                                <div class="text-muted small mb-1"><i class="fas fa-phone-alt"></i> SĐT: <span id="lblSDT" class="fw-bold text-dark"></span></div>
                                <div class="text-muted small mb-1"><i class="fas fa-map-marker-alt"></i> <span id="lblDiaChi"></span></div>
                                <div class="text-muted small mt-1"><i class="fas fa-id-card"></i> BHYT: <span id="lblBHYT" class="text-success fw-bold"></span></div>
                            </div>
                            <div class="col-md-7 border-start pl-3">
                                <div class="info-label">Thông tin y tế</div>
                                <div class="small mb-1">Mã Phiếu Khám: <strong id="lblMaPhieuKhamText"></strong></div>
                                <div class="small mb-1">Chẩn đoán / Lý do: <strong id="lblLyDo" class="text-dark"></strong></div>
                                <div class="small mb-1">Bác sĩ chỉ định: <strong id="lblBSChiDinh" class="text-dark"></strong></div>
                                <div class="small">Bác sĩ thực hiện: <span id="lblBS" class="fw-bold text-primary"></span></div>
                            </div>
                        </div>
                    </div>

                    <div class="section-header green mb-3">
                        <i class="fas fa-microscope"></i> Thông tin mẫu &amp; Chất lượng
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted mb-1 text-sm">Mẫu xét nghiệm <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm border-primary" id="ui-mau-xn">
                                <option value="Huyết thanh">Huyết thanh</option>
                                <option value="Huyết tương">Huyết tương</option>
                                <option value="Máu toàn phần">Máu toàn phần</option>
                                <option value="Nước tiểu">Nước tiểu</option>
                                <option value="Dịch não tủy">Dịch não tủy</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted mb-1 text-sm">Chất lượng mẫu</label>
                            <select class="form-select form-select-sm border-success" id="ui-chat-luong">
                                <option value="Đạt">Đạt</option>
                                <option value="Không đạt">Không đạt</option>
                            </select>
                        </div>
                    </div>

                    <div class="section-header blue mb-2">
                        <i class="fas fa-chart-line"></i> <span id="ui-ten-xn">Kết quả Xét Nghiệm</span>
                        <div class="ms-auto">
                            <button class="btn btn-warning btn-sm btn-action fw-semibold" id="btn-ket-noi-lis">
                                <i class="fas fa-satellite-dish me-1"></i> Lấy kết quả CLS
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle mb-3" id="tbl-ket-qua-lis">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th style="width: 35%;">Tên chỉ số</th>
                                    <th style="width: 65%;">Kết quả</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>

                    <div class="cls-media-panel" id="cls-image-panel">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                            <div class="fw-bold text-primary">
                                <i class="fas fa-image me-2"></i>Hình ảnh CLS
                            </div>
                            <div class="small text-muted">Ảnh demo lấy từ thư mục Images/cls</div>
                        </div>
                        <div class="row g-3" id="cls-image-grid"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" style="color: #0d6efd;">Kết luận (LIS):</label>
                        <input type="text" class="form-control" id="ui-ket-luan" placeholder="Nhập kết luận chạy máy / chỉ số (nếu có)..." />
                    </div>

                    <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-3">
                        <button class="btn btn-outline-secondary btn-action fw-semibold" id="btn-in-phieu">
                            <i class="fas fa-print me-1"></i> In kết quả
                        </button>
                        <button class="btn btn-success btn-action fw-semibold px-4" id="btn-xac-nhan">
                            <i class="fas fa-paper-plane me-1"></i> Gửi kết quả
                        </button>
                    </div>
                </div>
            </div>

            <div class="card" id="empty-card">
                <div class="card-body text-center py-5 text-muted">
                    <i class="fas fa-vials fa-3x mb-3 text-light"></i>
                    <h5 class="mb-1 fw-bold">Chưa chọn bệnh nhân</h5>
                    <div>Nhấn vào tên bệnh nhân ở cột bên trái để tiếp nhận và xem kết quả.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="print-section">
    <div style="display:flex;justify-content:space-between;border-bottom:2px solid #000;padding-bottom:4px;">
        <div style="width:45%;text-align:center;">
            <div style="font-weight:700;">SỞ Y TẾ ĐẮK LẮK</div>
            <div style="font-weight:700;">PHÒNG KHÁM ĐA KHOA CHẤT LƯỢNG CAO SÀI GÒN</div>
        </div>
        <div style="width:55%;text-align:center;">
            <div style="font-weight:700;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</div>
            <div style="font-weight:700;">Độc lập - Tự do - Hạnh phúc</div>
        </div>
    </div>

    <h2 style="text-align:center;margin:12px 0 8px;font-weight:700;">PHIẾU KẾT QUẢ XÉT NGHIỆM</h2>

    <div style="line-height:1.6;">
        <div style="display:flex;">
            <div style="flex:2;">Họ và tên: <b id="prt-ten" style="text-transform:uppercase;"></b></div>
            <div style="flex:1;">Tuổi: <span id="prt-tuoi"></span></div>
            <div style="flex:1;">Giới tính: <span id="prt-gt"></span></div>
        </div>
        <div style="display:flex;">
            <div style="flex:2;">Địa chỉ: <span id="prt-diachi"></span></div>
            <div style="flex:1;">Số BHYT: <b id="prt-bhyt"></b></div>
        </div>
        <div style="display:flex;">
            <div style="flex:2;">Chẩn đoán: <span id="prt-chandoan"></span></div>
            <div style="flex:1;">Bác sĩ chỉ định: <b id="prt-bschidinh"></b></div>
        </div>
    </div>

    <div style="line-height:1.6;margin-top:12px;margin-bottom:12px;">
        <div style="display:flex;">
            <div style="flex:2;">Mẫu xét nghiệm: <b id="prt-mauxn"></b></div>
            <div style="flex:1;">Chất lượng mẫu: <span id="prt-chatluong"></span></div>
        </div>
        <div style="display:flex; margin-top:4px;">
            <div style="flex:1;">Kết luận: <b id="prt-ketluan" style="color:red;"></b></div>
        </div>
    </div>

    <table class="print-table">
        <thead>
            <tr>
                <th style="width:35%;">Tên chỉ số</th>
                <th style="width:25%;">Kết quả</th>
                <th style="width:20%;">Đơn vị</th>
                <th style="width:20%;">Trị số bình thường</th>
            </tr>
        </thead>
        <tbody id="prt-lis-tbody">
        </tbody>
    </table>

    <div style="display:flex; justify-content:space-between; text-align:center; margin-top:24px;">
        <div style="width:40%;">
            <div style="font-weight:700;">BÁC SĨ CHỈ ĐỊNH</div>
            <div style="margin-top:70px; font-weight:bold;" id="prt-sign-bschidinh"></div>
        </div>
        <div style="width:40%;">
            <div id="prt-date-footer" style="font-style:italic; margin-bottom:5px;"></div>
            <div style="font-weight:700;">NGƯỜI THỰC HIỆN</div>
            <div style="margin-top:70px; font-weight:bold;" id="prt-sign-thuchien"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            var defaultSampleOptions = ['Huyết thanh', 'Huyết tương', 'Máu toàn phần', 'Nước tiểu', 'Khác'];

            function normalizeText(value) {
                return (value || '')
                    .toString()
                    .trim()
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/đ/g, 'd');
            }

            function parseStoredResult(rawValue) {
                var parsed = { data: [], ketluan: '', images: [] };
                if (!rawValue) return parsed;

                if (rawValue.startsWith('[')) {
                    try { parsed.data = JSON.parse(rawValue) || []; } catch (e) { }
                    return parsed;
                }

                if (rawValue.startsWith('{')) {
                    try {
                        var payload = JSON.parse(rawValue) || {};
                        parsed.data = Array.isArray(payload.data) ? payload.data : [];
                        parsed.ketluan = payload.ketluan || '';
                        parsed.images = Array.isArray(payload.images) ? payload.images : [];
                        parsed.resultType = payload.resultType || '';
                        return parsed;
                    } catch (e) { }
                }

                parsed.ketluan = rawValue;
                return parsed;
            }

            function setSampleOptions(options, selectedValue) {
                var items = (options && options.length ? options.slice() : defaultSampleOptions.slice());
                if (selectedValue && items.indexOf(selectedValue) < 0) {
                    items.unshift(selectedValue);
                }

                var html = items.map(function (item) {
                    return '<option value="' + item + '">' + item + '</option>';
                }).join('');

                $('#ui-mau-xn').html(html);
                $('#ui-mau-xn').val(selectedValue || items[0] || '');
            }

            function setQualityValue(value) {
                var qualityValue = value || 'Đạt';
                if ($('#ui-chat-luong option[value="' + qualityValue + '"]').length === 0) {
                    $('#ui-chat-luong').append('<option value="' + qualityValue + '">' + qualityValue + '</option>');
                }
                $('#ui-chat-luong').val(qualityValue);
            }

            function setReadonly(readOnly) {
                $('#ui-mau-xn').prop('disabled', readOnly);
                $('#ui-chat-luong').prop('disabled', readOnly);
                $('#ui-ket-luan').prop('disabled', readOnly);

                if (readOnly) {
                    $('#ui-mau-xn, #ui-chat-luong, #ui-ket-luan').addClass('bg-light');
                } else {
                    $('#ui-mau-xn, #ui-chat-luong, #ui-ket-luan').removeClass('bg-light');
                }
            }

            function renderLISUi(lisData) {
                var html = '';
                if (!lisData || lisData.length === 0) {
                    $('#tbl-ket-qua-lis thead').html('<tr><th style="width: 50%;">Tên chỉ số</th><th style="width: 50%;">Kết quả</th></tr>');
                    html = '<tr><td colspan="2" class="text-center text-muted py-3">Chưa có kết quả. Nhấn nút lấy kết quả để mô phỏng máy CLS.</td></tr>';
                } else {
                    var hasMetaColumns = lisData.some(function (item) {
                        var donVi = (item.DonVi || '').toString().trim();
                        var thamChieu = (item.ThamChieu || '').toString().trim();
                        return (donVi && donVi !== '-') || (thamChieu && thamChieu !== '-');
                    });

                    if (hasMetaColumns) {
                        $('#tbl-ket-qua-lis thead').html('<tr><th style="width: 30%;">Tên chỉ số</th><th style="width: 25%;">Kết quả</th><th style="width: 20%;">Đơn vị</th><th style="width: 25%;">Chỉ số bình thường</th></tr>');
                    } else {
                        $('#tbl-ket-qua-lis thead').html('<tr><th style="width: 35%;">Tên chỉ số</th><th style="width: 65%;">Kết quả</th></tr>');
                    }

                    lisData.forEach(function (item) {
                        var rowClass = item.Warning ? 'text-danger fw-bold' : 'fw-bold';
                        if (hasMetaColumns) {
                            html += '<tr>' +
                                '<td class="fw-semibold">' + item.Ten + '</td>' +
                                '<td class="text-center ' + rowClass + '">' + item.GiaTri + '</td>' +
                                '<td class="text-center text-muted">' + (item.DonVi || '-') + '</td>' +
                                '<td class="text-center text-muted">' + (item.ThamChieu || '-') + '</td>' +
                                '</tr>';
                        } else {
                            html += '<tr>' +
                                '<td class="fw-semibold">' + item.Ten + '</td>' +
                                '<td class="' + rowClass + '">' + item.GiaTri + '</td>' +
                                '</tr>';
                        }
                    });
                }
                $('#tbl-ket-qua-lis tbody').html(html);
            }

            function renderMediaUi(images) {
                if (!images || !images.length) {
                    $('#cls-image-grid').empty();
                    $('#cls-image-panel').hide();
                    return;
                }

                var html = images.map(function (image) {
                    return '' +
                        '<div class="col-md-6">' +
                            '<div class="cls-media-card">' +
                                '<img src="' + image.url + '" alt="' + (image.title || 'Hình ảnh CLS') + '" />' +
                                '<div class="cls-media-title">' + (image.title || 'Hình ảnh CLS') + '</div>' +
                                '<div class="cls-media-caption">' + (image.caption || '') + '</div>' +
                            '</div>' +
                        '</div>';
                }).join('');

                $('#cls-image-grid').html(html);
                $('#cls-image-panel').show();
            }

            function renderPrint(data, lisData, mauXN, chatLuong) {
                var now = new Date();
                var hasMetaColumns = (lisData || []).some(function (item) {
                    var donVi = (item.DonVi || '').toString().trim();
                    var thamChieu = (item.ThamChieu || '').toString().trim();
                    return (donVi && donVi !== '-') || (thamChieu && thamChieu !== '-');
                });

                $('#prt-ten').text(data.TenBenhNhan || data.TenBN || '');
                $('#prt-tuoi').text(data.Tuoi || '');
                $('#prt-gt').text(data.GioiTinh || '');
                $('#prt-chandoan').text(data.LyDoDenKham || data.ChanDoan || '');
                $('#prt-tenxn').text(data.TenDV || data.TenDichVu || '');
                $('#prt-mauxn').text(mauXN || 'Huyết thanh');
                $('#prt-chatluong').text(chatLuong || 'Đạt');
                $('#prt-ketluan').text($('#ui-ket-luan').val() || '');

                $('#prt-diachi').text(data.DiaChi || 'Chưa cập nhật');
                $('#prt-bhyt').text(data.SoTheBHYT || 'Không có');
                $('#prt-bschidinh').text(data.TenBacSiChiDinh || '');
                $('#prt-sign-bschidinh').text(data.TenBacSiChiDinh || '');
                $('#prt-sign-thuchien').text(data.TenNguoiThucHien || data.MaBacSiThucHien || '');

                $('#print-section .print-table thead').html(
                    hasMetaColumns
                        ? '<tr><th style="width:35%;">Tên chỉ số</th><th style="width:25%;">Kết quả</th><th style="width:20%;">Đơn vị</th><th style="width:20%;">Trị số bình thường</th></tr>'
                        : '<tr><th style="width:35%;">Tên chỉ số</th><th style="width:65%;">Kết quả</th></tr>'
                );

                var tbody = '';
                if (lisData && lisData.length > 0) {
                    lisData.forEach(function (item) {
                        var style = item.Warning ? 'color: red; font-weight: bold;' : 'font-weight: bold;';
                        if (hasMetaColumns) {
                            tbody += '<tr>' +
                                '<td>' + item.Ten + '</td>' +
                                '<td style="text-align:center;"><div style="' + style + '">' + item.GiaTri + '</div></td>' +
                                '<td style="text-align:center;">' + (item.DonVi || '-') + '</td>' +
                                '<td style="text-align:center;">' + (item.ThamChieu || '-') + '</td>' +
                                '</tr>';
                        } else {
                            tbody += '<tr>' +
                                '<td>' + item.Ten + '</td>' +
                                '<td><div style="' + style + '">' + item.GiaTri + '</div></td>' +
                                '</tr>';
                        }
                    });
                }
                $('#prt-lis-tbody').html(tbody);
                $('#prt-date-footer').text('Đắk Lắk, ngày ' + now.getDate() + ' tháng ' + (now.getMonth() + 1) + ' năm ' + now.getFullYear());
            }

            function updateResultUi(resultPayload) {
                var payload = resultPayload || { data: [], images: [] };
                var rows = payload.data || [];
                var images = payload.images || [];

                $('#btn-ket-noi-lis').data('lis', rows);
                $('#btn-ket-noi-lis').data('demoResult', payload);
                $('#btn-in-phieu').data('plis', rows);
                $('#btn-in-phieu').data('pimages', images);

                renderLISUi(rows);
                renderMediaUi(images);
            }

            function getServiceProfile(serviceName) {
                var normalized = normalizeText(serviceName);
                var profile = {
                    sampleOptions: defaultSampleOptions.slice(),
                    sampleDefault: 'Huyết thanh',
                    qualityDefault: 'Đạt',
                    actionLabel: 'Lấy kết quả CLS'
                };

                if (normalized.includes('nuoc tieu')) {
                    profile.sampleOptions = ['Nước tiểu'];
                    profile.sampleDefault = 'Nước tiểu';
                } else if (normalized.includes('mau') || normalized.includes('huyet') || normalized.includes('hba1c')) {
                    profile.sampleOptions = ['Máu toàn phần', 'Huyết thanh', 'Huyết tương'];
                    profile.sampleDefault = 'Máu toàn phần';
                } else if (normalized.includes('glucose') || normalized.includes('creatinin') || normalized.includes('cholesterol') || normalized.includes('gan')) {
                    profile.sampleOptions = ['Huyết thanh', 'Huyết tương'];
                    profile.sampleDefault = 'Huyết thanh';
                } else if (normalized.includes('sieu am') || normalized.includes('x-quang') || normalized.includes('x quang') || normalized.includes('noi soi') || normalized.includes('dien tam do') || normalized.includes('ecg')) {
                    profile.sampleOptions = ['Không áp dụng'];
                    profile.sampleDefault = 'Không áp dụng';
                    profile.qualityDefault = 'Không áp dụng';
                }

                return profile;
            }

            function applyServiceProfile(profile, selectedSample, selectedQuality) {
                var sampleValue = selectedSample || profile.sampleDefault || defaultSampleOptions[0];
                var qualityValue = selectedQuality || profile.qualityDefault || 'Đạt';

                setSampleOptions(profile.sampleOptions || defaultSampleOptions, sampleValue);
                setQualityValue(qualityValue);
                $('#btn-ket-noi-lis').html('<i class="fas fa-satellite-dish me-1"></i> ' + (profile.actionLabel || 'Lấy kết quả CLS'));
            }

            $('#btn-ket-noi-lis').off('click');
            $('#btn-in-phieu').off('click');
            $('#btn-xac-nhan').off('click');

            window.loadCase = function (maKetQua, fromHistory) {
                maKetQua = String(maKetQua);
                $('.cls-row').removeClass('active');

                if (fromHistory) {
                    $('#row-done-' + maKetQua).addClass('active');
                } else {
                    $('#row-' + maKetQua).addClass('active');
                }

                $.post('@Url.Action("GetChiTiet", "CLS")', { maKetQua: maKetQua }, function (res) {
                    if (!res.success) {
                        Swal.fire('Lỗi', res.message, 'error');
                        return;
                    }

                    var d = res.Data;
                    var profile = getServiceProfile(d.TenDV || d.TenDichVu || '');
                    var parsed = parseStoredResult(d.NoiDungKetQua || '');
                    var currentStaff = '@(Session["HoTenNV"] ?? "Nhân viên")';
                    var bsThucHien = d.TenNguoiThucHien || d.MaBacSiThucHien;

                    $('#hdnMaKetQua').val(d.MaKetQua);
                    $('#hdnMaPhieuKham').val(d.MaPhieuKhamBenh);
                    $('#lblTenBN').text(d.TenBenhNhan || d.TenBN || '');
                    $('#lblTuoiGT').text((d.Tuoi || '') + ' tuổi / ' + (d.GioiTinh || ''));
                    $('#lblCCCD').text(d.CCCD || 'Chưa cập nhật');
                    $('#lblSDT').text(d.SDT || 'Chưa cập nhật');
                    $('#lblDiaChi').text(d.DiaChi || 'Chưa cập nhật');
                    $('#lblBHYT').text(d.SoTheBHYT || 'Không có');
                    $('#lblMaPhieuKhamText').text(d.MaPhieuKhamBenh || '');
                    $('#lblBSChiDinh').text(d.TenBacSiChiDinh || '--');
                    $('#lblLyDo').text(d.ChanDoan || d.LyDoDenKham || '');
                    $('#ui-ten-xn').text(d.TenDV || d.TenDichVu || '');

                    if (bsThucHien) {
                        $('#lblBS').text(bsThucHien);
                    } else {
                        $('#lblBS').html(currentStaff + ' <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">Đang thực hiện</span>');
                    }

                    applyServiceProfile(profile, d.MauXetNghiem, d.ChatLuongMau);
                    $('#ui-ket-luan').val(parsed.ketluan || '');

                    $('#detail-card').data('caseData', d);
                    $('#btn-ket-noi-lis').data('profile', profile);
                    $('#btn-in-phieu').data('pdata', d);

                    updateResultUi(parsed);
                    renderPrint(d, parsed.data || [], $('#ui-mau-xn').val(), $('#ui-chat-luong').val());

                    var daCoKetQua = (d.TrangThai === 'Đã có kết quả' || fromHistory === true);
                    $('#btn-xac-nhan').toggle(!daCoKetQua);
                    $('#btn-ket-noi-lis').prop('disabled', daCoKetQua);
                    setReadonly(daCoKetQua);

                    $('#empty-card').hide();
                    $('#detail-card').show();
                });
            };

            $('#btn-in-phieu').on('click', function () {
                var d = $(this).data('pdata');
                var rows = $(this).data('plis') || [];
                var images = $(this).data('pimages') || [];
                var hasTextConclusion = ($('#ui-ket-luan').val() || '').trim().length > 0;

                if (!rows.length && !images.length && !hasTextConclusion) {
                    Swal.fire('Chú ý', 'Chưa có kết quả chuyên môn để in!', 'warning');
                    return;
                }

                if (d) {
                    renderPrint(d, rows, $('#ui-mau-xn').val(), $('#ui-chat-luong').val());
                }
                window.print();
            });

            $('#btn-ket-noi-lis').on('click', function () {
                var currentCase = $('#detail-card').data('caseData') || $('#btn-in-phieu').data('pdata') || {};
                var profile = $(this).data('profile') || getServiceProfile(currentCase.TenDV || currentCase.TenDichVu || $('#ui-ten-xn').text());
                var button = $(this);

                button.prop('disabled', true);
                $.post('@Url.Action("NhanKetQuaTuMay", "MockLIS", new { area = "" })', { maKetQua: String($('#hdnMaKetQua').val()) }, function (res) {
                    if (!res.success) {
                        button.prop('disabled', false);
                        Swal.fire('Lỗi', res.message || 'Không thể lấy kết quả từ máy CLS.', 'error');
                        return;
                    }

                    var resultPayload = {
                        data: res.data || [],
                        images: res.images || [],
                        ketluan: res.ketluan || '',
                        resultType: res.resultType || ((res.images || []).length ? 'image' : 'lab')
                    };

                    applyServiceProfile({
                        sampleOptions: res.sampleOptions || profile.sampleOptions,
                        sampleDefault: res.sampleDefault || profile.sampleDefault,
                        qualityDefault: res.chatLuong || profile.qualityDefault,
                        actionLabel: res.actionLabel || profile.actionLabel
                    }, res.sampleDefault || $('#ui-mau-xn').val(), res.chatLuong || $('#ui-chat-luong').val());

                    $('#ui-ket-luan').val(resultPayload.ketluan || '');
                    updateResultUi(resultPayload);
                    renderPrint(currentCase, resultPayload.data, $('#ui-mau-xn').val(), $('#ui-chat-luong').val());

                    Swal.fire({
                        icon: 'success',
                        title: 'Đã nhận kết quả CLS',
                        text: res.message || 'Máy CLS đã trả kết quả mô phỏng.',
                        timer: 1400,
                        showConfirmButton: false
                    });
                });
            });

            $('#btn-xac-nhan').on('click', function () {
                var maKetQua = String($('#hdnMaKetQua').val());
                var maPhieu = String($('#hdnMaPhieuKham').val());
                var mauXN = $('#ui-mau-xn').val();
                var chatLuong = $('#ui-chat-luong').val();
                var resultPayload = $('#btn-ket-noi-lis').data('demoResult') || { data: [], images: [] };
                var lisData = resultPayload.data || [];
                var images = resultPayload.images || [];
                var ketLuan = ($('#ui-ket-luan').val() || '').trim();

                if (!lisData.length && !images.length && !ketLuan) {
                    Swal.fire('Thiếu kết quả', 'Vui lòng nhận kết quả CLS trước khi gửi cho bác sĩ.', 'warning');
                    return;
                }

                var noiDung = JSON.stringify({
                    data: lisData,
                    ketluan: ketLuan,
                    images: images,
                    resultType: resultPayload.resultType || (images.length ? 'image' : 'lab')
                });

                Swal.fire({
                    title: 'Gửi kết quả về bác sĩ?',
                    html: '<div class="form-check text-start mt-2"><input class="form-check-input" type="checkbox" id="chkPrintAfterSend" checked><label class="form-check-label" for="chkPrintAfterSend">In kết quả ngay sau khi gửi</label></div>',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Gửi kết quả',
                    cancelButtonText: 'Hủy'
                }).then(function (result) {
                    if (!result.isConfirmed) return;

                    $.post('@Url.Action("XacNhanKetQua", "CLS")', {
                        maKetQua: maKetQua,
                        noiDung: noiDung,
                        maPhieuKhamBenh: maPhieu,
                        mauXN: mauXN,
                        chatLuong: chatLuong
                    }, function (res) {
                        if (!res.success) {
                            Swal.fire('Lỗi', res.message || 'Không thể lưu kết quả.', 'error');
                            return;
                        }

                        $('#lblBS').text(res.maBacSi || '');
                        var d = $('#btn-in-phieu').data('pdata');
                        if (d) {
                            d.TenBacSiThucHien = res.maBacSi;
                            renderPrint(d, lisData, mauXN, chatLuong);
                        }

                        Swal.fire({
                            icon: 'success',
                            title: 'Đã gửi kết quả',
                            timer: 1200,
                            showConfirmButton: false
                        }).then(function () {
                            if ($('#chkPrintAfterSend').is(':checked')) {
                                window.print();
                            }
                            location.reload();
                        });
                    });
                });
            });
        });
    </script>
}
