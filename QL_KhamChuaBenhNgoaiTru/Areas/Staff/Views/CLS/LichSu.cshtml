@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.KetQuaCLS>
@{
    ViewBag.Title = "Lịch Sử Xét Nghiệm";
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";
}

<style>
    .history-page .card { border: 0; border-radius: 16px; box-shadow: 0 8px 24px rgba(20, 40, 80, 0.08); }
    .history-page .card-header { border-radius: 16px 16px 0 0 !important; }

    @@media screen { #print-section { display: none; } }
</style>

@Html.Partial("~/Views/Shared/_PrintDocumentStyles.cshtml")

<div class="history-page d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1 fw-bold text-dark">Lịch Sử Xét Nghiệm</h4>
            <p class="text-muted mb-0">Tra cứu, xem nhanh và in lại các kết quả CLS đã hoàn tất.</p>
        </div>
        <div class="text-end">
            <div class="small text-muted">Tổng kết quả</div>
            <div class="fs-4 fw-bold text-primary">@(Model?.Count() ?? 0)</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-dark text-white fw-semibold">Danh sách kết quả xét nghiệm</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" id="tbl-history">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;" class="text-center">#</th>
                            <th>Bệnh nhân</th>
                            <th>Dịch vụ</th>
                            <th>Thời gian</th>
                            <th>Bác sĩ thực hiện</th>
                            <th>File kết quả</th>
                            <th class="text-center" style="width: 180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var stt = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold">@(stt++)</td>
                                    <td class="fw-semibold text-primary">@item.TenBenhNhan</td>
                                    <td>@item.TenDichVu</td>
                                    <td>@(item.NgayThucHien.HasValue ? item.NgayThucHien.Value.ToString("dd/MM/yyyy HH:mm") : "")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.MaBacSiThucHien) ? "-" : item.MaBacSiThucHien)</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.FileKetQua) ? "-" : item.FileKetQua)</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-primary me-1 btn-view" data-id="@item.MaKetQua">Xem</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary btn-print" data-id="@item.MaKetQua">In lại</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">Chưa có kết quả xét nghiệm.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="print-section" class="app-print-sheet">
    @{
        Html.RenderPartial(
            "~/Views/Shared/_PrintDocumentHeader.cshtml",
            new ViewDataDictionary(ViewData)
            {
                { "PrintDocumentTitle", "PHI&#7870;U K&#7870;T QU&#7842; XÉT NGHIỆM" },
                { "PrintDocumentMaBNElementId", "prt-mabn" },
                { "PrintDocumentCodeLabel", "Mã phiếu:" },
                { "PrintDocumentCodeElementId", "prt-maphieu" }
            });
    }

    <div class="app-print-section" style="line-height:1.6;">
        <div style="display:flex;">
            <div style="flex:2;">Họ và tên: <b id="prt-ten" style="text-transform:uppercase;"></b></div>
            <div style="flex:1;">Tuổi: <span id="prt-tuoi"></span></div>
            <div style="flex:1;">Giới tính: <span id="prt-gt"></span></div>
        </div>
        <div style="display:flex;">
            <div style="flex:2;">Địa chỉ: <span id="prt-diachi"></span></div>
            <div style="flex:1;">Số BHYT: <b id="prt-bhyt"></b></div>
        </div>
        <div style="display:flex;">
            <div style="flex:2;">Chẩn đoán: <span id="prt-chandoan"></span></div>
            <div style="flex:1;">Bác sĩ chỉ định: <b id="prt-bschidinh"></b></div>
        </div>
    </div>

    <div class="app-print-section" style="line-height:1.6;margin-top:12px;margin-bottom:12px;">
        <div style="display:flex;">
            <div style="flex:2;">Mẫu xét nghiệm: <b id="prt-mauxn"></b></div>
            <div style="flex:1;">Chất lượng mẫu: <span id="prt-chatluong"></span></div>
        </div>
        <div style="display:flex; margin-top:4px;">
            <div style="flex:1;">Kết luận: <b id="prt-ketluan" style="color:red;"></b></div>
        </div>
    </div>

    <table class="print-table app-print-table">
        <thead>
            <tr>
                <th style="width:35%;">Tên chỉ số</th>
                <th style="width:25%;">Kết quả</th>
                <th style="width:20%;">Đơn vị</th>
                <th style="width:20%;">Trị số bình thường</th>
            </tr>
        </thead>
        <tbody id="prt-lis-tbody">
            <!-- Render động -->
        </tbody>
    </table>

    <div class="app-print-signature" style="display:flex; justify-content:space-between; text-align:center; margin-top:24px;">
        <div style="width:40%;">
            <div style="font-weight:700;">BÁC SĨ CHỈ ĐỊNH</div>
            <div style="margin-top:70px; font-weight:bold;" id="prt-sign-bschidinh"></div>
        </div>
        <div style="width:40%;">
            <div id="prt-date-footer" style="font-style:italic; margin-bottom:5px;"></div>
            <div style="font-weight:700;">NGƯỜI THỰC HIỆN</div>
            <div style="margin-top:70px; font-weight:bold;" id="prt-sign-thuchien"></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function buildLisArray(noiDung) {
        if (!noiDung) return [];
        if (noiDung.startsWith('[')) {
            try { return JSON.parse(noiDung); } catch(e) {}
        }
        return [];
    }

    function fillPrint(data) {
        var lisData = buildLisArray(data.NoiDungKetQua);
        var now = new Date();
        $('#prt-mabn').text(data.MaBenhNhan || data.MaBN || '');
        $('#prt-maphieu').text(data.MaKetQua || '');
        $('#prt-ten').text(data.TenBenhNhan || '');
        $('#prt-tuoi').text(data.Tuoi || '');
        $('#prt-gt').text(data.GioiTinh || '');
        $('#prt-chandoan').text(data.LyDoDenKham || '');
        $('#prt-tenxn').text(data.TenDV || '');
        $('#prt-mauxn').text(data.MauXetNghiem || 'Huyết thanh');
        $('#prt-chatluong').text(data.ChatLuongMau || 'Đạt');
        
        var tbody = '';
        if (lisData && lisData.length > 0) {
            lisData.forEach(function(item) {
                var isWarning = item.Warning ? 'color: red; font-weight: bold;' : 'font-weight: bold;';
                tbody += '<tr>' +
                    '<td>' + item.Ten + '</td>' +
                    '<td style="text-align:center;"><div style="' + isWarning + '">' + item.GiaTri + '</div></td>' +
                    '<td style="text-align:center;">' + item.DonVi + '</td>' +
                    '<td style="text-align:center;">' + item.ThamChieu + '</td>' +
                    '</tr>';
            });
        }
        $('#prt-lis-tbody').html(tbody);
        
        $('#prt-date-footer').text('TP.HCM, ngày ' + now.getDate() + ' tháng ' + (now.getMonth() + 1) + ' năm ' + now.getFullYear());
    }

    function loadDetail(maKetQua, callback) {
        $.post('/Staff/CLS/GetChiTiet', { maKetQua: maKetQua }, function (res) {
            if (!res.success) {
                Swal.fire('Lỗi', res.message || 'Không tải được chi tiết.', 'error');
                return;
            }

            fillPrint(res.Data);
            if (typeof callback === 'function') callback(res.Data);
        });
    }

    $(document).on('click', '.btn-view', function () {
        var id = $(this).data('id');
        loadDetail(id, function (d) {
            var lisData = buildLisArray(d.NoiDungKetQua);
            var resultHtml = '';
            if (lisData.length > 0) {
                resultHtml = '<table class="table table-sm table-bordered mt-2"><thead><tr class="table-light"><th>Chỉ số</th><th>Kết quả</th><th>Đơn vị</th><th>Chỉ số bình thường</th></tr></thead><tbody>';
                lisData.forEach(function(item) {
                    var isWarn = item.Warning ? 'text-danger fw-bold' : 'fw-bold';
                    resultHtml += '<tr><td>' + item.Ten + '</td><td class="' + isWarn + '">' + item.GiaTri + '</td><td>' + item.DonVi + '</td><td>' + item.ThamChieu + '</td></tr>';
                });
                resultHtml += '</tbody></table>';
            } else {
                resultHtml = '<div>' + (d.NoiDungKetQua || '').replace(/\n/g, '<br>') + '</div>';
            }

            Swal.fire({
                title: 'Chi tiết kết quả xét nghiệm',
                html: '<div class="text-start">'
                    + '<div><b>Bệnh nhân:</b> ' + (d.TenBenhNhan || '') + '</div>'
                    + '<div><b>Dịch vụ:</b> ' + (d.TenDV || '') + '</div>'
                    + '<div><b>Mẫu xét nghiệm:</b> ' + (d.MauXetNghiem || '') + '</div>'
                    + '<div><b>Chất lượng mẫu:</b> ' + (d.ChatLuongMau || '') + '</div>'
                    + '<div class="mt-2"><b>Nội dung chỉ số:</b><br>' + resultHtml + '</div>'
                    + '</div>',
                width: 700,
                confirmButtonText: 'Đóng'
            });
        });
    });

    $(document).on('click', '.btn-print', function () {
        var id = $(this).data('id');
        loadDetail(id, function () {
            window.print();
        });
    });
</script>
<script>
    $(function () {
        function parseStoredResult(noiDung) {
            var parsed = { data: [], ketluan: '', images: [] };
            if (!noiDung) return parsed;

            if (noiDung.startsWith('[')) {
                try { parsed.data = JSON.parse(noiDung) || []; } catch (e) { }
                return parsed;
            }

            if (noiDung.startsWith('{')) {
                try {
                    var payload = JSON.parse(noiDung) || {};
                    parsed.data = Array.isArray(payload.data) ? payload.data : [];
                    parsed.ketluan = payload.ketluan || '';
                    parsed.images = Array.isArray(payload.images) ? payload.images : [];
                    return parsed;
                } catch (e) { }
            }

            parsed.ketluan = noiDung;
            return parsed;
        }

        function buildLisTable(lisData) {
            if (!lisData || !lisData.length) return '';

            var hasMetaColumns = lisData.some(function (item) {
                var donVi = (item.DonVi || '').toString().trim();
                var thamChieu = (item.ThamChieu || '').toString().trim();
                return (donVi && donVi !== '-') || (thamChieu && thamChieu !== '-');
            });

            var html = hasMetaColumns
                ? '<table class="table table-sm table-bordered mt-2"><thead><tr class="table-light"><th>Chỉ số</th><th>Kết quả</th><th>Đơn vị</th><th>Chỉ số bình thường</th></tr></thead><tbody>'
                : '<table class="table table-sm table-bordered mt-2"><thead><tr class="table-light"><th>Tên chỉ số</th><th>Kết quả</th></tr></thead><tbody>';

            lisData.forEach(function (item) {
                var rowClass = item.Warning ? 'text-danger fw-bold' : 'fw-bold';
                if (hasMetaColumns) {
                    html += '<tr><td>' + item.Ten + '</td><td class="' + rowClass + '">' + item.GiaTri + '</td><td>' + (item.DonVi || '-') + '</td><td>' + (item.ThamChieu || '-') + '</td></tr>';
                } else {
                    html += '<tr><td>' + item.Ten + '</td><td class="' + rowClass + '">' + item.GiaTri + '</td></tr>';
                }
            });
            html += '</tbody></table>';
            return html;
        }

        function buildImageHtml(images) {
            if (!images || !images.length) return '';

            return '<div class="row g-2 mt-2">' + images.map(function (image) {
                return '' +
                    '<div class="col-md-6">' +
                        '<div class="border rounded p-2 h-100 bg-light">' +
                            '<img src="' + image.url + '" alt="' + (image.title || 'Hình ảnh CLS') + '" class="img-fluid rounded" />' +
                            '<div class="small fw-bold mt-2 text-primary">' + (image.title || 'Hình ảnh CLS') + '</div>' +
                            '<div class="small text-muted">' + (image.caption || '') + '</div>' +
                        '</div>' +
                    '</div>';
            }).join('') + '</div>';
        }

        buildLisArray = function (noiDung) {
            return parseStoredResult(noiDung).data;
        };

        fillPrint = function (data) {
            var parsed = parseStoredResult(data.NoiDungKetQua);
            var lisData = parsed.data;
            var now = new Date();
            var hasMetaColumns = (lisData || []).some(function (item) {
                var donVi = (item.DonVi || '').toString().trim();
                var thamChieu = (item.ThamChieu || '').toString().trim();
                return (donVi && donVi !== '-') || (thamChieu && thamChieu !== '-');
            });

            $('#prt-mabn').text(data.MaBenhNhan || data.MaBN || '');
            $('#prt-maphieu').text(data.MaKetQua || '');
            $('#prt-ten').text(data.TenBenhNhan || '');
            $('#prt-tuoi').text(data.Tuoi || '');
            $('#prt-gt').text(data.GioiTinh || '');
            $('#prt-chandoan').text(data.LyDoDenKham || data.ChanDoan || '');
            $('#prt-tenxn').text(data.TenDV || '');
            $('#prt-mauxn').text(data.MauXetNghiem || 'Huyết thanh');
            $('#prt-chatluong').text(data.ChatLuongMau || 'Đạt');

            $('#print-section .print-table thead').html(
                hasMetaColumns
                    ? '<tr><th style="width:35%;">Tên chỉ số</th><th style="width:25%;">Kết quả</th><th style="width:20%;">Đơn vị</th><th style="width:20%;">Trị số bình thường</th></tr>'
                    : '<tr><th style="width:35%;">Tên chỉ số</th><th style="width:65%;">Kết quả</th></tr>'
            );

            var tbody = '';
            if (lisData && lisData.length > 0) {
                lisData.forEach(function (item) {
                    var isWarning = item.Warning ? 'color: red; font-weight: bold;' : 'font-weight: bold;';
                    if (hasMetaColumns) {
                        tbody += '<tr>' +
                            '<td>' + item.Ten + '</td>' +
                            '<td style="text-align:center;"><div style="' + isWarning + '">' + item.GiaTri + '</div></td>' +
                            '<td style="text-align:center;">' + (item.DonVi || '-') + '</td>' +
                            '<td style="text-align:center;">' + (item.ThamChieu || '-') + '</td>' +
                            '</tr>';
                    } else {
                        tbody += '<tr>' +
                            '<td>' + item.Ten + '</td>' +
                            '<td><div style="' + isWarning + '">' + item.GiaTri + '</div></td>' +
                            '</tr>';
                    }
                });
            }
            $('#prt-lis-tbody').html(tbody);
            $('#prt-date-footer').text('TP.HCM, ngày ' + now.getDate() + ' tháng ' + (now.getMonth() + 1) + ' năm ' + now.getFullYear());
        };

        loadDetail = function (maKetQua, callback) {
            $.post('/Staff/CLS/GetChiTiet', { maKetQua: maKetQua }, function (res) {
                if (!res.success) {
                    Swal.fire('Lỗi', res.message || 'Không tải được chi tiết.', 'error');
                    return;
                }

                fillPrint(res.Data);
                if (typeof callback === 'function') callback(res.Data);
            });
        };

        $(document).off('click', '.btn-view');
        $(document).on('click', '.btn-view', function () {
            var id = $(this).data('id');
            loadDetail(id, function (d) {
                var parsed = parseStoredResult(d.NoiDungKetQua);
                var tableHtml = buildLisTable(parsed.data);
                var imageHtml = buildImageHtml(parsed.images);
                var resultHtml = tableHtml || '<div>' + (parsed.ketluan || d.NoiDungKetQua || '').replace(/\n/g, '<br>') + '</div>';

                Swal.fire({
                    title: 'Chi tiết kết quả CLS',
                    html: '<div class="text-start">'
                        + '<div><b>Bệnh nhân:</b> ' + (d.TenBenhNhan || '') + '</div>'
                        + '<div><b>Dịch vụ:</b> ' + (d.TenDV || '') + '</div>'
                        + '<div><b>Mẫu xét nghiệm:</b> ' + (d.MauXetNghiem || '') + '</div>'
                        + '<div><b>Chất lượng mẫu:</b> ' + (d.ChatLuongMau || '') + '</div>'
                        + '<div class="mt-2"><b>Nội dung chỉ số:</b><br>' + resultHtml + '</div>'
                        + (parsed.ketluan ? '<div class="mt-2"><b>Kết luận:</b> ' + parsed.ketluan + '</div>' : '')
                        + imageHtml
                        + '</div>',
                    width: 900,
                    confirmButtonText: 'Đóng'
                });
            });
        });

        $(document).off('click', '.btn-print');
        $(document).on('click', '.btn-print', function () {
            var id = $(this).data('id');
            loadDetail(id, function () {
                window.print();
            });
        });
    });
</script>
}

