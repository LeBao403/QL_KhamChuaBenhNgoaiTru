            });

            function buildFallbackDrugSuggestions(trieuChung, ketLuan) {
                var text = (trieuChung + ' ' + ketLuan).toLowerCase();
                var fallback = [];
                function pick(code, name, score) {
                    if (fallback.some(function (x) { return x.code === code; })) return;
                    fallback.push({ code: code, name: name, score: score });
                }

                if (text.indexOf('sốt') >= 0 || text.indexOf('ho') >= 0 || text.indexOf('mũi') >= 0 || text.indexOf('nhức đầu') >= 0 || text.indexOf('đau đầu') >= 0 || text.indexOf('cảm') >= 0) {
                    pick('T001', 'Paracetamol 500mg', 0.96);
                    pick('T005', 'Cetirizine 10mg', 0.84);
                    pick('T006', 'Loratadine 10mg', 0.82);
                    pick('T004', 'Azithromycin 500mg', 0.68);
                    pick('T002', 'Amoxicillin 500mg', 0.66);
                }

                if (!fallback.length) {
                    pick('T001', 'Paracetamol 500mg', 0.80);
                    pick('T005', 'Cetirizine 10mg', 0.72);
                    pick('T007', 'Omeprazole 20mg', 0.60);
                }
                return fallback;
            }

            function refreshThuocDropdownSuggestions(items) {
                items = Array.isArray(items) ? items : [];

                var normalizeCode = function (value) {
                    return (value == null ? '' : String(value)).trim();
                };

                var normalized = items.map(function (x) {
                    var code = normalizeCode(x.drug_code || x.drugCode || x.MaThuoc || '');
                    var name = x.drug_name || x.drugName || x.TenThuoc || 'Thuốc gợi ý';
                    var score = typeof x.score === 'number' ? x.score : parseFloat(x.Score || x.score || 0);
                    if (isNaN(score)) score = 0;
                    return { code: code, name: name, score: score };
                }).filter(function (x) { return x.code; }).sort(function (a, b) { return b.score - a.score; });

                suggestedDrugCodes = normalized.map(function (x) { return x.code; });
                var suggestedMap = {};
                normalized.forEach(function (x) { suggestedMap[x.code] = x.score; });

                var $select = $('#cboThuoc');
                
                $('#drugSuggestionBox').addClass('d-none').empty();
                $('#drugSuggestionList').addClass('d-none').empty();

                var allOptions = $select.find('option').toArray();
                var firstOption = allOptions.filter(function (o) { return $(o).val() === ''; });
                var suggestedOptions = allOptions.filter(function (o) {
                    return normalizeCode($(o).val()) && suggestedDrugCodes.indexOf(normalizeCode($(o).val())) >= 0;
                }).map(function (o) {
                    var $o = $(o);
                    var code = normalizeCode($o.val());
                    var score = suggestedMap[code] || 0;
                    var pct = (score * 100).toFixed(1) + '%';
                    var donvi = $o.attr('data-donvi') || 'Viên';
                    var cleanName = ($o.attr('data-tenthuoc') || $o.text()).replace(/^★[\s\[BHYT\]]*/, '').split('- Điểm:')[0].replace(/\(.*?\)$/, '').trim();
                    $o.text('★ ' + cleanName + ' (' + donvi + ') - Điểm: ' + pct).attr('data-suggested', '1').attr('data-score', score);
                    return o;
                }).sort(function (a, b) {
                    return parseFloat($(b).attr('data-score') || '0') - parseFloat($(a).attr('data-score') || '0');
                });

                var otherOptions = allOptions.filter(function (o) {
                    return normalizeCode($(o).val()) && suggestedDrugCodes.indexOf(normalizeCode($(o).val())) < 0;
                }).map(function (o) {
                    var $o = $(o);
                    var donvi = $o.attr('data-donvi') || 'Viên';
                    var cleanName = ($o.attr('data-tenthuoc') || $o.text()).replace(/^★\s*/, '').split('- Điểm:')[0].replace(/\(.*?\)$/, '').trim();
                    $o.text(cleanName + ' (' + donvi + ')').attr('data-suggested', '0').removeAttr('data-score');
                    return o;
                });

                $select.empty();
                firstOption.forEach(function (o) { $select.append(o); });
                suggestedOptions.forEach(function (o) { $select.append(o); });
                otherOptions.forEach(function (o) { $select.append(o); });

                if ($select.data('select2')) {
                    $select.select2('destroy');
                }
                $select.select2({
                    width: '100%',
                    theme: 'classic',
                    allowClear: true,
                    dropdownCssClass: 'thuoc-dropdown-below',
                    escapeMarkup: function (markup) { return markup; },
                    templateResult: function (data) {
                        if (!data.id) return data.text;
                        var $el = data.element ? $(data.element) : null;
                        var isSug = $el && $el.attr('data-suggested') === '1';
                        var bhytStatus = $el && $el.attr('data-bhyt') === '1' ? '<span class="badge bg-success" style="font-size: 0.75rem;">BHYT</span>' : '<span class="badge bg-secondary" style="font-size: 0.75rem;">Không BHYT</span>';
                        var text = ($el && $el.text()) || data.text;
                        if (isSug) {
                            return $('<div style="background-color: #fffae6; border-left: 3px solid #ffc107; padding: 4px 8px; border-radius: 4px;"><i class="fas fa-star text-warning me-1"></i> ' + bhytStatus + ' <strong class="text-danger ms-1">' + text.replace(/^★\s*/, '') + '</strong></div>');
                        }
                        return $('<div style="padding: 4px 8px;">' + bhytStatus + ' <span class="ms-1 fw-bold text-dark">' + text + '</span></div>');
                    },
                    templateSelection: function (data) {
                        if (!data.id) return data.text;
                        return data.text || '';
                    }
                });
                $select.trigger('change.select2');
            }

            $('#btnGoiYThuoc').on('click', function () {
                var maPhieu = $('#MaPhieuKhamBenh').val();
                var trieuChung = $('#TrieuChung').val() || $('#txtTrieuChung').val() || '';
                var ketLuan = $('#KetLuan').val() || $('#txtKetLuan').val() || '';
                var tuoiText = $('#lblTuoi').text() || '';
                var tuoi = parseInt((tuoiText.match(/(\d+)/) || ['30'])[0], 10) || 30;
                var gioiTinh = $('#lblGioiTinh').text() || 'Nam';

                if (!maPhieu) {
                    var msgNoPhieu = 'Chưa có mã phiếu khám, không thể gợi ý thuốc.';
                    if (window.Swal && Swal.fire) Swal.fire('Thông báo', msgNoPhieu, 'info'); else alert(msgNoPhieu);
                    return;
                }

                var payload = {
                    trieuChung: trieuChung,
                    ketLuan: ketLuan,
                    tuoi: tuoi,
                    gioiTinh: gioiTinh,
                    maPhieu: maPhieu,
                    age: tuoi,
                    sex: gioiTinh,
                    age_group: (tuoi < 13 ? 'TreEm' : (tuoi < 18 ? 'ThieuNien' : (tuoi < 40 ? 'NguoiLonTre' : (tuoi < 60 ? 'TrungNien' : 'NguoiCaoTuoi')))),
                    disease: ketLuan,
                    symptoms: trieuChung,
                    comorbidity: 'None',
                    allergy: 'None'
                };
                console.log('GoiYThuoc payload', payload);

                $.ajax({
                    url: '@Url.Action("GoiYThuoc", "BacSi", new { area = "Staff" })',
                    method: 'POST',
                    data: payload,
                    dataType: 'json'
                }).done(function (res) {
                    console.log('GoiYThuoc response', res);
                    if (!res || !res.success) {
                        var msg = (res && res.message) ? res.message : 'Không lấy được gợi ý thuốc';
                        if (window.Swal && Swal.fire) Swal.fire('Lỗi', msg, 'error'); else alert(msg);
                        return;
                    }

                    var items = [];
                    if (res.data && Array.isArray(res.data.items)) items = res.data.items;
                    else if (Array.isArray(res.items)) items = res.items;
                    else if (Array.isArray(res.data)) items = res.data;

                    if (!items.length) {
                        var msgEmpty = 'Không có thuốc gợi ý phù hợp từ AI. Đang hiển thị danh sách tham khảo.';
                        if (window.Swal && Swal.fire) Swal.fire('Thông báo', msgEmpty, 'info'); else alert(msgEmpty);
                        var fallbackItems = buildFallbackDrugSuggestions(trieuChung, ketLuan);
                        refreshThuocDropdownSuggestions(fallbackItems);
                        return;
                    }

                    refreshThuocDropdownSuggestions(items);
                    if (res.meta && res.meta.disease_category) {
                        $('#drugSuggestionBox').removeClass('d-none').html('<div class="small fw-bold text-primary"><i class="fas fa-robot me-1"></i> AI gợi ý nhóm bệnh: <span class="text-danger">' + res.meta.disease_category + '</span></div>');
                    }
                    if (window.Swal && Swal.fire) {
                        Swal.fire('Đã gợi ý thuốc', 'Các thuốc gợi ý đã được đánh dấu ★ trong danh sách.', 'success');
                    }
                }).fail(function (xhr, status, err) {
                    console.error('GoiYThuoc ajax fail', status, err, xhr && xhr.responseText);
                    var msgFail = 'Không gọi được API gợi ý thuốc.';
                    if (window.Swal && Swal.fire) Swal.fire('Lỗi', msgFail, 'error'); else alert(msgFail);
                });
            });

            $('#cboTimBenhNhan').select2();
            $('#cboLichSuKham').select2();

            // 1. Load danh sách bệnh nhân
            $.get('@Url.Action("LayDanhSachBenhNhan", "BacSi", new { area = "Staff" })', function(res) {
                $('#cboTimBenhNhan').select2({
                    data: res,
                    placeholder: "-- Chọn hoặc nhập tên/SĐT/CCCD bệnh nhân --",
                    allowClear: true
                });
            });

            // 2. Khi chọn Bệnh nhân -> Lấy Lịch sử
            $('#cboTimBenhNhan').on('select2:select', function (e) {
                var maBN = e.params.data.id;
                $.get('@Url.Action("LayLichSuKham", "BacSi", new { area = "Staff" })', { maBN: maBN }, function(res) {
                    $('#cboLichSuKham').empty();
                    if(res && res.length > 0) {
                        $('#cboLichSuKham').select2({ data: res });
                        $('#boxChonLichSu').fadeIn();
                        // Tự động chọn lần khám gần nhất và kích hoạt sự kiện tải chi tiết
                        $('#cboLichSuKham').val(res[0].id).trigger('change');
                    } else {
                        $('#boxChonLichSu').hide();
                        $('#panelChiTietLichSu').slideUp();
                        Swal.fire('Thông báo', 'Bệnh nhân này chưa có lịch sử khám nào trong hệ thống!', 'info');
                    }
                });
            });

            // Xóa Bệnh nhân -> Đóng bảng lịch sử
            $('#cboTimBenhNhan').on('select2:unselect', function (e) {
                 $('#boxChonLichSu').hide();
                 $('#panelChiTietLichSu').slideUp();
            });

            // 3. Khi chọn 1 Phiếu khám cũ -> Load chi tiết
            $('#cboLichSuKham').on('change', function() {
                var maPhieu = $(this).val();
                if(!maPhieu) return;

                // Tái sử dụng lại API lấy chi tiết phiếu đang khám
                $.post('@Url.Action("ChiTietDangKham", "BacSi", new { area = "Staff" })', { maPhieu: maPhieu }, function(res) {
                    if(res.success) {
                        RenderHistoryPanel(res.Data);
                    }
                });
            });

            // SỰ KIỆN TÍNH TOÁN SỐ LƯỢNG THUỐC TỰ ĐỘNG
            $(document).on('input change', '.input-calc', function (e) {
                var row = $(this).closest('tr');
                var sangElem = row.find('input[name*=".Sang"]');
                var truaElem = row.find('input[name*=".Trua"]');
                var chieuElem = row.find('input[name*=".Chieu"]');
                var toiElem = row.find('input[name*=".Toi"]');
                var songayElem = row.find('input[name*=".SoNgay"]');

                var sang = parseFloat(sangElem.val()) || 0;
                var trua = parseFloat(truaElem.val()) || 0;
                var chieu = parseFloat(chieuElem.val()) || 0;
                var toi = parseFloat(toiElem.val()) || 0;
                var songay = parseInt(songayElem.val()) || 1;

                if (e.type === 'change') {
                    // Ép làm tròn 0.5
                    sang = Math.round(sang * 2) / 2; sangElem.val(sang);
                    trua = Math.round(trua * 2) / 2; truaElem.val(trua);
                    chieu = Math.round(chieu * 2) / 2; chieuElem.val(chieu);
                    toi = Math.round(toi * 2) / 2; toiElem.val(toi);

                    var tong1Ngay = sang + trua + chieu + toi;
                    if (tong1Ngay > 0 && tong1Ngay % 1 !== 0) {
                        if (songay % 2 !== 0) { songay += 1; songayElem.val(songay); }
                    }
                }

                var tong1NgayCalc = sang + trua + chieu + toi;
                row.find('.tong-sl').val(tong1NgayCalc * songay);
            });

            // SỰ KIỆN CHỌN DỊCH VỤ CẬN LÂM SÀNG
            $('#cboDichVu').on('select2:select', function (e) {
                var data = e.params.data;
                var maDV = data.id; var tenDV = data.text;
                if (!maDV) return;

                // --- SỬA Ở ĐÂY: Lấy giá ngay lập tức từ option vừa click, xóa sạch dấu phẩy ---
                var optionElement = $(data.element);
                var rawGia = optionElement.attr('data-gia') || "0";
                // Chuyển "120,000.00" thành "120000.00" để hàm parseFloat hiểu được chính xác
                var giaDV = parseFloat(rawGia.replace(/,/g, ''));

                var exists = false;
                $('input[name$=".MaDV"]').each(function() { if($(this).val() == maDV) exists = true; });

                if(exists) {
                    alert('Dịch vụ này đã được chỉ định!');
                } else {
                    $.post('@Url.Action("GetPhongDichVu", "BacSi", new { area = "Staff" })', { maDV: maDV }, function(phongs) {
                        var options = '';
                        if (phongs && phongs.length > 0) {
                            phongs.forEach(function(p, i) {
                                var isSelected = (i === 0) ? 'selected' : '';
                                options += `<option value="${p.MaPhong}" ${isSelected}>${p.TenPhong} (Đang chờ: ${p.SoNguoiCho} người)</option>`;
                            });
                        } else {
                            options = '<option value="">-- Không có phòng phù hợp --</option>';
                        }

                        var tenHienThi = tenDV.split('] ')[1] || tenDV;
                        var rawGia = $('#cboDichVu option:selected').attr('data-gia') || "0";
                        var giaDV = parseFloat(rawGia.replace(',', '.')); // Thay dấu phẩy thành chấm đề phòng format C# tiếng Việt

                        var tr = `
                            <tr>
                                <td>
                                    <input type="hidden" name="ChiDinhs.Index" value="${dvIndex}" />
                                    <input type="hidden" name="ChiDinhs[${dvIndex}].MaDV" value="${maDV}" />
                                    <input type="hidden" class="dv-gia" value="${giaDV}" />

                                    <strong class="text-primary">${tenHienThi}</strong>
                                </td>
                                <td>
                                    <select name="ChiDinhs[${dvIndex}].MaPhong" class="form-select form-select-sm border-danger text-danger fw-bold bg-light">
                                        ${options}
                                    </select>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="$(this).closest('tr').remove()"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        `;
                        $('#tbDichVu tbody').append(tr);
                        dvIndex++;
                    });
                }
                $(this).val(null).trigger('change');
            });

            // SỰ KIỆN NÚT HOÀN THÀNH - IN & LƯU
            // SỰ KIỆN NÚT HOÀN THÀNH - IN & LƯU
            $('#btnHoanThanh').on('click', function (e) {
                // KIỂM TRA SỐ LƯỢNG THUỐC
                if (!$('#chkCLS').is(':checked')) {
                    var soLoaiThuoc = $('#tbDonThuoc tbody tr').length;
                    if (soLoaiThuoc > 0) {
                        var isInvalid = false;
                        $('#tbDonThuoc tbody tr').each(function () {
                            var sl = parseFloat($(this).find('.tong-sl').val()) || 0;
                            if (sl <= 0) { isInvalid = true; }
                        });

                        if (isInvalid) {
                            alert("Cảnh báo: Có thuốc trong đơn đang có số lượng bằng 0. Vui lòng kiểm tra lại đơn thuốc trước khi lưu!");
                            return false;
                        }
                    }
                }

                // CẬP NHẬT HEADER BẢNG IN (Phân chia 4 cột Sáng/Trưa/Chiều/Tối)
                if ($('#chkCLS').is(':checked')) {
                    $('#printTitle').text('PHIẾU CHỈ ĐỊNH CẬN LÂM SÀNG');
                    $('#printTableThead').html(`
                        <tr>
                            <th class="text-center" style="width: 50px;">STT</th>
                            <th>Nội dung Dịch vụ</th>
                            <th class="text-center" style="width: 80px;">S.Lượng</th>
                            <th>Phòng thực hiện</th>
                        </tr>
                    `);
                } else {
                    $('#printTitle').text('KẾT QUẢ KHÁM BỆNH & ĐƠN THUỐC');
                    $('#printTableThead').html(`
                        <tr>
                            <th class="text-center" style="width: 40px;">STT</th>
                            <th>Tên Thuốc</th>
                            <th class="text-center" style="width: 50px;">Sáng</th>
                            <th class="text-center" style="width: 50px;">Trưa</th>
                            <th class="text-center" style="width: 50px;">Chiều</th>
                            <th class="text-center" style="width: 50px;">Tối</th>
                            <th class="text-center" style="width: 70px;">Số ngày</th>
                            <th class="text-center" style="width: 70px;">S.Lượng</th>
                            <th style="width: 120px;">Cách dùng</th>
                        </tr>
                    `);
                }

                $('#printMaPK').text('#' + $('#MaPhieuKhamBenh').val());
                $('#printTenBN').text($('#lblTenBN').text());
                $('#printTuoi').text($('#lblTuoi').text());
                $('#printGioiTinh').text($('#lblGioiTinh').text());
                $('#printLyDo').text($('#lblLyDo').text());
                $('#printDiaChi').text($('#lblDiaChi').text());
                $('#printSDT').text($('#lblSDT').text());

                var chanDoan = $('#KetLuan').val();
                $('#tbBenhDaChon tbody tr').each(function () {
                    var tenB = $(this).find('td:eq(1)').text();
                    if (tenB) chanDoan += (chanDoan ? ", " : "") + tenB;
                });
                $('#printChanDoan').text(chanDoan || 'Theo dõi / Chưa kết luận');

                var tbodyHtml = ''; var stt = 1;
                if ($('#chkCLS').is(':checked')) {
                    $('#tbDichVu tbody tr').each(function () {
                        var tenDV = $(this).find('td:eq(0) strong').text();
                        var tenPhongFull = $(this).find('select[name*=".MaPhong"] option:selected').text();
                        var tenPhong = tenPhongFull.split(' (')[0] || tenPhongFull;

                        tbodyHtml += `<tr>
                            <td class="text-center">${stt++}</td>
                            <td><strong>${tenDV}</strong></td>
                            <td class="text-center">1</td>
                            <td class="text-primary fw-bold">${tenPhong}</td>
                        </tr>`;
                    });
                } else {
                    $('#tbDonThuoc tbody tr').each(function () {
                        var tenThuoc = $(this).find('td:eq(0) strong').text();
                        var sang = parseFloat($(this).find('input[name*=".Sang"]').val()) || 0;
                        var trua = parseFloat($(this).find('input[name*=".Trua"]').val()) || 0;
                        var chieu = parseFloat($(this).find('input[name*=".Chieu"]').val()) || 0;
                        var toi = parseFloat($(this).find('input[name*=".Toi"]').val()) || 0;
                        var soNgay = $(this).find('input[name*=".SoNgay"]').val() || 1;
                        var sl = $(this).find('.tong-sl').val() || 0;
                        var cachDung = $(this).find('select[name*=".GhiChu"]').val();

                        tbodyHtml += `<tr>
                            <td class="text-center">${stt++}</td>
                            <td><strong>${tenThuoc}</strong></td>
                            <td class="text-center fw-bold text-primary">${sang > 0 ? sang : ''}</td>
                            <td class="text-center fw-bold text-primary">${trua > 0 ? trua : ''}</td>
                            <td class="text-center fw-bold text-primary">${chieu > 0 ? chieu : ''}</td>
                            <td class="text-center fw-bold text-primary">${toi > 0 ? toi : ''}</td>
                            <td class="text-center">${soNgay}</td>
                            <td class="text-center fw-bold text-danger">${sl}</td>
                            <td>${cachDung}</td>
                        </tr>`;
                    });

                    // THÊM LỜI DẶN VÀ TÁI KHÁM VÀO ĐƠN THUỐC
                    var danDo = $('#DanDo').val();
                    var ngayHẹn = $('#NgayTaiKham').val();

                    if (danDo || ngayHẹn) {
                        tbodyHtml += `<tr><td colspan="9" class="text-start pb-3 pt-3">`;
                        if (danDo) tbodyHtml += `<div class="mb-1"><span class="fw-bold text-dark">Lời dặn của Bác sĩ:</span> ${danDo}</div>`;
                        if (ngayHẹn) {
                            var d = new Date(ngayHẹn);
                            tbodyHtml += `<div><span class="fw-bold text-danger">Ngày hẹn tái khám:</span> ${d.getDate().toString().padStart(2, '0')}/${(d.getMonth() + 1).toString().padStart(2, '0')}/${d.getFullYear()}</div>`;
                        }
                        tbodyHtml += `</td></tr>`;
                    }
                }

                if (tbodyHtml === '') {
                    var cols = $('#chkCLS').is(':checked') ? 4 : 9;
                    tbodyHtml = `<tr><td colspan="${cols}" class="text-center text-muted">Không có dịch vụ/thuốc nào được xuất.</td></tr>`;
                }

                $('#printTbBody').html(tbodyHtml);

                window.print();
                setTimeout(function () { $('#frmKhamBenh').submit(); }, 500);
            });
        });
    </script>
}