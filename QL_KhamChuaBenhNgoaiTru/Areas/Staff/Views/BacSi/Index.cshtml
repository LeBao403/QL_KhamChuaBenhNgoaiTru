                                <select id="cboThuoc" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn thuốc --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachThuoc != null)
                                    {
                                        foreach (var t in ViewBag.DanhSachThuoc)
                                        {
                                            int isBHYT = t.CoBHYT ? 1 : 0;
                                            <option value="@t.MaThuoc" data-gia="@t.GiaBan" data-bhyt="@isBHYT" data-donvi="@t.DonViCoBan" data-tenthuoc="@t.TenThuoc">@t.TenThuoc (@t.DonViCoBan)</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle text-center" id="tbDonThuoc">
                                    <thead class="table-success">
                                        <tr>
                                            <th class="text-start">Tên Thuốc</th>
                                            <th width="70px">Sáng</th>
                                            <th width="70px">Trưa</th>
                                            <th width="70px">Chiều</th>
                                            <th width="70px">Tối</th>
                                            <th width="80px">Số Ngày</th>
                                            <th width="80px">Số Lượng</th>
                                            <th width="180px">Cách dùng</th>
                                            <th width="50px">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <div class="row g-3 mt-3 mb-2 pt-3 border-top">
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Lời dặn dò của Bác sĩ:</label>
                                <textarea name="DanDo" id="DanDo" class="form-control" rows="2" placeholder="Ví dụ: Kiêng ăn đồ cay nóng, tập thể dục nhẹ nhàng..."></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Ngày hẹn tái khám:</label>
                                <input type="date" name="NgayTaiKham" id="NgayTaiKham" class="form-control" />
