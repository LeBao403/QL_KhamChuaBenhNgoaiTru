    </div>

    <div id="printPrescriptionArea" class="d-none">
        <div class="row align-items-center mb-4">
            <div class="col-7">
                <div class="d-flex align-items-center gap-3">
                    <i class="fas fa-hospital text-primary" style="font-size: 2.5rem;"></i>
                    <div>
                        <h2 class="mb-0 fw-bold" style="color: #1e293b; font-size: 1.8rem;">HIS CLINIC CENTER</h2>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">MST: 0312345678 - Hotline: 1900 8888</p>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">ĐC: Số 123 Nguyễn Văn Cừ, Quận 5, TP.HCM</p>
                    </div>
                </div>
            </div>
            <div class="col-5 text-end">
                <h3 style="font-weight: 800; color: #3b82f6; font-size: 1.4rem; text-transform:uppercase;" id="printTitle">PHIẾU KHÁM BỆNH</h3>
                <p class="mb-0 fw-bold text-dark fs-5">Mã PK: <span class="text-danger" id="printMaPK"></span></p>
            </div>
