@model QL_KhamChuaBenhNgoaiTru.Models.KhamBenhViewModel
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";
    ViewBag.Title = "Phòng Khám Bác Sĩ";
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    :root {
        --primary-blue: #0d6efd;
        --dark-blue: #0a58ca;
        --soft-bg: #f8f9fa;
    }

    body {
        background-color: #f4f7f6;
    }

    .page-header-card {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--dark-blue) 100%);
        border: none;
        border-radius: 15px;
        margin-bottom: 1.5rem;
    }

    .queue-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.07);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

        .queue-card .card-header {
            padding: .85rem 1.25rem;
            font-weight: 700;
            font-size: .85rem;
            letter-spacing: .3px;
            text-transform: uppercase;
        }

    .queue-table thead th {
        background-color: var(--soft-bg);
        color: #495057;
        font-weight: 700;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #e9ecef;
        padding: .9rem 1rem;
    }

    .queue-table tbody tr {
        border-bottom: 1px solid #f0f0f0;
        transition: background .15s;
    }

        .queue-table tbody tr:hover {
            background: #f0f7ff;
        }

        .queue-table tbody tr.table-active {
            background: #dbeafe;
        }

    .exam-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.09);
        overflow: hidden;
    }

        .exam-card .card-header {
            background: linear-gradient(90deg, #0d6efd 0%, #6ea8fe 100%);
            color: #fff;
            padding: 1rem 1.5rem;
            font-weight: 700;
            font-size: 1rem;
        }

    .patient-info-bar {
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 5px solid var(--primary-blue);
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .info-label {
        color: #6c757d;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 2px;
    }

    .info-value {
        color: #212529;
        font-weight: 700;
        font-size: .9rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        font-size: 1rem;
        padding: .5rem 0;
        border-bottom: 2px solid #e9ecef;
        margin-bottom: .75rem;
    }

        .section-header.blue {
            color: #0d6efd;
            border-color: #0d6efd;
        }

        .section-header.red {
            color: #dc3545;
            border-color: #dc3545;
        }

        .section-header.green {
            color: #198754;
            border-color: #198754;
        }

    .cls-result-card {
        border: none;
        border-radius: 10px;
        background: #e8f4fd;
        border-left: 4px solid #0d6efd;
        margin-bottom: .5rem;
    }

        .cls-result-card .card-header {
            background: linear-gradient(90deg,#0d6efd 0%,#6ea8fe 100%);
            border-radius: 10px 10px 0 0;
            color: #fff;
            font-weight: 700;
            padding: .5rem 1rem;
            font-size: .85rem;
        }

    .btn-action {
        border-radius: 8px;
        transition: all .25s;
        font-weight: 600;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

    .table thead th {
        background-color: var(--soft-bg);
        color: #495057;
        font-weight: 700;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #e9ecef;
        padding: .9rem;
    }

    .table tbody tr:hover {
        background: #f8fbff;
    }

    /* LỆNH CSS MA THUẬT CHO VIỆC IN PDF */
    @@media print {
        body { background-color: #fff; }
        /* Giấu toàn bộ UI trang web để dành không gian in */
        #sidebar, .top-navbar, .page-header-card, .queue-card, .exam-card, .d-print-none { display: none !important; }
        #content { margin-left: 0 !important; width: 100% !important; padding: 0 !important; }
        .main-body { padding: 0 !important; }

        /* Chỉ hiển thị khu vực đơn thuốc in ra */
        #printPrescriptionArea {
            display: block !important;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            background: #fff;
        }
        .table-bordered th, .table-bordered td {
            border: 1px solid #000 !important;
            padding: 8px !important;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="card page-header-card shadow-sm mb-4">
        <div class="card-body text-white p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h3 class="mb-1 fw-bold"><i class="fas fa-stethoscope me-2"></i> PHÒNG KHÁM BÁC SĨ</h3>
                    <p class="mb-0 opacity-75">Tiếp nhận, khám bệnh, kê đơn và quản lý kết quả cận lâm sàng</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (TempData["SuccessMsg"] != null)
                    {
                        <span class="badge bg-success bg-opacity-25 border border-success border-opacity-50 text-white px-3 py-2">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMsg"]
                        </span>
                    }
                    @if (TempData["ErrorMsg"] != null)
                    {
                        <span class="badge bg-danger bg-opacity-25 border border-danger border-opacity-50 text-white px-3 py-2">
                            <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMsg"]
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card queue-card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-users me-2"></i>Bệnh Nhân Chờ Khám</span>
                    @if (ViewBag.ChoKham != null)
                    {
                        <span class="badge bg-light text-primary rounded-pill">@(((System.Collections.ICollection)ViewBag.ChoKham).Count)</span>
                    }
                </div>
                <div class="card-body p-0" style="max-height: 380px; overflow-y: auto;">
                    <table class="table queue-table mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:50px">#</th>
                                <th>Tên Bệnh Nhân</th>
                                <th class="text-center" style="width:100px">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.ChoKham != null)
                            {
                                foreach (var item in ViewBag.ChoKham)
                                {
                                    string bgClass = item.TrangThai == "Đã có kết quả CLS" ? "table-warning border-warning" : "";
                                    <tr id="row-wait-@item.MaPhieuKhamBenh" class="@bgClass">
                                        <td><span class="badge bg-danger fs-6">@item.STT</span></td>
                                        <td class="align-middle fw-bold">
                                            @item.TenBN
                                            @if (item.TrangThai == "Đã có kết quả CLS")
                                            {
                                                <div class="mt-1"><span class="badge bg-warning text-dark"><i class="fas fa-check-circle"></i> Đã có KQ CLS</span></div>
                                            }
                                        </td>
                                        <td class="align-middle text-center">
                                            <button class="btn btn-sm btn-success shadow-sm" onclick="TiepNhanBN(@item.MaPhieuKhamBenh)">
                                                Tiếp nhận
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card queue-card">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-user-md me-2"></i>Danh sách Đang Khám</span>
                    <small class="text-dark opacity-75">Click để nạp</small>
                </div>
                <div class="card-body p-0" style="max-height: 280px; overflow-y: auto;">
                    <table class="table queue-table mb-0" id="table-dangkham">
                        <thead>
                            <tr>
                                <th>Tên Bệnh Nhân</th>
                                <th>Lý do</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.DangKham != null)
                            {
                                foreach (var item in ViewBag.DangKham)
                                {
                                    <tr style="cursor:pointer;" onclick="LoadDangKham(@item.MaPhieuKhamBenh)" id="row-dang-@item.MaPhieuKhamBenh">
                                        <td class="text-primary fw-bold">@item.TenBN</td>
                                        <td>@item.LyDoDenKham</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card exam-card">
                <div class="card-header">
                    <i class="fas fa-file-medical me-2"></i> Khung Khám Bệnh &amp; Kê Đơn
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("LuuKhamBenh", "BacSi", FormMethod.Post, new { id = "frmKhamBenh", @class = "form-horizontal" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="MaPhieuKhamBenh" name="MaPhieuKhamBenh" value="0" />

                        <div class="patient-info-bar">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="info-label">Họ tên bệnh nhân</div>
                                    <div class="info-value text-danger fs-5" id="lblTenBN">Chưa tiếp nhận</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="info-label">Tuổi</div>
                                    <div class="info-value" id="lblTuoi">&mdash;</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="info-label">Giới tính</div>
                                    <div class="info-value" id="lblGioiTinh">&mdash;</div>
                                </div>
                                <div class="col-md-12">
                                    <div class="info-label">Lý do khám</div>
                                    <div class="info-value text-primary" id="lblLyDo">&mdash;</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Triệu chứng lâm sàng / Khám thực thể:</label>
                            <textarea name="TrieuChung" id="TrieuChung" class="form-control" rows="3" placeholder="Nhập triệu chứng, dấu hiệu sinh tồn..."></textarea>
                        </div>

                        <div id="vungHienThiKQCLS" class="mb-3" style="display: none;">
                            <div class="section-header blue">
                                <i class="fas fa-file-medical-alt"></i> Kết Quả Cận Lâm Sàng Tự Động từ LIS
                            </div>
                            <div id="noiDungKQCLS"></div>
                        </div>

                        <div class="form-check form-switch mb-3 p-3 border rounded-3 bg-danger bg-opacity-10 border-danger">
                            <input type="checkbox" class="form-check-input ms-0" id="chkCLS" name="YeuCauCanLamSang" value="true" style="width: 2.5em; height: 1.25em;">
                            <label class="form-check-label text-danger fw-bold ms-5 mt-1" for="chkCLS" style="cursor: pointer;">
                                <i class="fas fa-x-ray me-1"></i> Yêu cầu khám Cận Lâm Sàng (Chưa thể kết luận bệnh)
                            </label>
                        </div>

                        <div id="vungChiDinhCLS" style="display: none;">
                            <div class="section-header red mt-3">
                                <i class="fas fa-x-ray"></i> Chỉ Định Dịch Vụ Cận Lâm Sàng
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Chọn dịch vụ (Sẽ tự động thêm xuống dưới):</label>
                                <select id="cboDichVu" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn dịch vụ --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachDichVu != null)
                                    {
                                        foreach (var dv in ViewBag.DanhSachDichVu)
                                        {
                                            <option value="@dv.MaDV" data-gia="@dv.GiaDichVu">[@dv.MaDV] @dv.TenDV</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle" id="tbDichVu">
                                    <thead class="table-warning">
                                        <tr>
                                            <th>Tên Dịch Vụ</th>
                                            <th width="350px">Phòng Thực Hiện (Gợi ý phòng trống nhất)</th>
                                            <th width="60px" class="text-center">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div id="vungKetLuan">
                            <div class="section-header blue mt-3">
                                <i class="fas fa-diagnoses"></i> Kết Luận và Kê Đơn Thuốc
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Kết luận bệnh (Nhập tay):</label>
                                <input type="text" name="KetLuan" id="KetLuan" class="form-control" placeholder="Ví dụ: Viêm họng cấp / Theo dõi viêm loét dạ dày..." />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Chẩn đoán theo danh mục Bệnh (Chọn để thêm tự động):</label>
                                <select id="cboBenh" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn bệnh --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachBenh != null)
                                    {
                                        foreach (var b in ViewBag.DanhSachBenh)
                                        {
                                            <option value="@b.MaBenh">[@b.MaBenh] @b.TenBenh</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle" id="tbBenhDaChọn">
                                    <thead class="table-secondary">
                                        <tr>
                                            <th width="150px">Mã Bệnh</th>
                                            <th>Tên Bệnh</th>
                                            <th width="60px" class="text-center">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>

                            <div class="section-header green mt-3">
                                <i class="fas fa-pills"></i> Kê Đơn Thuốc
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Chọn thuốc (Chọn để tự động thêm xuống đơn):</label>
                                <select id="cboThuoc" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn thuốc --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachThuoc != null)
                                    {
                                        foreach (var t in ViewBag.DanhSachThuoc)
                                        {
                                            <option value="@t.MaThuoc" data-gia="@t.GiaBan">@t.TenThuoc (ĐVT: @t.DonViCoBan)</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle text-center" id="tbDonThuoc">
                                    <thead class="table-success">
                                        <tr>
                                            <th class="text-start">Tên Thuốc</th>
                                            <th width="70px">Sáng</th>
                                            <th width="70px">Trưa</th>
                                            <th width="70px">Chiều</th>
                                            <th width="70px">Tối</th>
                                            <th width="80px">Số Ngày</th>
                                            <th width="80px">Số Lượng</th>
                                            <th width="180px">Cách dùng</th>
                                            <th width="50px">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 border-top pt-3">
                            <span class="text-muted small"><i class="fas fa-info-circle me-1"></i> Đảm bảo đã điền đầy đủ thông tin trước khi lưu</span>
                            <button type="button" class="btn btn-success btn-lg px-5 shadow-sm btn-action" id="btnHoanThanh" disabled>
                                <i class="fas fa-print me-2"></i>In & Lưu kết quả
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div id="printPrescriptionArea" class="d-none">
        <div class="row align-items-center mb-4">
            <div class="col-7">
                <div class="d-flex align-items-center gap-3">
                    <i class="fas fa-hospital text-primary" style="font-size: 2.5rem;"></i>
                    <div>
                        <h2 class="mb-0 fw-bold" style="color: #1e293b; font-size: 1.8rem;">HIS CLINIC CENTER</h2>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">MST: 0312345678 - Hotline: 1900 8888</p>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">ĐC: Số 123 Nguyễn Văn Cừ, Quận 5, TP.HCM</p>
                    </div>
                </div>
            </div>
            <div class="col-5 text-end">
                <h3 style="font-weight: 800; color: #3b82f6; font-size: 1.6rem; text-transform:uppercase;">HÓA ĐƠN & KẾT QUẢ KHÁM</h3>
                <p class="mb-0 fw-bold text-dark fs-5">Mã PK: <span class="text-danger" id="printMaPK"></span></p>
            </div>
        </div>

        <hr style="border-top: 2px solid #1e293b; margin-bottom: 2rem;" />

        <div class="row mb-4">
            <div class="col-12">
                <div style="font-size: 0.85rem; color: #64748b; font-weight: 600; text-transform: uppercase;">Thông tin bệnh nhân</div>
                <div class="text-primary fs-5 fw-bold" id="printTenBN"></div>
                <div class="row mt-2">
                    <div class="col-4">
                        <div style="font-size: 0.85rem; color: #64748b;">Tuổi / Giới tính</div>
                        <div class="fw-bold"><span id="printTuoi"></span> - <span id="printGioiTinh"></span></div>
                    </div>
                    <div class="col-8">
                        <div style="font-size: 0.85rem; color: #64748b;">Lý do khám</div>
                        <div class="fw-bold" id="printLyDo"></div>
                    </div>
                    <div class="col-12 mt-2">
                        <div style="font-size: 0.85rem; color: #64748b;">Kết luận chẩn đoán</div>
                        <div class="fw-bold text-danger" id="printChanDoan"></div>
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-bordered w-100" style="border-color: #000;">
            <thead style="background-color: #f8fafc !important; -webkit-print-color-adjust: exact;">
                <tr>
                    <th class="text-center" style="width: 50px;">STT</th>
                    <th>Nội dung (Thuốc / Dịch vụ)</th>
                    <th class="text-center" style="width: 80px;">S.Lượng</th>
                    <th class="text-end" style="width: 120px;">Đơn giá</th>
                    <th class="text-end" style="width: 120px;">Thành tiền</th>
                </tr>
            </thead>
            <tbody id="printTbBody">
            </tbody>
        </table>

        <div class="row justify-content-end mt-3">
            <div class="col-6 text-end">
                <div style="font-size: 1.3rem; font-weight: 800; color: #0f172a;">
                    <span class="text-primary">TỔNG CỘNG:</span>
                    <span class="text-danger fs-2 ms-2" id="printTongTien">0 ₫</span>
                </div>
                <div class="text-muted fst-italic" style="font-size: 0.85rem;">(Vui lòng mang phiếu này ra Quầy Thu Ngân)</div>
            </div>
        </div>

        <div class="row mt-5 pt-4 text-center">
            <div class="col-6">
                <div style="font-weight: 700; color: #334155;">Bệnh nhân</div>
                <div class="text-muted fst-italic" style="font-size: 0.8rem;">(Ký, ghi rõ họ tên)</div>
            </div>
            <div class="col-6">
                <div style="font-weight: 700; color: #334155;">Bác sĩ điều trị</div>
                <div class="text-muted fst-italic" style="font-size: 0.8rem;">(Ký, ghi rõ họ tên)</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        var thuocIndex = 0;
        var dvIndex = 0;

        $(document).ready(function () {
            $('.select2').select2({ width: '100%', theme: "classic", allowClear: true });

            $('#chkCLS').change(function() {
                if(this.checked) {
                    $('#vungKetLuan').slideUp();
                    $('#vungChiDinhCLS').slideDown();
                    $('#TrieuChung').attr('placeholder', 'Nhập tóm tắt triệu chứng yêu cầu cận lâm sàng...');
                    $('#btnHoanThanh').html('<i class="fas fa-print me-2"></i> In Cận Lâm Sàng & Lưu')
                                      .removeClass('btn-success').addClass('btn-danger');
                } else {
                    $('#vungKetLuan').slideDown();
                    $('#vungChiDinhCLS').slideUp();
                    $('#TrieuChung').attr('placeholder', 'Nhập triệu chứng, dấu hiệu sinh tồn...');
                    $('#btnHoanThanh').html('<i class="fas fa-print me-2"></i> In Đơn Thuốc & Lưu')
                                      .removeClass('btn-danger').addClass('btn-success');
                }
            });

            // SỰ KIỆN NÚT HOÀN THÀNH - IN TRƯỚC LƯU SAU
            $('#btnHoanThanh').on('click', function(e) {
                // 1. Chuẩn bị dữ liệu hiển thị lên tờ IN
                $('#printMaPK').text('#' + $('#MaPhieuKhamBenh').val());
                $('#printTenBN').text($('#lblTenBN').text());
                $('#printTuoi').text($('#lblTuoi').text());
                $('#printGioiTinh').text($('#lblGioiTinh').text());
                $('#printLyDo').text($('#lblLyDo').text());

                var chanDoan = $('#KetLuan').val();
                $('#tbBenhDaChọn tbody tr').each(function() {
                    var tenB = $(this).find('td:eq(1)').text();
                    if(tenB) chanDoan += (chanDoan ? ", " : "") + tenB;
                });
                $('#printChanDoan').text(chanDoan || 'Theo dõi / Chưa kết luận');

                var tbodyHtml = '';
                var stt = 1;
                var tongTien = 0;

                // 2. Nếu là chỉ định Cận Lâm Sàng
                if ($('#chkCLS').is(':checked')) {
                    $('#tbDichVu tbody tr').each(function() {
                        var tenDV = $(this).find('td:eq(0) strong').text();
                        var maDV = $(this).find('input[name*=".MaDV"]').val();
                        var option = $('#cboDichVu option[value="'+maDV+'"]');
                        var gia = option.length ? parseFloat(option.attr('data-gia') || 0) : 0;

                        tbodyHtml += `<tr>
                            <td class="text-center">${stt++}</td>
                            <td><strong>${tenDV}</strong></td>
                            <td class="text-center">1</td>
                            <td class="text-end">${gia.toLocaleString('vi-VN')} ₫</td>
                            <td class="text-end fw-bold">${gia.toLocaleString('vi-VN')} ₫</td>
                        </tr>`;
                        tongTien += gia;
                    });
                } else {
                    // 3. Nếu là kê Đơn Thuốc
                    $('#tbDonThuoc tbody tr').each(function() {
                        var tenThuoc = $(this).find('td:eq(0) strong').text();
                        var maThuoc = $(this).find('input[name*=".MaThuoc"]').val();
                        var sl = parseFloat($(this).find('.tong-sl').val()) || 0;
                        var option = $('#cboThuoc option[value="'+maThuoc+'"]');
                        var gia = option.length ? parseFloat(option.attr('data-gia') || 0) : 0;
                        var cachDung = $(this).find('select[name*=".GhiChu"]').val();
                        var thanhTien = gia * sl;

                        tbodyHtml += `<tr>
                            <td class="text-center">${stt++}</td>
                            <td>
                                <strong>${tenThuoc}</strong><br/>
                                <small class="text-muted">Cách dùng: ${cachDung}</small>
                            </td>
                            <td class="text-center">${sl}</td>
                            <td class="text-end">${gia.toLocaleString('vi-VN')} ₫</td>
                            <td class="text-end fw-bold">${thanhTien.toLocaleString('vi-VN')} ₫</td>
                        </tr>`;
                        tongTien += thanhTien;
                    });
                }

                if (tbodyHtml === '') {
                    tbodyHtml = '<tr><td colspan="5" class="text-center text-muted">Không có dịch vụ/thuốc nào được xuất.</td></tr>';
                }

                $('#printTbBody').html(tbodyHtml);
                $('#printTongTien').text(tongTien.toLocaleString('vi-VN') + ' ₫');

                // 4. Bật hộp thoại máy In (Cửa sổ Print PDF)
                window.print();

                // 5. Delay 1 chút rồi tự động Submit Form để Code lưu xuống DB chạy tiếp
                setTimeout(function() {
                    $('#frmKhamBenh').submit();
                }, 500);
            });

            // SỰ KIỆN CHỌN DỊCH VỤ CẬN LÂM SÀNG
            $('#cboDichVu').on('select2:select', function (e) {
                var data = e.params.data;
                var maDV = data.id;
                var tenDV = data.text;

                if (!maDV) return;

                var exists = false;
                $('input[name$=".MaDV"]').each(function() {
                    if($(this).val() == maDV) exists = true;
                });

                if(exists) {
                    alert('Dịch vụ này đã được chỉ định!');
                } else {
                    $.post('@Url.Action("GetPhongDichVu", "BacSi", new { area = "Staff" })', { maDV: maDV }, function(phongs) {
                        var options = '';
                        if (phongs && phongs.length > 0) {
                            phongs.forEach(function(p, i) {
                                var isSelected = (i === 0) ? 'selected' : '';
                                options += `<option value="${p.MaPhong}" ${isSelected}>${p.TenPhong} (Đang chờ: ${p.SoNguoiCho} người)</option>`;
                            });
                        } else {
                            options = '<option value="">-- Không có phòng phù hợp --</option>';
                        }

                        var tenHienThi = tenDV.split('] ')[1] || tenDV;
                        var tr = `
                            <tr>
                                <td>
                                    <input type="hidden" name="ChiDinhs.Index" value="${dvIndex}" />
                                    <input type="hidden" name="ChiDinhs[${dvIndex}].MaDV" value="${maDV}" />
                                    <strong class="text-primary">${tenHienThi}</strong>
                                </td>
                                <td>
                                    <select name="ChiDinhs[${dvIndex}].MaPhong" class="form-select form-select-sm border-danger text-danger fw-bold bg-light">
                                        ${options}
                                    </select>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="$(this).closest('tr').remove()" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
                        $('#tbDichVu tbody').append(tr);
                        dvIndex++;
                    });
                }
                $(this).val(null).trigger('change');
            });

            // SỰ KIỆN CHỌN BỆNH TỪ COMBOBOX
            $('#cboBenh').on('select2:select', function (e) {
                var data = e.params.data;
                var maBenh = data.id;
                var textBenh = data.text;

                if (!maBenh) return;

                var exists = false;
                $('input[name="DanhSachMaBenh"]').each(function() {
                    if($(this).val() == maBenh) exists = true;
                });

                if(exists) {
                    alert('Bệnh này đã được chẩn đoán!');
                } else {
                    var tenBenh = textBenh.split('] ')[1] || textBenh;
                    var tr = `
                        <tr>
                            <td>
                                <input type="hidden" name="DanhSachMaBenh" value="${maBenh}" />
                                <span class="badge bg-secondary">${maBenh}</span>
                            </td>
                            <td class="fw-bold">${tenBenh}</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="$(this).closest('tr').remove()" title="Xóa">
                                    <i class="fas fa-times"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    $('#tbBenhDaChọn tbody').append(tr);
                }
                $(this).val(null).trigger('change');
            });

            // SỰ KIỆN CHỌN THUỐC TỪ COMBOBOX
            $('#cboThuoc').on('select2:select', function (e) {
                var data = e.params.data;
                var maThuoc = data.id;
                var tenThuoc = data.text;

                if (!maThuoc) return;

                var exists = false;
                $('input[name$=".MaThuoc"]').each(function() {
                    if($(this).val() == maThuoc) exists = true;
                });

                if(exists) {
                    alert('Thuốc này đã có trong đơn!');
                } else {
                    var tr = `
                        <tr>
                            <td class="text-start align-middle">
                                <input type="hidden" name="DonThuoc.Index" value="${thuocIndex}" />
                                <input type="hidden" name="DonThuoc[${thuocIndex}].MaThuoc" value="${maThuoc}" />
                                <strong class="text-success">${tenThuoc}</strong>
                            </td>
                            <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Sang" value="0" min="0"></td>
                            <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Trua" value="0" min="0"></td>
                            <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Chieu" value="0" min="0"></td>
                            <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Toi" value="0" min="0"></td>
                            <td><input type="number" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].SoNgay" value="1" min="1"></td>

                            <td>
                                <input type="number" class="form-control form-control-sm text-center bg-warning text-dark fw-bold tong-sl border-warning" readonly value="0">
                            </td>

                            <td>
                                <select class="form-select form-select-sm" name="DonThuoc[${thuocIndex}].GhiChu">
                                    <option value="Uống sau khi ăn">Uống sau khi ăn</option>
                                    <option value="Uống trước khi ăn">Uống trước khi ăn</option>
                                    <option value="Uống trong bữa ăn">Uống trong bữa ăn</option>
                                    <option value="Hòa tan với nước">Hòa tan với nước</option>
                                    <option value="Ngậm dưới lưỡi">Ngậm dưới lưỡi</option>
                                    <option value="Bôi ngoài da">Bôi ngoài da</option>
                                    <option value="Nhỏ mắt/mũi/tai">Nhỏ mắt/mũi/tai</option>
                                    <option value="Sử dụng theo chỉ dẫn">Khác (Theo chỉ dẫn)</option>
                                </select>
                            </td>

                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="$(this).closest('tr').remove()" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    $('#tbDonThuoc tbody').append(tr);
                    thuocIndex++;
                }
                $(this).val(null).trigger('change');
            });

            $(document).on('input', '.input-calc', function() {
                var row = $(this).closest('tr');
                var sang = parseFloat(row.find('input[name*=".Sang"]').val()) || 0;
                var trua = parseFloat(row.find('input[name*=".Trua"]').val()) || 0;
                var chieu = parseFloat(row.find('input[name*=".Chieu"]').val()) || 0;
                var toi = parseFloat(row.find('input[name*=".Toi"]').val()) || 0;
                var songay = parseFloat(row.find('input[name*=".SoNgay"]').val()) || 0;

                var tong = (sang + trua + chieu + toi) * songay;
                row.find('.tong-sl').val(Math.ceil(tong));
            });
        });

        function ResetFormAndBindData(resData) {
            $('#MaPhieuKhamBenh').val(resData.MaPhieuKhamBenh);
            $('#lblTenBN').text(resData.TenBN);
            $('#lblTuoi').text(resData.Tuoi);
            $('#lblGioiTinh').text(resData.GioiTinh);
            $('#lblLyDo').text(resData.LyDoDenKham);
            $('#TrieuChung').val(resData.TrieuChung || '');
            $('#KetLuan').val('');
            $('#tbBenhDaChọn tbody').empty();
            $('#tbDonThuoc tbody').empty();
            $('#tbDichVu tbody').empty();
            $('#noiDungKQCLS').empty();
            $('#vungHienThiKQCLS').slideUp();

            thuocIndex = 0;
            dvIndex = 0;
            $('#chkCLS').prop('checked', false).trigger('change');
            $('#btnHoanThanh').prop('disabled', false);
            $('html, body').animate({ scrollTop: $('#frmKhamBenh').offset().top - 100 }, 500);
        }

        function TiepNhanBN(maPhieu) {
            $.post('@Url.Action("TiepNhan", "BacSi", new { area = "Staff" })', { maPhieu: maPhieu }, function (res) {
                if (res.success) {
                    $('#row-wait-' + maPhieu).fadeOut(300, function() { $(this).remove(); });

                    var rowDangKham = `<tr style="cursor:pointer;" onclick="LoadDangKham(${res.Data.MaPhieuKhamBenh})" id="row-dang-${res.Data.MaPhieuKhamBenh}">
                                            <td class="text-primary fw-bold">${res.Data.TenBN}</td>
                                            <td>${res.Data.LyDoDenKham}</td>
                                       </tr>`;
                    $('#table-dangkham tbody').append(rowDangKham);

                    ResetFormAndBindData(res.Data);
                    LoadKetQuaCLS(res.Data.MaPhieuKhamBenh);
                } else {
                    alert('Có lỗi xảy ra khi tiếp nhận bệnh nhân!');
                }
            });
        }

        function LoadDangKham(maPhieu) {
            $.post('@Url.Action("ChiTietDangKham", "BacSi", new { area = "Staff" })', { maPhieu: maPhieu }, function (res) {
                if (res.success) {
                    $('#table-dangkham tr').removeClass('table-active');
                    $('#row-dang-' + maPhieu).addClass('table-active');

                    ResetFormAndBindData(res.Data);
                    LoadKetQuaCLS(maPhieu);
                } else {
                    alert('Không lấy được thông tin bệnh nhân này!');
                }
            });
        }

        function LoadKetQuaCLS(maPhieu) {
            $.post('@Url.Action("GetKetQuaCLS", "BacSi", new { area = "Staff" })', { maPhieu: maPhieu }, function (data) {
                if (data && data.length > 0) {
                    $('#vungHienThiKQCLS').slideDown();
                    var content = '';
                    data.forEach(function(item) {
                        var htmlNoiDung = item.NoiDungKetQua || '';
                        if (htmlNoiDung.startsWith('[')) {
                            try {
                                var ls = JSON.parse(htmlNoiDung);
                                htmlNoiDung = '<table class="table table-sm table-bordered mt-2"><thead><tr class="table-light"><th>Chỉ số</th><th class="text-center">Kết quả</th><th class="text-center">Đơn vị</th><th class="text-center">CS Bình thường</th></tr></thead><tbody>';
                                ls.forEach(function(i) {
                                    var isWarn = i.Warning ? 'text-danger fw-bold' : 'fw-bold';
                                    htmlNoiDung += '<tr><td>' + i.Ten + '</td><td class="text-center ' + isWarn + '">' + i.GiaTri + '</td><td class="text-center">' + i.DonVi + '</td><td class="text-center">' + i.ThamChieu + '</td></tr>';
                                });
                                htmlNoiDung += '</tbody></table>';
                            } catch(e) {}
                        } else {
                            htmlNoiDung = '<div style="white-space:pre-wrap;">' + htmlNoiDung + '</div>';
                        }

                        var ngayTra = item.NgayThucHien || '';
                        if (ngayTra && ngayTra.indexOf('/Date(') >= 0) {
                            var date = new Date(parseInt(ngayTra.substr(6)));
                            ngayTra = date.toLocaleString('vi-VN');
                        }

                        content += `
                        <div class="cls-result-card mb-3">
                            <div class="card-header">
                                <i class="fas fa-flask me-1"></i> Dịch vụ: ${item.TenDichVu || item.TenDV} <span class="float-end">Ngày trả: ${ngayTra}</span>
                            </div>
                            <div class="card-body py-2">
                                ${htmlNoiDung}
                            </div>
                        </div>`;
                    });
                    $('#noiDungKQCLS').html(content);
                } else {
                    $('#vungHienThiKQCLS').slideUp();
                }
            });
        }
    </script>
}