</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        // ==========================================
        // 1. BIẾN VÀ CÁC HÀM TOÀN CỤC (GLOBAL SCOPE)
        // ==========================================
        var thuocIndex = 0;
        var dvIndex = 0;
        var isDaThanhToanKham = true;
        var phiKhamBenh = 0;
        var currentTrangThai = '';
        var suggestedDrugCodes = [];

        // Hàm thêm Dòng Bệnh
        function AddBenhRow(maBenh, tenBenh) {
            var tr = `
                <tr class="benh-row">
                    <td><input type="hidden" name="DanhSachMaBenh" value="${maBenh}" /><span class="badge bg-secondary">${maBenh}</span></td>
                    <td class="fw-bold">${tenBenh}</td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="XoaBenh(this, '${maBenh}')"><i class="fas fa-times"></i></button>
                    </td>
                </tr>`;
            $('#tbBenhDaChon tbody').append(tr);
            $('#cboBenh').find(`option[value="${maBenh}"]`).prop('disabled', true);
        }

        // Hàm thêm Dòng Thuốc (Cho phép nhập số thập phân step="0.5")
        function AddThuocRow(t) {
            var tr = `
                <tr>
                    <td class="text-start align-middle">
                        <input type="hidden" name="DonThuoc.Index" value="${thuocIndex}" />
                        <input type="hidden" name="DonThuoc[${thuocIndex}].MaThuoc" value="${t.MaThuoc}" />
                        <strong class="text-success">${t.TenThuoc}</strong>
                    </td>
                    <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Sang" value="${t.Sang || 0}" min="0"></td>
                    <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Trua" value="${t.Trua || 0}" min="0"></td>
                    <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Chieu" value="${t.Chieu || 0}" min="0"></td>
                    <td><input type="number" step="0.5" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].Toi" value="${t.Toi || 0}" min="0"></td>
                    <td><input type="number" class="form-control form-control-sm text-center input-calc" name="DonThuoc[${thuocIndex}].SoNgay" value="${t.SoNgay || 1}" min="1"></td>
                    <td><input type="number" class="form-control form-control-sm text-center bg-warning text-dark fw-bold tong-sl" readonly value="${t.SoLuong || 0}" name="DonThuoc[${thuocIndex}].SoLuong"></td>
                    <td>
                        <select class="form-select form-select-sm" name="DonThuoc[${thuocIndex}].GhiChu">
                            <option value="Uống sau ăn" ${t.GhiChu == 'Uống sau ăn' ? 'selected' : ''}>Uống sau ăn</option>
                            <option value="Uống trước ăn" ${t.GhiChu == 'Uống trước ăn' ? 'selected' : ''}>Uống trước ăn</option>
                            <option value="Ngậm" ${t.GhiChu == 'Ngậm' ? 'selected' : ''}>Ngậm</option>
                            <option value="Bôi ngoài da" ${t.GhiChu == 'Bôi ngoài da' ? 'selected' : ''}>Bôi ngoài da</option>
                        </select>
                    </td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="XoaThuoc(this, '${t.MaThuoc}')"><i class="fas fa-trash"></i></button></td>
                </tr>`;
            $('#tbDonThuoc tbody').append(tr);
            thuocIndex++;
            // Đánh dấu thuốc đã kê và làm mờ nó
            $('#cboThuoc').find(`option[value="${t.MaThuoc}"]`).addClass('in-prescription').prop('disabled', true);
        }

        // Xóa Bệnh và Thuốc (Mở khóa lại trong Combobox)
        function XoaBenh(btn, ma) { $(btn).closest('tr').remove(); $('#cboBenh').find(`option[value="${ma}"]`).prop('disabled', false).trigger('change'); }
        function XoaThuoc(btn, ma) {
            $(btn).closest('tr').remove();
            $('#cboThuoc').find(`option[value="${ma}"]`).removeClass('in-prescription');
            ApplyBHYTFilter(); // Lọc lại để trả thuốc về danh sách combobox
        }

        function ApplyBHYTFilter() {
            var chkCo = $('#chkCoBHYT').is(':checked');
            var chkKhong = $('#chkKhongBHYT').is(':checked');
            var showAll = (chkCo && chkKhong) || (!chkCo && !chkKhong);

            var currentVal = $('#cboThuoc').val();
            var currentSuggestions = suggestedDrugCodes.slice();
            var currentSuggestionMap = {};
            $('#cboThuoc option').each(function () {
                var code = (($(this).val() == null ? '' : String($(this).val()))).trim();
                if (code) currentSuggestionMap[code] = $(this).attr('data-suggested') === '1';
            });

            $('#cboThuoc').select2('destroy'); // Tắt Select2 để can thiệp DOM

            $('#cboThuoc option').each(function () {
                if ($(this).val() === "") return;

                var optionCode = (($(this).val() == null ? '' : String($(this).val()))).trim();
                var isBHYT = $(this).attr('data-bhyt') === "1";
                var inPrescription = $(this).hasClass('in-prescription');
                var isSuggested = currentSuggestions.indexOf(optionCode) >= 0 || currentSuggestionMap[optionCode] === true;

                if (showAll || (chkCo && isBHYT) || (chkKhong && !isBHYT)) {
                    $(this).prop('disabled', inPrescription); // Mở khóa nếu chưa kê
                    if (isSuggested) {
                        $(this).attr('data-suggested', '1');
                    }
                    // Bỏ thẻ span ẩn đi (nếu có)
                    if ($(this).parent().is('span.hidden-opt')) {
                        $(this).unwrap();
                    }
                } else {
                    $(this).prop('disabled', true);
                    if (isSuggested) {
                        $(this).attr('data-suggested', '1');
                    }
                    // Bọc bằng thẻ span có display:none để Select2 bỏ qua option này
                    if (!$(this).parent().is('span.hidden-opt')) {
                        $(this).wrap('<span class="hidden-opt" style="display:none;"></span>');
                    }
                }
            });

            $('#cboThuoc').select2({
                width: '100%',
                theme: "classic",
                allowClear: true,
                dropdownCssClass: 'thuoc-dropdown-below',
                escapeMarkup: function (markup) { return markup; },
                templateResult: function (data) {
                    if (!data.id) return data.text;
                    var $el = data.element ? $(data.element) : null;
                    var isSug = $el && $el.attr('data-suggested') === '1';
                    var bhytStatus = $el && $el.attr('data-bhyt') === '1' ? '<span class="badge bg-success" style="font-size: 0.75rem;">BHYT</span>' : '<span class="badge bg-secondary" style="font-size: 0.75rem;">Không BHYT</span>';
                    var text = ($el && $el.text()) || data.text;
                    if (isSug) {
                        return $('<div style="background-color: #fffae6; border-left: 3px solid #ffc107; padding: 4px 8px; border-radius: 4px;"><i class="fas fa-star text-warning me-1"></i> ' + bhytStatus + ' <strong class="text-danger ms-1">' + text.replace(/^★\s*/, '') + '</strong></div>');
                    }
                    return $('<div style="padding: 4px 8px;">' + bhytStatus + ' <span class="ms-1 fw-bold text-dark">' + text + '</span></div>');
                },
                templateSelection: function (data) {
                    if (!data.id) return data.text;
                    return data.text || '';
                }
            });

            // Xóa giá trị đang hiển thị trên combobox nếu nó bị bộ lọc ẩn đi
            if ($('#cboThuoc option:selected').prop('disabled') || $('#cboThuoc option:selected').parent().is('span.hidden-opt')) {
                $('#cboThuoc').val(null).trigger('change');
            } else {
                $('#cboThuoc').val(currentVal).trigger('change');
            }
        }

        // Logic Phân Trang cho 3 bảng
        function setupPagination(tbodyId, navId, itemsPerPage) {
            let rows = $('#' + tbodyId + ' tr.paginate-row');
            let totalRows = rows.length;
            let totalPages = Math.ceil(totalRows / itemsPerPage);
            if (totalPages <= 1) { $('#' + navId).empty(); return; }

            function showPage(page) {
                if (page < 1) page = 1;
                if (page > totalPages) page = totalPages;

                rows.hide();
                rows.slice((page - 1) * itemsPerPage, page * itemsPerPage).show();

                let html = '<nav><ul class="pagination pagination-sm mb-0">';
                html += `<li class="page-item ${page === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="1">&laquo;&laquo;</a></li>`;
                html += `<li class="page-item ${page === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${page - 1}">&laquo;</a></li>`;
                for (let i = 1; i <= totalPages; i++) {
                    html += `<li class="page-item ${page === i ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
                }
                html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${page + 1}">&raquo;</a></li>`;
                html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${totalPages}">&raquo;&raquo;</a></li>`;
                html += '</ul></nav>';

                $('#' + navId).html(html);
                $('#' + navId + ' .page-link').off('click').on('click', function (e) {
                    e.preventDefault();
                    let targetPage = parseInt($(this).attr('data-page'));
                    if (!isNaN(targetPage)) showPage(targetPage);
                });
            }
            showPage(1);
        }

        // Cập nhật giao diện khi chọn/tiếp nhận bệnh nhân
        // Cập nhật giao diện khi chọn/tiếp nhận bệnh nhân
        function ResetFormAndBindData(resData) {
            $('#MaPhieuKhamBenh').val(resData.MaPhieuKhamBenh);
            $('#lblTenBN').text(resData.TenBN);
            $('#lblTuoi').text(resData.NgaySinhStr + ' (' + resData.Tuoi + ' tuổi)');
            $('#lblGioiTinh').text(resData.GioiTinh);
            $('#lblSDT').text(resData.SoDienThoai);
            $('#lblDiaChi').text(resData.DiaChi);
            $('#lblLyDo').text(resData.LyDoDenKham);
            $('#TrieuChung').val(resData.TrieuChung || '');
            $('#KetLuan').val(resData.KetLuan || '');

            // Đổ dữ liệu Sinh hiệu và Dặn dò
            $('#ChieuCao').val(resData.ChieuCao || '');
            $('#CanNang').val(resData.CanNang || '');
            $('#NhietDo').val(resData.NhietDo || '');
            $('#HuyetApTamThu').val(resData.HuyetApTamThu || '');
            $('#HuyetApTamTruong').val(resData.HuyetApTamTruong || '');
            $('#Mach').val(resData.Mach || '');
            $('#SpO2').val(resData.SpO2 || '');
            $('#DanDo').val(resData.DanDo || '');

            if (resData.NgayTaiKhamStr) {
                $('#NgayTaiKham').val(resData.NgayTaiKhamStr.split('T')[0].split(' ')[0]);
            } else {
                $('#NgayTaiKham').val('');
            }

            var cccd = resData.CCCD || 'Chưa cập nhật';
            $('#lblCCCD').text(cccd);
            $('#printCCCD').text(cccd);

            var bhytText = 'Không có BHYT';
            if (resData.BHYT === true) {
                var soThe = resData.SoTheBHYT || '---';
                var hsd = resData.HanSuDungBHYTStr || '---';
                var mucHuong = resData.MucHuongBHYT || 0;
                bhytText = `Có (${mucHuong}%) - Số: ${soThe} - HSD: ${hsd}`;
            }
            $('#lblBHYT').text(bhytText);
            $('#printBHYT').text(bhytText);

            isDaThanhToanKham = resData.DaThanhToanKham !== false;
            phiKhamBenh = resData.PhiKham || 0;
            currentTrangThai = resData.TrangThai;
            $('#printTenBS').text(resData.TenBS || '');

            // Làm sạch UI
            $('#tbBenhDaChon tbody').empty();
            $('#tbDonThuoc tbody').empty();
            $('#tbDichVu tbody').empty();
            $('#noiDungKQCLS').empty();
            $('#vungHienThiKQCLS').slideUp();
            thuocIndex = 0;
            dvIndex = 0;

            // Uncheck các bộ lọc BHYT để reset trạng thái
            $('#chkCoBHYT, #chkKhongBHYT').prop('checked', false);

            // Kích hoạt lại option trong combobox và bỏ đánh dấu đang kê
            $('#cboBenh option').prop('disabled', false);
            $('#cboThuoc option').removeClass('in-prescription').prop('disabled', false);

            // Kích hoạt lại option trong combobox
            $('#cboBenh option, #cboThuoc option').prop('disabled', false);

            // Nạp dữ liệu cũ (Nếu bệnh nhân Đã Khám)
            if (resData.DanhSachBenh) resData.DanhSachBenh.forEach(b => AddBenhRow(b.MaBenh, b.TenBenh));
            if (resData.DanhSachThuoc) resData.DanhSachThuoc.forEach(t => AddThuocRow(t));

            if (resData.DanhSachDichVu && resData.DanhSachDichVu.length > 0) {
                $('#chkCLS').prop('checked', true);
                resData.DanhSachDichVu.forEach(function (dv) {
                    var tr = `
                        <tr>
                            <td>
                                <input type="hidden" name="ChiDinhs.Index" value="${dvIndex}" />
                                <input type="hidden" name="ChiDinhs[${dvIndex}].MaDV" value="${dv.MaDV}" />
                                <input type="hidden" class="dv-gia" value="${dv.Gia}" /> <strong class="text-primary">${dv.TenDV}</strong>
                            </td>
                            <td>
                                <select name="ChiDinhs[${dvIndex}].MaPhong" class="form-select form-select-sm border-danger text-danger fw-bold bg-light">
                                    <option value="${dv.MaPhong}">Phòng đang thực hiện / Đã xếp</option>
                                </select>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="$(this).closest('tr').remove()"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>`;
                    $('#tbDichVu tbody').append(tr);
                    dvIndex++;
                });
            } else {
