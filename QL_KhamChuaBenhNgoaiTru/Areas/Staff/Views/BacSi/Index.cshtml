        <hr style="border-top: 2px solid #1e293b; margin-bottom: 1.5rem;" />

        <div class="row mb-4">
            <div class="col-12">
                <div style="font-size: 0.9rem; color: #64748b; font-weight: bold; text-transform: uppercase; border-bottom: 1px solid #cbd5e1; padding-bottom: 5px; margin-bottom: 10px;">THÔNG TIN BỆNH NHÂN</div>
                <div class="row">
                    <div class="col-7">
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">Họ và tên:</span>
                            <span class="text-primary fs-5 fw-bold text-uppercase" id="printTenBN"></span>
                        </div>
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">Ngày sinh:</span>
                            <span class="fw-bold" id="printTuoi"></span>
                        </div>
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">Địa chỉ:</span>
                            <span class="fw-bold" id="printDiaChi"></span>
                        </div>
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">BHYT:</span>
                            <span class="fw-bold text-success" id="printBHYT"></span>
                        </div>
                    </div>
                    <div class="col-5">
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">Giới tính:</span>
                            <span class="fw-bold" id="printGioiTinh"></span>
                        </div>
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">Điện thoại:</span>
                            <span class="fw-bold" id="printSDT"></span>
                        </div>
                        <div class="d-flex align-items-baseline gap-2 mb-1">
                            <span style="font-size: 0.85rem; color: #64748b; width: 75px;">CCCD:</span>
                            <span class="fw-bold" id="printCCCD"></span>
                        </div>
                    </div>
                </div>
                <div class="row mt-2 pt-2" style="border-top: 1px dashed #cbd5e1;">
                    <div class="col-12 mb-1 d-flex align-items-baseline gap-2">
                        <span style="font-size: 0.85rem; color: #64748b; width: 130px;">Lý do khám:</span>
                        <span class="fw-bold" id="printLyDo"></span>
                    </div>
                    <div class="col-12 d-flex align-items-baseline gap-2">
                        <span style="font-size: 0.85rem; color: #64748b; width: 130px;">Kết luận chẩn đoán:</span>
                        <span class="fw-bold text-danger" id="printChanDoan"></span>
                    </div>
                </div>
