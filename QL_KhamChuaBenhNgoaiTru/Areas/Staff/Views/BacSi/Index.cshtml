@model QL_KhamChuaBenhNgoaiTru.Models.KhamBenhViewModel
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";
    ViewBag.Title = "Phòng Khám Bác Sĩ";
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.min.css" rel="stylesheet">

<style>
    :root {
        --primary-blue: #0d6efd;
        --dark-blue: #0a58ca;
        --soft-bg: #f8f9fa;
    }

    body {
        background-color: #f4f7f6;
    }

    .page-header-card {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--dark-blue) 100%);
        border: none;
        border-radius: 15px;
        margin-bottom: 1.5rem;
    }

    .queue-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.07);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

        .queue-card .card-header {
            padding: .85rem 1.25rem;
            font-weight: 700;
            font-size: .85rem;
            letter-spacing: .3px;
            text-transform: uppercase;
        }

    .queue-table thead th {
        background-color: var(--soft-bg);
        color: #495057;
        font-weight: 700;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #e9ecef;
        padding: .9rem 1rem;
    }

    .queue-table tbody tr {
        border-bottom: 1px solid #f0f0f0;
        transition: background .15s;
    }

        .queue-table tbody tr:hover {
            background: #f0f7ff;
        }

        .queue-table tbody tr.table-active {
            background: #dbeafe;
        }

    .exam-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.09);
        overflow: hidden;
    }

        .exam-card .card-header {
            background: linear-gradient(90deg, #0d6efd 0%, #6ea8fe 100%);
            color: #fff;
            padding: 1rem 1.5rem;
            font-weight: 700;
            font-size: 1rem;
        }

    .patient-info-bar {
        background: #f8f9fa;
        border-radius: 10px;
        border-left: 5px solid var(--primary-blue);
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .info-label {
        color: #6c757d;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 2px;
    }

    .info-value {
        color: #212529;
        font-weight: 700;
        font-size: .9rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        font-size: 1rem;
        padding: .5rem 0;
        border-bottom: 2px solid #e9ecef;
        margin-bottom: .75rem;
    }

        .section-header.blue {
            color: #0d6efd;
            border-color: #0d6efd;
        }

        .section-header.red {
            color: #dc3545;
            border-color: #dc3545;
        }

        .section-header.green {
            color: #198754;
            border-color: #198754;
        }

    .cls-result-card {
        border: none;
        border-radius: 10px;
        background: #e8f4fd;
        border-left: 4px solid #0d6efd;
        margin-bottom: .5rem;
    }

        .cls-result-card .card-header {
            background: linear-gradient(90deg,#0d6efd 0%,#6ea8fe 100%);
            border-radius: 10px 10px 0 0;
            color: #fff;
            font-weight: 700;
            padding: .5rem 1rem;
            font-size: .85rem;
        }

    .btn-action {
        border-radius: 8px;
        transition: all .25s;
        font-weight: 600;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

    .table thead th {
        background-color: var(--soft-bg);
        color: #495057;
        font-weight: 700;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #e9ecef;
        padding: .9rem;
    }

    .table tbody tr:hover {
        background: #f8fbff;
    }

    /* LỆNH CSS CHO VIỆC IN PDF */
    @@media print {
        body {
            background-color: #fff;
        }

        #sidebar, .top-navbar, .page-header-card, .queue-card, .exam-card, .d-print-none {
            display: none !important;
        }

        #content {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 0 !important;
        }

        .main-body {
            padding: 0 !important;
        }

        #printPrescriptionArea {
            display: block !important;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            background: #fff;
        }

        .table-bordered th, .table-bordered td {
            border: 1px solid #000 !important;
            padding: 8px !important;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="card page-header-card shadow-sm mb-4">
        <div class="card-body text-white p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h3 class="mb-1 fw-bold"><i class="fas fa-stethoscope me-2"></i> PHÒNG KHÁM BÁC SĨ</h3>
                    <p class="mb-0 opacity-75">Tiếp nhận, khám bệnh, kê đơn và quản lý kết quả cận lâm sàng</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (TempData["SuccessMsg"] != null)
                    {
                        <span class="badge bg-success bg-opacity-25 border border-success border-opacity-50 text-white px-3 py-2">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMsg"]
                        </span>
                    }
                    @if (TempData["ErrorMsg"] != null)
                    {
                        <span class="badge bg-danger bg-opacity-25 border border-danger border-opacity-50 text-white px-3 py-2">
                            <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMsg"]
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body bg-white">
            <div class="row align-items-end g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-primary"><i class="fas fa-search me-2"></i>Tra cứu hồ sơ bệnh nhân toàn hệ thống</label>
                    <select id="cboTimBenhNhan" class="form-select select2" style="width: 100%;">
                        <option value="">-- Chọn bệnh nhân để xem lịch sử --</option>
                    </select>
                </div>
                <div class="col-md-6" id="boxChonLichSu" style="display:none;">
                    <label class="form-label fw-bold text-danger"><i class="fas fa-history me-2"></i>Lịch sử các lần khám (Tự động chọn gần nhất)</label>
                    <select id="cboLichSuKham" class="form-select select2" style="width: 100%;"></select>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 shadow-sm border-info" id="panelChiTietLichSu" style="display:none; border-radius: 12px;">
        <div class="card-header bg-info text-white fw-bold d-flex justify-content-between align-items-center">
            <span><i class="fas fa-file-medical-alt me-2"></i>CHI TIẾT HỒ SƠ KHÁM BỆNH CŨ</span>
            <button type="button" class="btn-close btn-close-white" onclick="$('#panelChiTietLichSu').slideUp()"></button>
        </div>
        <div class="card-body bg-light" id="contentChiTietLichSu">
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card queue-card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-users me-2"></i>Chờ Khám</span>
                    <div class="d-flex align-items-center">
                        @if (ViewBag.ChoKham != null)
                        {
                            <span class="badge bg-light text-primary rounded-pill me-2" id="badge-cho-kham">@(((System.Collections.ICollection)ViewBag.ChoKham).Count)</span>}
                        <button type="button" id="btnReloadChoKham" class="btn btn-sm btn-light text-primary shadow-sm py-0 px-2" title="Làm mới danh sách chờ">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table queue-table mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:40px">#</th>
                                <th>Bệnh Nhân</th>
                                <th class="text-center" style="width:90px">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="body-cho-kham">
                            @if (ViewBag.ChoKham != null)
                            {
                                foreach (var item in ViewBag.ChoKham)
                                {
                                    string bgClass = item.TrangThai == "Đã có kết quả CLS" ? "table-warning border-warning" : "";
                                    <tr id="row-wait-@item.MaPhieuKhamBenh" class="paginate-row @bgClass">
                                        <td><span class="badge bg-danger fs-6">@item.STT</span></td>
                                        <td class="align-middle fw-bold">
                                            @item.TenBN
                                            @if (item.TrangThai == "Đã có kết quả CLS")
                                            {
                                                <div class="mt-1"><span class="badge bg-warning text-dark"><i class="fas fa-check-circle"></i> Có KQ CLS</span></div>
                                            }
                                        </td>
                                        <td class="align-middle text-center">
                                            <button class="btn btn-sm btn-success shadow-sm" onclick="TiepNhanBN('@item.MaPhieuKhamBenh')">Khám</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div id="page-cho-kham" class="d-flex justify-content-center py-2 bg-light"></div>
                </div>
            </div>

            <div class="card queue-card">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-user-md me-2"></i>Đang Khám</span>
                    <small class="text-dark opacity-75">Click để nạp</small>
                </div>
                <div class="card-body p-0">
                    <table class="table queue-table mb-0" id="table-dangkham">
                        <thead>
                            <tr>
                                <th>Tên Bệnh Nhân</th>
                                <th>Lý do</th>
                            </tr>
                        </thead>
                        <tbody id="body-dang-kham">
                            @if (ViewBag.DangKham != null)
                            {
                                foreach (var item in ViewBag.DangKham)
                                {
                                    // Đổi màu nền nhẹ nếu đã có kết quả CLS để bác sĩ dễ chú ý
                                    string bgDangKham = item.TrangThai == "Đã có kết quả CLS" ? "table-warning border-warning" : "";
                                    <tr style="cursor:pointer;" class="paginate-row @bgDangKham" onclick="LoadDangKham('@item.MaPhieuKhamBenh')" id="row-dang-@item.MaPhieuKhamBenh">

                                        <td class="text-primary fw-bold">
                                            @item.TenBN

                                            @if (item.TrangThai == "Chờ thanh toán" || item.TrangThai == "Chờ cận lâm sàng")
                                            {
                                                <div class="mt-1"><span class="badge bg-secondary"><i class="fas fa-running me-1"></i>Đang đi CLS</span></div>
                                            }
                                            else if (item.TrangThai == "Đã có kết quả CLS")
                                            {
                                                <div class="mt-1"><span class="badge bg-warning text-dark"><i class="fas fa-check-circle me-1"></i>Đã xong CLS</span></div>
                                            }
                                        </td>
                                        <td class="align-middle">@item.LyDoDenKham</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div id="page-dang-kham" class="d-flex justify-content-center py-2 bg-light"></div>
                </div>
            </div>

            <div class="card queue-card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-check-double me-2"></i>Đã Khám Xong</span>
                </div>
                <div class="card-body p-0">
                    <table class="table queue-table mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:40px">#</th>
                                <th>Tên Bệnh Nhân</th>
                                <th>Lý do</th>
                            </tr>
                        </thead>
                        <tbody id="body-da-kham">
                            @if (ViewBag.DaKham != null)
                            {
                                int sttDK = 1;
                                foreach (var item in ViewBag.DaKham)
                                {
                                    <tr style="cursor:pointer;" class="paginate-row" onclick="LoadDangKham('@item.MaPhieuKhamBenh')" id="row-dakham-@item.MaPhieuKhamBenh">

                                        <td class="text-center">@(sttDK++)</td>
                                        <td class="text-success fw-bold">@item.TenBN</td>
                                        <td>@item.LyDoDenKham</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div id="page-da-kham" class="d-flex justify-content-center py-2 bg-light"></div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card exam-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-file-medical me-2"></i> Khung Khám Bệnh &amp; Kê Đơn</span>
                    <button class="btn btn-sm btn-light text-primary shadow-sm fw-bold" onclick="window.location.reload()" type="button" title="Hủy bỏ dữ liệu đang nhập và làm mới trang">
                        <i class="fas fa-sync-alt me-1"></i> Làm mới
                    </button>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("LuuKhamBenh", "BacSi", FormMethod.Post, new { id = "frmKhamBenh", @class = "form-horizontal" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="MaPhieuKhamBenh" name="MaPhieuKhamBenh" value="0" />

                        <div class="patient-info-bar">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <div class="info-label">Họ tên bệnh nhân</div>
                                    <div class="info-value text-danger fs-5" id="lblTenBN">Chưa tiếp nhận</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="info-label">Ngày sinh (Tuổi)</div>
                                    <div class="info-value" id="lblTuoi">&mdash;</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="info-label">Giới tính</div>
                                    <div class="info-value" id="lblGioiTinh">&mdash;</div>
                                </div>
                                <div class="col-md-2">
                                    <div class="info-label">CCCD</div>
                                    <div class="info-value" id="lblCCCD">&mdash;</div>
                                </div>
                                <div class="col-md-3">
                                    <div class="info-label">SĐT</div>
                                    <div class="info-value" id="lblSDT">&mdash;</div>
                                </div>
                                <div class="col-md-5">
                                    <div class="info-label">Địa chỉ liên hệ</div>
                                    <div class="info-value" id="lblDiaChi">&mdash;</div>
                                </div>
                                <div class="col-md-7">
                                    <div class="info-label">Thông tin BHYT</div>
                                    <div class="info-value text-success" id="lblBHYT">&mdash;</div>
                                </div>
                                <div class="col-md-12">
                                    <div class="info-label">Lý do khám</div>
                                    <div class="info-value text-primary fw-bold" id="lblLyDo">&mdash;</div>
                                </div>
                            </div>
                        </div>

                        <div class="section-header blue mt-3">
                            <i class="fas fa-heartbeat"></i> Chỉ số Sinh hiệu (Khám sàng lọc)
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-2 col-sm-4">
                                <label class="form-label text-muted small fw-bold mb-1">Chiều cao (cm)</label>
                                <input type="number" step="0.1" class="form-control form-control-sm" name="ChieuCao" id="ChieuCao" />
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <label class="form-label text-muted small fw-bold mb-1">Cân nặng (kg)</label>
                                <input type="number" step="0.1" class="form-control form-control-sm" name="CanNang" id="CanNang" />
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <label class="form-label text-muted small fw-bold mb-1">Nhiệt độ (°C)</label>
                                <input type="number" step="0.1" class="form-control form-control-sm" name="NhietDo" id="NhietDo" />
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <label class="form-label text-muted small fw-bold mb-1">Mạch (lần/p)</label>
                                <input type="number" class="form-control form-control-sm" name="Mach" id="Mach" />
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label text-muted small fw-bold mb-1">Huyết áp (T.Thu / T.Trương)</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" class="form-control text-center" name="HuyetApTamThu" id="HuyetApTamThu" placeholder="120" />
                                    <span class="input-group-text bg-light">/</span>
                                    <input type="number" class="form-control text-center" name="HuyetApTamTruong" id="HuyetApTamTruong" placeholder="80" />
                                </div>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <label class="form-label text-muted small fw-bold mb-1">SpO2 (%)</label>
                                <input type="number" class="form-control form-control-sm" name="SpO2" id="SpO2" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Triệu chứng lâm sàng / Khám thực thể:</label>
                            <textarea name="TrieuChung" id="TrieuChung" class="form-control" rows="3" placeholder="Nhập triệu chứng, dấu hiệu bệnh lý..."></textarea>
                        </div>

                        <div id="vungHienThiKQCLS" class="mb-3" style="display: none;">
                            <div class="section-header blue">
                                <i class="fas fa-file-medical-alt"></i> Kết Quả Cận Lâm Sàng Tự Động từ LIS
                            </div>
                            <div id="noiDungKQCLS"></div>
                        </div>

                        <div class="form-check form-switch mb-3 p-3 border rounded-3 bg-danger bg-opacity-10 border-danger">
                            <input type="checkbox" class="form-check-input ms-0" id="chkCLS" name="YeuCauCanLamSang" value="true" style="width: 2.5em; height: 1.25em;">
                            <label class="form-check-label text-danger fw-bold ms-5 mt-1" for="chkCLS" style="cursor: pointer;">
                                <i class="fas fa-x-ray me-1"></i> Yêu cầu khám Cận Lâm Sàng (Chưa thể kết luận bệnh)
                            </label>
                        </div>

                        <div id="vungChiDinhCLS" style="display: none;">
                            <div class="section-header red mt-3">
                                <i class="fas fa-x-ray"></i> Chỉ Định Dịch Vụ Cận Lâm Sàng
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Chọn dịch vụ (Sẽ tự động thêm xuống dưới):</label>
                                <select id="cboDichVu" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn dịch vụ --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachDichVu != null)
                                    {
                                        foreach (var dv in ViewBag.DanhSachDichVu)
                                        {
                                            <option value="@dv.MaDV" data-gia="@dv.GiaDichVu">[@dv.MaDV] @dv.TenDV</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle" id="tbDichVu">
                                    <thead class="table-warning">
                                        <tr>
                                            <th>Tên Dịch Vụ</th>
                                            <th width="350px">Phòng Thực Hiện (Gợi ý phòng trống nhất)</th>
                                            <th width="60px" class="text-center">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <div id="vungKetLuan">
                            <div class="section-header blue mt-3">
                                <i class="fas fa-diagnoses"></i> Kết Luận và Kê Đơn Thuốc
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Kết luận bệnh (Nhập tay):</label>
                                <input type="text" name="KetLuan" id="KetLuan" class="form-control" placeholder="Ví dụ: Viêm họng cấp / Theo dõi viêm loét dạ dày..." />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Chẩn đoán theo danh mục Bệnh (Chọn để thêm tự động):</label>
                                <select id="cboBenh" class="form-select select2" data-placeholder="-- Tìm kiếm và chọn bệnh --">
                                    <option value=""></option>
                                    @if (ViewBag.DanhSachBenh != null)
                                    {
                                        int sttBenh = 1;
                                        foreach (var b in ViewBag.DanhSachBenh)
                                        {
                                            <option value="@b.MaBenh">[#@(sttBenh++)] @b.TenBenh</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle" id="tbBenhDaChon">
                                    <thead class="table-secondary">
                                        <tr>
                                            <th width="150px">Mã Bệnh</th>
                                            <th>Tên Bệnh</th>
                                            <th width="60px" class="text-center">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>

                            <div class="section-header green mt-3 d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-pills"></i> Kê Đơn Thuốc</span>
                                <button type="button" class="btn btn-sm btn-outline-success" id="btnGoiYThuoc">
                                    <i class="fas fa-magic me-1"></i> Gợi ý thuốc
                                </button>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-end mb-2">
                                    <label class="form-label mb-0">Chọn thuốc (Chọn để tự động thêm xuống đơn):</label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check form-check-inline text-success mb-0">
                                            <input class="form-check-input filter-bhyt" type="checkbox" id="chkCoBHYT" value="1">
