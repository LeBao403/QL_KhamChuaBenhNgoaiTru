        </div>

        <table class="table table-bordered w-100" style="border-color: #000;">
            <thead id="printTableThead" style="background-color: #f8fafc !important; -webkit-print-color-adjust: exact;">
            </thead>
            <tbody id="printTbBody"></tbody>
        </table>

        <div class="row mt-4 pt-4 text-center">
            <div class="col-6">
            </div>
            <div class="col-6">
                <div style="font-weight: 700; color: #334155;">Bác sĩ điều trị</div>
                <div class="text-muted fst-italic" style="font-size: 0.8rem;">(Ký, ghi rõ họ tên)</div>
                <div class="mt-5 fw-bold text-dark fs-5" id="printTenBS"></div>
            </div>
        </div>
