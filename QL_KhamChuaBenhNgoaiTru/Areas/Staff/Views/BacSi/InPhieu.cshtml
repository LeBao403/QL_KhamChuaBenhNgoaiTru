@model QL_KhamChuaBenhNgoaiTru.Areas.Staff.Controllers.BacSiController.InPhieuViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@(Model.IsCLS ? "Phiếu Chỉ Định Cận Lâm Sàng" : "Đơn Thuốc & Kết Quả Khám")</title>
    <style>
        body { font-family: 'Times New Roman', serif; font-size: 15px; margin: 0; padding: 20px; }
        .header { text-align: center; margin-bottom: 20px; }
        .hospital-name { font-size: 18px; font-weight: bold; text-transform: uppercase; }
        .title { font-size: 22px; font-weight: bold; margin-top: 15px; text-transform: uppercase; }
        .info-row { margin-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        table, th, td { border: 1px solid black; }
        th, td { padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; text-align: center; }
        .text-right { text-align: right; }
        .text-bold { font-weight: bold; }
        .footer { margin-top: 40px; display: flex; justify-content: space-between; }
        .sign-box { text-align: center; width: 250px; }

        @@media print {
            .no-print { display: none; }
        }
    </style>
</head>
<body onload="window.print(); setTimeout(function(){ window.close(); }, 1000);">

    <div class="header">
        <div class="hospital-name">PHÒNG KHÁM ĐA KHOA ABC</div>
        <div>Địa chỉ: 123 Nguyễn Văn Cừ, Quận 5, TP.HCM - SĐT: 0123.456.789</div>
        <div class="title">
            @(Model.IsCLS ? "PHIẾU CHỈ ĐỊNH CẬN LÂM SÀNG" : "ĐƠN THUỐC VÀ KẾT QUẢ KHÁM BỆNH")
        </div>
        <div><i style="font-size: 13px;">(Kèm sao kê các khoản chưa thanh toán)</i></div>
    </div>

    <div class="patient-info">
        <div class="info-row"><span class="text-bold">Họ và tên:</span> @Model.TenBN &nbsp;&nbsp;&nbsp; <span class="text-bold">Tuổi:</span> @Model.Tuoi &nbsp;&nbsp;&nbsp; <span class="text-bold">Giới tính:</span> @Model.GioiTinh</div>
        <div class="info-row"><span class="text-bold">Địa chỉ:</span> @Model.DiaChi</div>
        <div class="info-row"><span class="text-bold">Lý do khám:</span> @Model.LyDoKham</div>
        @if (!Model.IsCLS)
        {
            <div class="info-row"><span class="text-bold">Chẩn đoán:</span> @Model.ChanDoan</div>
        }
    </div>

    <table>
        <thead>
            <tr>
                <th width="5%">STT</th>
                <th width="45%">Nội dung (Thuốc / CLS / Phí khám)</th>
                <th width="15%">SL / DVT</th>
                <th width="15%">Thành tiền (VNĐ)</th>
                <th width="20%">Ghi chú (Cách dùng)</th>
            </tr>
        </thead>
        <tbody>
            @{ int stt = 1; }
            @foreach (var item in Model.DanhSachDichVu)
            {
                <tr>
                    <td style="text-align:center;">@(stt++)</td>
                    <td>
                        @if (item.TenGiaoDich.Contains("Chưa thanh toán"))
                        {
                            <strong style="color:red;">@item.TenGiaoDich</strong>
                        }
                        else
                        {
                            @item.TenGiaoDich
                        }
                    </td>
                    <td style="text-align:center;">@item.SoLuongDVT</td>
                    <td class="text-right">@item.ThanhTien.ToString("N0")</td>
                    <td>@item.GhiChu</td>
                </tr>
            }
            <tr>
                <td colspan="3" class="text-right text-bold">TỔNG CẦN THANH TOÁN:</td>
                <td class="text-right text-bold" style="color:red;">@Model.TongTien.ToString("N0")</td>
                <td></td>
            </tr>
        </tbody>
    </table>

    <div class="footer">
        <div class="sign-box">
            <p><strong>Bệnh nhân/Người nhà</strong></p>
            <p><i>(Ký và ghi rõ họ tên)</i></p>
        </div>
        <div class="sign-box">
            <p>Ngày @DateTime.Now.Day tháng @DateTime.Now.Month năm @DateTime.Now.Year</p>
            <p><strong>Bác sĩ chỉ định</strong></p>
            <br /><br /><br />
            <p>@Model.TenBS</p>
        </div>
    </div>

    <div class="no-print" style="text-align:center; margin-top: 30px;">
        <button onclick="window.print()" style="padding: 10px 20px; cursor:pointer; font-size:16px;">In Lại Phiếu Này</button>
    </div>

</body>
</html>