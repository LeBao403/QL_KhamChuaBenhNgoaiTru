@{
    ViewBag.Title = "Quầy Thu Ngân & Viện Phí";
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";
    var dtThuTien = ViewBag.DanhSachThuTien as System.Data.DataTable;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #f4f7f6;
    }

    .split-panel {
        height: calc(100vh - 120px);
        overflow-y: auto;
    }

        .split-panel::-webkit-scrollbar {
            width: 6px;
        }

        .split-panel::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .split-panel::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 10px;
        }

            .split-panel::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8;
            }

    .patient-row {
        cursor: pointer;
        transition: all 0.2s ease;
        border-left: 4px solid transparent;
    }

        .patient-row:hover {
            background-color: #f8fafc;
            border-left-color: #cbd5e1;
        }

        .patient-row.active {
            background-color: #eff6ff;
            border-left-color: #3b82f6;
        }

    .bill-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: none;
    }

    .bill-header {
        border-bottom: 2px dashed #e2e8f0;
    }

    .total-amount-box {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border-radius: 12px;
    }

    .payment-method .btn-outline-primary {
        border-color: #cbd5e1;
        color: #475569;
        font-weight: 600;
    }

    .payment-method .btn-check:checked + .btn-outline-primary {
        background-color: #eff6ff;
        border-color: #3b82f6;
        color: #1d4ed8;
    }

    /* CSS cho thanh phân nhóm (Tiền Khám, Tiền Thuốc...) */
    .group-header {
        background-color: #f8fafc;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .group-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        margin-right: 8px;
    }

    .icon-kham {
        background-color: #e0e7ff;
        color: #3b82f6;
    }

    .icon-cls {
        background-color: #fef08a;
        color: #ca8a04;
    }

    .icon-thuoc {
        background-color: #dcfce7;
        color: #16a34a;
    }
</style>

<div class="container-fluid px-4 mt-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold text-dark mb-0"><i class="bi bi-cash-coin text-success me-2"></i>Quản Lý Viện Phí & Thu Ngân</h3>
        <button class="btn btn-outline-secondary rounded-pill px-4 shadow-sm" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
        </button>
    </div>

    <div class="row g-4">
        <div class="col-xl-5 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 split-panel bg-white">
                <div class="card-header bg-white py-3 border-0 sticky-top z-1">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-upc-scan fs-5"></i></span>
                        <input type="text" id="searchPatient" class="form-control bg-light border-start-0 ps-0" placeholder="Quét mã vạch hoặc tìm Tên, Mã BN...">
                    </div>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" id="patientList">
                        @if (dtThuTien != null && dtThuTien.Rows.Count > 0)
                        {
                            foreach (System.Data.DataRow row in dtThuTien.Rows)
                            {
                                bool hasBHYT = row["BHYT"] != DBNull.Value && Convert.ToBoolean(row["BHYT"]);
                                <li class="list-group-item patient-row p-3 border-bottom"
                                    data-mahd="@row["MaHD"]"
                                    data-mapkb="@row["MaPhieuKhamBenh"]"
                                    data-mabn="@row["MaBN"]"
                                    data-hoten="@row["HoTen"]"
                                    data-bhyt="@(hasBHYT ? "CÓ" : "KHÔNG")"
                                    onclick="loadBillDetails(this)">

                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 fw-bold text-primary">@row["HoTen"]</h6>
                                        <span class="badge bg-danger rounded-pill">Nợ: @Convert.ToDecimal(row["TongTienBenhNhanTra"]).ToString("N0") ₫</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span><i class="bi bi-person-vcard me-1"></i>Mã BN: @row["MaBN"]</span>
                                        <span>
                                            @if (hasBHYT)
                                            {<span class="text-success fw-bold"><i class="bi bi-shield-fill-check me-1"></i>BHYT</span> }
                                            else
                                            { <span class="text-secondary"><i class="bi bi-cash me-1"></i>Dịch vụ</span>}
                                        </span>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-5 text-muted border-0">
                                <i class="bi bi-check2-circle display-4 text-success opacity-50 d-block mb-3"></i>
                                Tuyệt vời! Không có bệnh nhân nào đang nợ viện phí.
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-xl-7 col-lg-7">
            <div class="bill-card split-panel h-100 d-flex flex-column position-relative">

                <div id="emptyState" class="m-auto text-center text-muted opacity-50 py-5">
                    <i class="bi bi-receipt-cutoff display-1 mb-3 d-block"></i>
                    <h5>Chọn một bệnh nhân bên trái<br />để xem hóa đơn chi tiết</h5>
                </div>

                <div id="billContent" class="d-none d-flex flex-column h-100">
                    <div class="bill-header p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4 class="fw-bold text-uppercase mb-1" id="lblHoTen">NGUYỄN VĂN A</h4>
                                <p class="text-muted mb-0"><i class="bi bi-person-vcard me-2"></i>Mã BN: <span id="lblMaBN" class="fw-bold text-dark">KH0001</span></p>
                                <p class="text-muted mb-0"><i class="bi bi-shield-plus me-2"></i>Đối tượng: <span id="lblBHYT" class="fw-bold text-primary">Dịch Vụ</span></p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-warning text-dark fs-6 rounded-pill border border-warning"><i class="bi bi-hourglass-split me-1"></i>Chờ thanh toán</span>
                                <p class="small text-muted mt-2 mb-0">Mã Phiếu Khám: <span id="lblMaPKB" class="fw-bold text-primary">#PKB123</span></p>
                            </div>
                        </div>
                    </div>

                    <div class="flex-grow-1 p-0 overflow-y-auto">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="border-bottom border-2 bg-white sticky-top z-1">
                                <tr class="text-muted small">
                                    <th class="text-center px-4" style="width:60px"><i class="bi bi-check2-square fs-5"></i></th>
                                    <th>Nội dung phát sinh</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end text-success">BHYT Trả</th>
                                    <th class="text-end text-danger pe-4">BN Phải Trả</th>
                                </tr>
                            </thead>
                            <tbody id="tbChiTiet">
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 bg-light rounded-bottom-4 mt-auto border-top">
                        <h6 class="fw-bold text-secondary mb-2 fs-7 text-uppercase">Phương thức thanh toán</h6>
                        <div class="payment-method d-flex gap-2 mb-4">
                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptCash" value="TIEN_MAT" autocomplete="off" checked>
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptCash">
                                <i class="bi bi-cash-stack d-block fs-4 mb-1"></i>Tiền mặt
                            </label>

                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptQR" value="CHUYEN_KHOAN" autocomplete="off">
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptQR">
                                <i class="bi bi-qr-code-scan d-block fs-4 mb-1"></i>Chuyển khoản
                            </label>

                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptPOS" value="QUET_THE" autocomplete="off">
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptPOS">
                                <i class="bi bi-credit-card-2-front d-block fs-4 mb-1"></i>Quẹt thẻ
                            </label>
                        </div>

                        <div class="total-amount-box p-4 d-flex justify-content-between align-items-center mb-3 shadow-sm">
                            <h5 class="mb-0 fw-bold opacity-75">TỔNG CẦN THU (Chưa thu):</h5>
                            <h1 class="mb-0 fw-bolder display-5" id="lblTongTien">0 ₫</h1>
                        </div>

                        <input type="hidden" id="hdnMaHD" value="0" />
                        <input type="hidden" id="hdnMaPKB" value="0" />

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow hover-lift" id="btnThanhToan" onclick="xuLyThanhToan()">
                                <i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // Lọc bệnh nhân
            $("#searchPatient").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#patientList li").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

        // TÍNH LẠI TỔNG TIỀN MỖI KHI TICK/BỎ TICK
        function tinhLaiTongTien() {
            let tongTien = 0;
            let soMonConLai = 0;

            $('.chk-item:checked').each(function () {
                tongTien += parseFloat($(this).data('tien'));
                soMonConLai++;
            });

            $('#lblTongTien').text(tongTien.toLocaleString('vi-VN') + ' ₫');

            let btn = $('#btnThanhToan');
            let tongSoMonNangNo = $('.chk-item').length;

            if (soMonConLai === 0 && tongSoMonNangNo > 0) {
                // Đổi câu chữ cho đúng logic: Chỉ hủy các món đang nợ, không phải hủy cả Bill
                btn.removeClass('btn-primary').addClass('btn-danger');
                btn.html('<i class="bi bi-x-octagon me-2 fs-5 align-middle"></i>XÁC NHẬN HỦY MÓN NỢ');
            } else {
                btn.removeClass('btn-danger').addClass('btn-primary');
                btn.html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
            }
        }

        // LOAD CHI TIẾT VÀ PHÂN NHÓM
        function loadBillDetails(element) {
            $('.patient-row').removeClass('active');
            $(element).addClass('active');

            $('#emptyState').addClass('d-none');
            $('#billContent').removeClass('d-none');

            let maHD = $(element).data('mahd');
            let maPKB = $(element).data('mapkb');

            $('#lblMaHD').text('#' + maHD);
            $('#lblMaBN').text($(element).data('mabn'));
            $('#lblHoTen').text($(element).data('hoten'));
            $('#lblMaPKB').text('#' + maPKB);
            $('#lblBHYT').text($(element).data('bhyt') === "CÓ" ? "Bảo Hiểm Y Tế (BHYT)" : "Khám Dịch Vụ");

            $('#hdnMaHD').val(maHD);
            $('#hdnMaPKB').val(maPKB);

            $('#tbChiTiet').html('<tr><td colspan="5" class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted">Đang tải dữ liệu...</p></td></tr>');

            $.post('@Url.Action("GetChiTiet", "ThuNgan")', { maPKB: maPKB }, function (res) {
                if (res.success) {
                    let html = '';
                    let tongBenhNhanTra = 0;

                    if (res.data.length === 0) {
                        html = '<tr><td colspan="5" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có dịch vụ nào cần thanh toán.</td></tr>';
                    } else {
                        // 1. CHIA DATA THÀNH 3 NHÓM DỰA VÀO ĐẶC ĐIỂM
                        let nhomKham = [];
                        let nhomCLS = [];
                        let nhomThuoc = [];

                        res.data.forEach(item => {
                            if (item.LoaiItem === "THUOC") {
                                nhomThuoc.push(item);
                            } else {
                                // Quy ước: Nếu tên có chữ "Khám" thì nhét vào nhóm Tiền Khám, còn lại là Cận lâm sàng
                                if (item.TenDV.toLowerCase().includes("khám")) {
                                    nhomKham.push(item);
                                } else {
                                    nhomCLS.push(item);
                                }
                            }
                        });

                        // 2. HÀM PHỤ TRỢ RENDER TỪNG DÒNG (Tránh lặp code)
                        const renderRow = (item) => {
                            let chkHtml = '';
                            let rowClass = '';
                            let priceClass = 'fw-bold text-danger';
                            let tienKhachTra = item.TienBenhNhan;

                            if (item.TrangThai === "Đã thanh toán") {
                                chkHtml = '<span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã đóng</span>';
                                rowClass = 'bg-light opacity-75';
                                priceClass = 'text-muted fw-bold';
                            }
                            else if (item.TrangThai === "Hủy") {
                                chkHtml = '<span class="badge bg-danger"><i class="bi bi-x-circle"></i> Khách bỏ</span>';
                                rowClass = 'bg-light opacity-50 text-decoration-line-through';
                                priceClass = 'text-muted';
                                tienKhachTra = 0;
                            }
                            else {
                                chkHtml = `<input type="checkbox" class="form-check-input chk-item fs-5 shadow-sm border-primary" style="cursor:pointer" data-macthd="${item.MaCTHD}" data-loai="${item.LoaiItem}" data-tien="${item.TienBenhNhan}" checked onchange="tinhLaiTongTien()">`;
                                tongBenhNhanTra += item.TienBenhNhan;
                            }

                            return `
                                <tr class="border-bottom ${rowClass}">
                                    <td class="text-center align-middle px-4">${chkHtml}</td>
                                    <td class="fw-bold text-dark py-3">${item.TenDV}</td>
                                    <td class="text-end py-3 text-muted">${item.DonGia.toLocaleString('vi-VN')} ₫</td>
                                    <td class="text-end text-success fw-medium py-3">${item.TienBHYT.toLocaleString('vi-VN')} ₫</td>
                                    <td class="text-end ${priceClass} py-3 pe-4 fs-6">${tienKhachTra.toLocaleString('vi-VN')} ₫</td>
                                </tr>
                            `;
                        };

                        // 3. RENDER NHÓM TIỀN KHÁM
                        if (nhomKham.length > 0) {
                            html += `
                                <tr class="group-header">
                                    <td colspan="5" class="fw-bold text-primary py-2 px-4 border-bottom">
                                        <span class="group-icon icon-kham"><i class="bi bi-stethoscope"></i></span> CÔNG KHÁM BỆNH
                                    </td>
                                </tr>
                            `;
                            nhomKham.forEach(item => html += renderRow(item));
                        }

                        // 4. RENDER NHÓM CLS
                        if (nhomCLS.length > 0) {
                            html += `
                                <tr class="group-header">
                                    <td colspan="5" class="fw-bold text-warning py-2 px-4 border-bottom" style="color: #b45309 !important;">
                                        <span class="group-icon icon-cls"><i class="bi bi-activity"></i></span> XÉT NGHIỆM & CẬN LÂM SÀNG
                                    </td>
                                </tr>
                            `;
                            nhomCLS.forEach(item => html += renderRow(item));
                        }

                        // 5. RENDER NHÓM THUỐC
                        if (nhomThuoc.length > 0) {
                            html += `
                                <tr class="group-header">
                                    <td colspan="5" class="fw-bold text-success py-2 px-4 border-bottom">
                                        <span class="group-icon icon-thuoc"><i class="bi bi-capsule"></i></span> ĐƠN THUỐC NGOẠI TRÚ
                                    </td>
                                </tr>
                            `;
                            nhomThuoc.forEach(item => html += renderRow(item));
                        }
                    }

                    $('#tbChiTiet').html(html);
                    $('#lblTongTien').text(tongBenhNhanTra.toLocaleString('vi-VN') + ' ₫');
                } else {
                    Swal.fire('Lỗi', 'Không thể lấy chi tiết hóa đơn: ' + res.message, 'error');
                }
            });
        }

        // XỬ LÝ THANH TOÁN
        function xuLyThanhToan() {
            let maHD = $('#hdnMaHD').val();
            let maPKB = $('#hdnMaPKB').val();
            let phuongThuc = $('input[name="phuongThucTT"]:checked').val();
            let phuongThucText = $('label[for="' + $('input[name="phuongThucTT"]:checked').attr('id') + '"]').text().trim();

            if (maHD == 0) { Swal.fire('Chú ý', 'Chưa chọn hồ sơ cần thanh toán!', 'warning'); return; }

            let arrHuyDV = [];
            let arrHuyThuoc = [];
            $('.chk-item:not(:checked)').each(function () {
                if ($(this).data('loai') === 'DV') arrHuyDV.push($(this).data('macthd'));
                if ($(this).data('loai') === 'THUOC') arrHuyThuoc.push($(this).data('macthd'));
            });

            let dsHuyDV = arrHuyDV.join(',');
            let dsHuyThuoc = arrHuyThuoc.join(',');

            let tongTien = parseInt($('#lblTongTien').text().replace(/\D/g, ''));
            let soMonConLai = $('.chk-item:checked').length;

            // TRƯỜNG HỢP 1: BỎ TICK HẾT TẤT CẢ CÁC MÓN ĐANG NỢ (Thu 0đ)
            if (soMonConLai === 0) {
                Swal.fire({
                    title: 'Xác nhận Hủy món nợ?',
                    html: `Bệnh nhân từ chối sử dụng các dịch vụ/thuốc đang nợ.<br/>Các món này sẽ được chuyển sang trạng thái <strong class="text-danger">Khách bỏ</strong>.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Đồng ý Hủy',
                    cancelButtonText: 'Quay lại',
                    confirmButtonColor: '#dc3545'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // TRUYỀN CHUỖI RỖNG "" để SQL không cập nhật Hình Thức Thanh Toán
                        thucHienGoiApiThanhToan(maHD, maPKB, "", dsHuyDV, dsHuyThuoc);
                    }
                });
                return;
            }

            // TRƯỜNG HỢP 2: THANH TOÁN CHUYỂN KHOẢN PAYOS
            if (phuongThuc === "CHUYEN_KHOAN" && tongTien > 0) {
                let btn = $('#btnThanhToan');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo mã QR...');

                $.post('@Url.Action("TaoMaQR", "ThuNgan")', { maHD: maHD, maPKB: maPKB }, function(res) {
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
                    if(res.success) {
                        let qrImageUrl = "https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=" + encodeURIComponent(res.qrString);
                        let checkInterval;
                        Swal.fire({
                            title: 'Quét mã VietQR',
                            html: `
                                <div class="p-3 text-center">
                                    <h4 class="text-danger fw-bolder mb-3">${$('#lblTongTien').text()}</h4>
                                    <img src="${qrImageUrl}" class="img-thumbnail border border-primary p-2 mb-3" style="width: 250px; height: 250px;"/>
                                    <div class="alert alert-primary bg-primary bg-opacity-10 border-0 mb-0">
                                        <p class="mb-0 fw-bold text-primary"><span class="spinner-grow spinner-grow-sm me-2"></span>Hệ thống đang chờ nhận tiền...</p>
                                    </div>
                                </div>
                            `,
                            showCancelButton: true, showConfirmButton: false, cancelButtonText: 'Hủy giao dịch', allowOutsideClick: false,
                            didOpen: () => {
                                checkInterval = setInterval(function() {
                                    $.post('@Url.Action("KiemTraThanhToan", "ThuNgan")', { orderCode: res.orderCode }, function(checkRes) {
                                        if(checkRes.isPaid) {
                                            clearInterval(checkInterval); Swal.close();
                                            thucHienGoiApiThanhToan(maHD, maPKB, "Chuyển khoản", dsHuyDV, dsHuyThuoc);
                                        }
                                    });
                                }, 3000);
                            },
                            willClose: () => { clearInterval(checkInterval); }
                        });
                    } else { Swal.fire('Lỗi', res.message, 'error'); }
                });
            }
            // TRƯỜNG HỢP 3: THANH TOÁN TIỀN MẶT / QUẸT THẺ
            else {
                Swal.fire({
                    title: 'Xác nhận chốt sổ?',
                    html: `Tổng tiền: <strong class="text-danger fs-4">${$('#lblTongTien').text()}</strong><br/>Thu bằng: <strong class="text-primary">${phuongThucText}</strong>`,
                    icon: 'question',
                    showCancelButton: true, confirmButtonText: 'Đồng ý thu tiền', cancelButtonText: 'Hủy', confirmButtonColor: '#0d6efd'
                }).then((result) => {
                    if (result.isConfirmed) { thucHienGoiApiThanhToan(maHD, maPKB, phuongThucText, dsHuyDV, dsHuyThuoc); }
                });
            }
        }

        // ĐẨY API
        function thucHienGoiApiThanhToan(maHD, maPKB, phuongThuc, dsHuyDV, dsHuyThuoc) {
            let btn = $('#btnThanhToan');
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');

            $.post('@Url.Action("ThanhToan", "ThuNgan")', {
                maHD: maHD, maPKB: maPKB, phuongThucTT: phuongThuc, dsHuyDV: dsHuyDV, dsHuyThuoc: dsHuyThuoc
            }, function (res) {
                if (res.success) {
                    Swal.fire({
                        title: 'ĐÃ THU TIỀN!', html: `Hóa đơn đã chốt xong qua <strong>${phuongThuc}</strong>.`, icon: 'success', timer: 2000, showConfirmButton: false
                    }).then(() => { location.reload(); });
                } else {
                    Swal.fire('Lỗi hệ thống', res.message, 'error');
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
                }
            }).fail(function() {
                Swal.fire('Lỗi kết nối', 'Không thể kết nối đến server.', 'error');
                btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
            });
        }
    </script>
}