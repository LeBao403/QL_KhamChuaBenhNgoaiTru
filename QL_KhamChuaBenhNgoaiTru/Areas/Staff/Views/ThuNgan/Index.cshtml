@{
    ViewBag.Title = "Quầy Thu Ngân & Viện Phí";
    Layout = "~/Areas/Staff/Views/Shared/_Layout_Staff.cshtml";

    var dtThuTien = ViewBag.DanhSachThuTien as System.Data.DataTable;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #f4f7f6;
    }

    .split-panel {
        height: calc(100vh - 120px);
        overflow-y: auto;
    }
        /* Scrollbar gọn gàng */
        .split-panel::-webkit-scrollbar {
            width: 6px;
        }

        .split-panel::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .split-panel::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 10px;
        }

            .split-panel::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8;
            }

    .patient-row {
        cursor: pointer;
        transition: all 0.2s ease;
        border-left: 4px solid transparent;
    }

        .patient-row:hover {
            background-color: #f8fafc;
            border-left-color: #cbd5e1;
        }

        .patient-row.active {
            background-color: #eff6ff;
            border-left-color: #3b82f6;
        }

    .bill-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: none;
    }

    .bill-header {
        border-bottom: 2px dashed #e2e8f0;
    }

    .total-amount-box {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        border-radius: 12px;
    }

    /* Style cho Radio Button Chọn Phương thức TT */
    .payment-method .btn-outline-primary {
        border-color: #cbd5e1;
        color: #475569;
        font-weight: 600;
    }

    .payment-method .btn-check:checked + .btn-outline-primary {
        background-color: #eff6ff;
        border-color: #3b82f6;
        color: #1d4ed8;
    }
</style>

<div class="container-fluid px-4 mt-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold text-dark mb-0"><i class="bi bi-cash-coin text-success me-2"></i>Quản Lý Viện Phí & Thu Ngân</h3>
        <button class="btn btn-outline-secondary rounded-pill px-4 shadow-sm" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
        </button>
    </div>

    <div class="row g-4">

        <div class="col-xl-5 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 split-panel bg-white">
                <div class="card-header bg-white py-3 border-0 sticky-top z-1">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-upc-scan fs-5"></i></span>
                        <input type="text" id="searchPatient" class="form-control bg-light border-start-0 ps-0" placeholder="Quét mã vạch hoặc tìm Tên, Mã BN...">
                    </div>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" id="patientList">
                        @if (dtThuTien != null && dtThuTien.Rows.Count > 0)
                        {
                            foreach (System.Data.DataRow row in dtThuTien.Rows)
                            {
                                bool hasBHYT = row["BHYT"] != DBNull.Value && Convert.ToBoolean(row["BHYT"]);
                                <li class="list-group-item patient-row p-3 border-bottom"
                                    data-mapkb="@row["MaPhieuKhamBenh"]"
                                    data-mabn="@row["MaBN"]"
                                    data-hoten="@row["HoTen"]"
                                    data-bhyt="@(hasBHYT ? "CÓ" : "KHÔNG")"
                                    onclick="loadBillDetails(this)">

                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 fw-bold text-primary">@row["HoTen"]</h6>
                                        <span class="badge bg-danger rounded-pill">Đang nợ phí</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span><i class="bi bi-person-vcard me-1"></i>Mã BN: @row["MaBN"]</span>
                                        <span>
                                            @if (hasBHYT)
                                            {<span class="text-success fw-bold"><i class="bi bi-shield-fill-check me-1"></i>BHYT</span> }
                                            else
                                            { <span class="text-secondary"><i class="bi bi-cash me-1"></i>Dịch vụ</span>}
                                        </span>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-5 text-muted border-0">
                                <i class="bi bi-check2-circle display-4 text-success opacity-50 d-block mb-3"></i>
                                Tuyệt vời! Không có bệnh nhân nào đang nợ viện phí.
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-xl-7 col-lg-7">
            <div class="bill-card split-panel h-100 d-flex flex-column position-relative">

                <div id="emptyState" class="m-auto text-center text-muted opacity-50 py-5">
                    <i class="bi bi-receipt-cutoff display-1 mb-3 d-block"></i>
                    <h5>Chọn một bệnh nhân bên trái<br />để xem hóa đơn chi tiết</h5>
                </div>

                <div id="billContent" class="d-none d-flex flex-column h-100">
                    <div class="bill-header p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4 class="fw-bold text-uppercase mb-1" id="lblHoTen">NGUYỄN VĂN A</h4>
                                <p class="text-muted mb-0"><i class="bi bi-person-vcard me-2"></i>Mã BN: <span id="lblMaBN" class="fw-bold text-dark">KH0001</span></p>
                                <p class="text-muted mb-0"><i class="bi bi-shield-plus me-2"></i>Đối tượng: <span id="lblBHYT" class="fw-bold text-primary">Dịch Vụ</span></p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-warning text-dark fs-6 rounded-pill border border-warning"><i class="bi bi-hourglass-split me-1"></i>Chưa thanh toán</span>
                                <p class="small text-muted mt-2 mb-0">Mã Hóa Đơn: <span id="lblMaHD" class="fw-bold">#HD123</span></p>
                            </div>
                        </div>
                    </div>

                    <div class="flex-grow-1 p-4 overflow-y-auto">
                        <h6 class="fw-bold text-secondary mb-3 text-uppercase fs-7">Chọn khoản phí cần thanh toán</h6>
                        <div class="list-group mb-3" id="paymentOptions">
                            <!-- Chờ render từ AJAX -->
                        </div>
                    </div>

                    <div class="p-4 bg-light rounded-bottom-4 mt-auto">

                        <h6 class="fw-bold text-secondary mb-2 fs-7 text-uppercase">Phương thức thanh toán</h6>
                        <div class="payment-method d-flex gap-2 mb-4">
                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptCash" value="TIEN_MAT" autocomplete="off" checked>
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptCash">
                                <i class="bi bi-cash-stack d-block fs-4 mb-1"></i>Tiền mặt
                            </label>

                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptQR" value="CHUYEN_KHOAN" autocomplete="off">
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptQR">
                                <i class="bi bi-qr-code-scan d-block fs-4 mb-1"></i>Chuyển khoản
                            </label>

                            <input type="radio" class="btn-check" name="phuongThucTT" id="ptPOS" value="QUET_THE" autocomplete="off">
                            <label class="btn btn-outline-primary flex-fill rounded-3 py-2" for="ptPOS">
                                <i class="bi bi-credit-card-2-front d-block fs-4 mb-1"></i>Quẹt thẻ
                            </label>
                        </div>

                        <div class="total-amount-box p-4 d-flex justify-content-between align-items-center mb-3 shadow-sm">
                            <h5 class="mb-0 fw-bold opacity-75">TỔNG CẦN THU:</h5>
                            <h1 class="mb-0 fw-bolder display-5" id="lblTongTien">0 ₫</h1>
                        </div>

                        <input type="hidden" id="hdnMaPKB" value="0" />
                        <input type="hidden" id="hdnTongTien" value="0" />

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow hover-lift" id="btnThanhToan" onclick="xuLyThanhToan()">
                                <i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $("#searchPatient").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#patientList li").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
            
            // Xử lý khi tick chọn checkbox tính tổng tiền
            $(document).on('change', '.payment-check', function() {
                let total = 0;
                $('.payment-check:checked').each(function() {
                    total += parseFloat($(this).data('price'));
                });
                $('#lblTongTien').text(total.toLocaleString('vi-VN') + ' ₫');
                $('#hdnTongTien').val(total);
                
                if (total == 0) {
                    $('#btnThanhToan').prop('disabled', true);
                } else {
                    $('#btnThanhToan').prop('disabled', false);
                }
            });
        });

        function loadBillDetails(element) {
            $('.patient-row').removeClass('active');
            $(element).addClass('active');

            $('#emptyState').addClass('d-none');
            $('#billContent').removeClass('d-none');

            let maPKB = $(element).data('mapkb');
            let maBN = $(element).data('mabn');
            let hoTen = $(element).data('hoten');
            let bhyt = $(element).data('bhyt');

            $('#lblMaHD').text('#PKB' + maPKB);
            $('#lblMaBN').text(maBN);
            $('#lblHoTen').text(hoTen);
            $('#lblBHYT').text(bhyt === "CÓ" ? "Bảo Hiểm Y Tế (BHYT)" : "Khám Dịch Vụ");

            $('#hdnMaPKB').val(maPKB);
            $('#hdnTongTien').val(0);
            $('#lblTongTien').text('0 ₫');
            $('#btnThanhToan').prop('disabled', true);
            $('#paymentOptions').html('<div class="text-center py-3"><div class="spinner-border text-primary spinner-border-sm"></div> Đang tải dữ liệu...</div>');

            $.post('@Url.Action("GetChiTiet", "ThuNgan")', { maPKB: maPKB }, function (res) {
                if (res.success) {
                    let d = res.data;
                    let html = '';
                    
                    if (!d.DaThuPhiKham && d.PhiKham > 0) {
                        html += `
                            <label class="list-group-item d-flex justify-content-between align-items-center shadow-sm mb-2 rounded border-primary">
                                <div>
                                    <input class="form-check-input me-1 payment-check fs-5" type="checkbox" id="chkKham" value="kh" data-price="${d.PhiKham}">
                                    <span class="fw-bold text-primary ms-2 fs-6">Phí Khám Bệnh</span>
                                </div>
                                <span class="fw-bold text-danger fs-5">${d.PhiKham.toLocaleString('vi-VN')} ₫</span>
                            </label>
                        `;
                    }
                    if (!d.DaThuPhiDichVuCLS && d.PhiDichVuCLS > 0) {
                        html += `
                            <label class="list-group-item d-flex justify-content-between align-items-center shadow-sm mb-2 rounded border-success">
                                <div>
                                    <input class="form-check-input me-1 payment-check fs-5" type="checkbox" id="chkCLS" value="cls" data-price="${d.PhiDichVuCLS}">
                                    <span class="fw-bold text-success ms-2 fs-6">Phí Cận Lâm Sàng</span>
                                </div>
                                <span class="fw-bold text-danger fs-5">${d.PhiDichVuCLS.toLocaleString('vi-VN')} ₫</span>
                            </label>
                        `;
                    }
                    if (!d.DaThuPhiThuoc && d.PhiThuoc > 0) {
                        html += `
                            <label class="list-group-item d-flex justify-content-between align-items-center shadow-sm mb-2 rounded border-info">
                                <div>
                                    <input class="form-check-input me-1 payment-check fs-5" type="checkbox" id="chkThuoc" value="thuoc" data-price="${d.PhiThuoc}">
                                    <span class="fw-bold text-info ms-2 fs-6">Phí Thuốc Men</span>
                                </div>
                                <span class="fw-bold text-danger fs-5">${d.PhiThuoc.toLocaleString('vi-VN')} ₫</span>
                            </label>
                        `;
                    }

                    if (html === '') {
                        html = '<div class="alert alert-success mt-2"><i class="bi bi-check-circle me-2"></i>Bệnh nhân này đã thanh toán toàn bộ chi phí phát sinh.</div>';
                    }

                    $('#paymentOptions').html(html);

                } else {
                    Swal.fire('Lỗi', 'Không thể lấy chi tiết công nợ: ' + res.message, 'error');
                }
            });
        }

        // BẤM XÁC NHẬN THU TIỀN
        function xuLyThanhToan() {
            let maPKB = $('#hdnMaPKB').val();
            let tongTien = $('#hdnTongTien').val();
            
            let thuPhiKham = $('#chkKham').is(':checked');
            let thuPhiCLS = $('#chkCLS').is(':checked');
            let thuPhiThuoc = $('#chkThuoc').is(':checked');

            let phuongThuc = $('input[name="phuongThucTT"]:checked').val();
            let phuongThucText = $('label[for="' + $('input[name="phuongThucTT"]:checked').attr('id') + '"]').text().trim();

            if (maPKB == 0 || tongTien == 0) {
                Swal.fire('Chú ý', 'Vui lòng chọn ít nhất một khoản phí để thanh toán!', 'warning');
                return;
            }

            // CHUYỂN KHOẢN (QR PAYOS ĐỘNG)
            if(phuongThuc === "CHUYEN_KHOAN") {
                let btn = $('#btnThanhToan');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo mã QR...');

                $.post('@Url.Action("TaoMaQR", "ThuNgan")', { maPKB: maPKB, tongTien: tongTien }, function(res) {
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');

                    if(res.success) {
                        let qrImageUrl = "https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=" + encodeURIComponent(res.qrString);
                        let checkInterval;

                        Swal.fire({
                            title: 'Quét mã VietQR',
                            html: `
                                <div class="p-3 text-center">
                                    <img src="${qrImageUrl}" alt="QR Code" class="img-thumbnail border border-primary p-2 mb-3" style="width: 250px; height: 250px;"/>
                                    <div class="alert alert-primary bg-primary bg-opacity-10 border-0 mb-0">
                                        <p class="mb-0 fw-bold text-primary"><span class="spinner-grow spinner-grow-sm me-2"></span>Hệ thống đang chờ nhận tiền...</p>
                                        <small class="text-muted">Cửa sổ này sẽ tự động đóng khi thanh toán thành công.</small>
                                    </div>
                                </div>
                            `,
                            showCancelButton: true,
                            showConfirmButton: false, 
                            cancelButtonText: 'Hủy giao dịch',
                            allowOutsideClick: false,
                            didOpen: () => {
                                checkInterval = setInterval(function() {
                                    $.post('@Url.Action("KiemTraThanhToan", "ThuNgan")', { orderCode: res.orderCode }, function(checkRes) {
                                        if(checkRes.isPaid) {
                                            clearInterval(checkInterval);
                                            Swal.close();
                                            thucHienGoiApiThanhToan(maPKB, thuPhiKham, thuPhiCLS, thuPhiThuoc, "Chuyển khoản VietQR");
                                        }
                                    });
                                }, 3000);
                            },
                            willClose: () => {
                                clearInterval(checkInterval);
                            }
                        });
                    } else {
                        Swal.fire('Lỗi tạo mã QR', res.message, 'error');
                    }
                }).fail(function() {
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
                    Swal.fire('Lỗi kết nối', 'Không thể kết nối đến server PayOS.', 'error');
                });
            }
            // NẾU LÀ TIỀN MẶT HOẶC QUẸT THẺ
            else {
                Swal.fire({
                    title: 'Xác nhận thu tiền cục bộ?',
                    html: `Tổng thu <b class="text-danger">${parseFloat(tongTien).toLocaleString('vi-VN')} ₫</b> qua <strong class="text-primary">${phuongThucText}</strong>. Hành động này không thể hoàn tác.`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Đồng ý thu tiền',
                    cancelButtonText: 'Hủy',
                    confirmButtonColor: '#0d6efd'
                }).then((result) => {
                    if (result.isConfirmed) { thucHienGoiApiThanhToan(maPKB, thuPhiKham, thuPhiCLS, thuPhiThuoc, phuongThucText); }
                });
            }
        }

        function thucHienGoiApiThanhToan(maPKB, thuPhiKham, thuPhiCLS, thuPhiThuoc, phuongThucText) {
            let btn = $('#btnThanhToan');
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');

            $.post('@Url.Action("ThanhToan", "ThuNgan")', { 
                maPKB: maPKB, 
                thuPhiKham: thuPhiKham, 
                thuPhiCLS: thuPhiCLS, 
                thuPhiThuoc: thuPhiThuoc 
            }, function (res) {
                if (res.success) {
                    Swal.fire({
                        title: 'ĐÃ THU TIỀN!',
                        html: `Ghi nhận thành công qua <strong>${phuongThucText}</strong>.<br/>Bệnh nhân có thể tiếp tục quy trình khám/chữa bệnh.`,
                        icon: 'success',
                        timer: 3000,
                        timerProgressBar: true,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('Lỗi hệ thống', res.message, 'error');
                    btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
                }
            }).fail(function() {
                Swal.fire('Lỗi mạng', 'Không kết nối được server.', 'error');
                btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2 fs-5 align-middle"></i>XÁC NHẬN THU TIỀN');
            });
        }
    </script>
}