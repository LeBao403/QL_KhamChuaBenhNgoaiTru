@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // Tooltip Init
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });

            // Lịch
            flatpickr("#dateRangePicker", {
                mode: "range", dateFormat: "Y-m-d", altInput: true, altFormat: "d/m/Y", locale: "vn",
                defaultDate: [$("#tuNgay").val(), $("#denNgay").val()],
                onChange: function(dates, dateStr, instance) {
                    if (dates.length === 2) {
                        $("#tuNgay").val(instance.formatDate(dates[0], "Y-m-d"));
                        $("#denNgay").val(instance.formatDate(dates[1], "Y-m-d"));
                        triggerSearch();
                    }
                }
            });

            let timer;
            $('#liveSearchInput').on('input', function () { clearTimeout(timer); timer = setTimeout(() => triggerSearch(1), 500); });
            $('#statusFilter').on('change', () => triggerSearch(1));

            $(document).on('click', '.sortable-col', function () {
                let col = $(this).data('col');
                $('#sortDir').val($('#sortCol').val() === col ? ($('#sortDir').val() === 'asc' ? 'desc' : 'asc') : 'desc');
                $('#sortCol').val(col);
                triggerSearch(1);
            });

            $(document).on('click', '.ajax-page', function (e) {
                e.preventDefault();
                let url = $(this).attr('href');
                let pageMatch = url.match(/page=(\d+)/);
                if (pageMatch) triggerSearch(pageMatch[1]);
            });

            function triggerSearch(page = '@ViewBag.CurrentPage') {
                $('#loadingOverlay').css('display', 'flex');
                let url = `@Url.Action("LichSu")?tuNgay=${$('#tuNgay').val()}&denNgay=${$('#denNgay').val()}&tuKhoa=${encodeURIComponent($('#liveSearchInput').val())}&trangThai=${encodeURIComponent($('#statusFilter').val())}&sortCol=${$('#sortCol').val()}&sortDir=${$('#sortDir').val()}&page=${page}`;
                $.get(url, function (data) {
                    $('#tableUpdateArea').html($(data).find('#tableUpdateArea').html());
                    window.history.pushState({path: url}, '', url);

                    $('[data-bs-toggle="tooltip"]').tooltip();
                });
            }
        });

        // ========================================================
        // HÀM CHUYỂN SỐ TIỀN VNĐ SANG CHỮ
        // ========================================================
        const chuSo = [" không ", " một ", " hai ", " ba ", " bốn ", " năm ", " sáu ", " bảy ", " tám ", " chín "];
        const tien = ["", " nghìn", " triệu", " tỷ", " nghìn tỷ", " triệu tỷ"];

        function docTienBangChu(soTien) {
            if (soTien == 0) return "Không đồng";
            let str = "";
            let isNegative = soTien < 0;
            soTien = Math.abs(soTien);
            let s = soTien.toString();
            let group = [];
            while (s.length > 0) {
                group.push(s.slice(Math.max(0, s.length - 3)));
                s = s.slice(0, Math.max(0, s.length - 3));
            }
            for (let i = 0; i < group.length; i++) {
                let num = parseInt(group[i]);
                if (num > 0) {
                    let text = doc3So(group[i]);
                    str = text + tien[i] + str;
                }
            }
            str = str.trim();
            str = str.charAt(0).toUpperCase() + str.slice(1);
            if (isNegative) str = "Âm " + str;
            return str.replace(/  +/g, ' ') + " đồng.";
        }

        function doc3So(so) {
            let str = "";
            let tram = Math.floor(so / 100);
            let chuc = Math.floor((so % 100) / 10);
            let donVi = so % 10;
            if (tram > 0) {
                str += chuSo[tram] + "trăm";
                if (chuc == 0 && donVi > 0) str += " lẻ";
            }
            if (chuc > 1) {
                str += chuSo[chuc] + "mươi";
                if (donVi == 1) str += " mốt";
            } else if (chuc == 1) {
                str += " mười";
                if (donVi == 1) str += " một";
            }
            if (donVi == 5 && chuc >= 1) {
                str += " lăm";
            } else if (donVi > 1 || (donVi == 1 && chuc == 0)) {
                str += chuSo[donVi];
            }
            return str;
        }

        // =====================================================================
        // XEM CHI TIẾT ĐÃ ĐƯỢC PHÂN NHÓM VÀ THIẾT KẾ UI BIÊN LAI CÓ NÚT IN LẠI
        // =====================================================================
        function xemChiTiet(maHD, tenBN, maBN, maPKB, trangThaiHD) {
            Swal.fire({
                title: 'Đang tải dữ liệu...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.post('@Url.Action("GetChiTiet", "ThuNgan")', { maHD: maHD }, function (res) {
                if (res.success) {
                    let total = 0;
                    let nhomKham = []; let nhomCLS = []; let nhomThuoc = [];

                    // Chia nhóm dữ liệu và chỉ tính tiền cho những khoản KHÔNG BỊ HỦY
                    res.data.forEach(item => {
                        let tenDV = item.TenDV.toLowerCase();
                        if (item.LoaiItem === "THUOC") nhomThuoc.push(item);
                        else if (tenDV.includes("khám") || tenDV.includes("tiện ích") || tenDV.includes("đặt lịch")) nhomKham.push(item);
                        else nhomCLS.push(item);

                        if (item.TrangThai !== "Hủy") total += item.TienBenhNhan;
                    });

                    // CẤU TRÚC LẠI NÚT IN THEO TRẠNG THÁI
                    let btnInHTML = trangThaiHD === 'Đã thanh toán'
                        ? `<button class="btn btn-light text-primary btn-sm fw-bold shadow-sm" onclick="inHoaDonLichSu('${maHD}', '${tenBN}', '${maBN}', '${maPKB}', ${total}, false)"><i class="bi bi-printer me-1"></i> In Lại Hóa Đơn</button>`
                        : `<button class="btn btn-outline-light text-white btn-sm fw-bold shadow-sm" onclick="inHoaDonLichSu('${maHD}', '${tenBN}', '${maBN}', '${maPKB}', ${total}, true)"><i class="bi bi-x-circle me-1"></i> In Phiếu Hủy</button>`;

                    let infoHtml = `
                        <div class="receipt-header text-start">
                            <div class="d-flex justify-content-between align-items-center px-4 py-4" style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);">
                                <div>
                                    <div class="text-white-50 small fw-bold mb-1 tracking-wider text-uppercase">Thông tin Bệnh nhân</div>
                                    <h4 class="fw-bolder mb-1 text-white text-uppercase" style="letter-spacing: 0.5px">${tenBN}</h4>
                                    <div class="text-white opacity-75"><i class="bi bi-person-vcard me-2"></i>Mã BN: <strong class="text-white">${maBN}</strong></div>
                                </div>
                                <div class="text-end">
                                    <div class="text-white-50 small fw-bold mb-1 tracking-wider text-uppercase">Mã Hóa Đơn</div>
                                    <div class="d-flex justify-content-end align-items-center gap-2 mb-1">
                                        <h3 class="fw-black mb-0 text-white">#${maHD}</h3>
                                        ${btnInHTML}
                                    </div>
                                    <div class="text-white opacity-75 small mt-2">PKB: <strong class="text-white">${maPKB ? '#' + maPKB : 'N/A'}</strong></div>
                                </div>
                            </div>
                        </div>
                    `;

                    let tableHtml = `
                        <div class="px-4 py-4 text-start" id="viewChiTietData">
                            <div class="table-responsive rounded-4 border shadow-sm">
                                <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem">
                                    <thead class="bg-light text-muted small text-uppercase" style="border-bottom: 2px solid #e2e8f0;">
                                        <tr>
                                            <th class="ps-4 py-3 fw-bold">Nội dung phát sinh</th>
                                            <th class="text-end py-3 fw-bold" style="width:160px;">Tiền khách trả</th>
                                            <th class="text-center pe-4 py-3 fw-bold" style="width:140px;">Trạng thái</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                    const renderRow = (item) => {
                        let isHuy = item.TrangThai === "Hủy";
                        let rowCls = isHuy ? "bg-light opacity-75" : "";
                        let textDeco = isHuy ? "text-decoration-line-through text-muted" : "text-dark";

                        let badge = isHuy
                            ? '<span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-x-circle me-1"></i>Đã hủy</span>'
                            : '<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-check-circle me-1"></i>Hoàn tất</span>';

                        let textDV = `<div class="fw-bold fs-6 ${textDeco}">${item.TenDV}</div>`;

                        if (item.LoaiItem === 'THUOC') {
                            let slMua = item.SoLuong || 0;
                            let slGoc = item.SoLuongGoc || slMua;

                            if (!isHuy) {
                                if (slMua < slGoc) {
                                    textDV += `<div class="mt-2"><span class="badge bg-warning bg-opacity-10 text-dark border border-warning rounded-pill px-2 py-1"><i class="bi bi-exclamation-circle text-warning me-1"></i>Mua giảm: ${slMua} / ${slGoc}</span></div>`;
                                } else {
                                    textDV += `<div class="mt-2"><span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-2 py-1"><i class="bi bi-box-seam me-1"></i>SL: ${slMua}</span></div>`;
                                }
                            } else {
                                textDV += `<div class="mt-2"><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-2 py-1"><i class="bi bi-dash-circle me-1"></i>Từ chối mua</span></div>`;
                            }
                        }

                        // Nhét luôn các DATA ẩn vào dòng để tý nữa đọc cho dễ
                        return `<tr class="${rowCls} print-item-row" data-ten="${item.TenDV}" data-sl="${item.SoLuong || 1}" data-gia="${item.DonGia}" data-bhyt="${item.TienBHYT}" data-tien="${item.TienBenhNhan}" data-huy="${isHuy ? '1' : '0'}">
                                    <td class="ps-4 py-3 border-bottom">${textDV}</td>
                                    <td class="text-end fw-bolder ${isHuy ? 'text-muted' : 'text-primary'} fs-5 py-3 border-bottom ${textDeco}">${isHuy ? '0' : item.TienBenhNhan.toLocaleString('vi-VN')} ₫</td>
                                    <td class="text-center pe-4 py-3 border-bottom">${badge}</td>
                                </tr>`;
                    };

                    if (nhomKham.length > 0) {
                        tableHtml += `<tr><td colspan="3" class="bg-light fw-bold text-primary px-4 py-2 border-bottom" style="font-size: 0.85rem;"><i class="bi bi-stethoscope me-2"></i>CÔNG KHÁM BỆNH</td></tr>`;
                        nhomKham.forEach(item => tableHtml += renderRow(item));
                    }
                    if (nhomCLS.length > 0) {
                        tableHtml += `<tr><td colspan="3" class="bg-light fw-bold px-4 py-2 border-bottom" style="color: #b45309 !important; font-size: 0.85rem;"><i class="bi bi-activity me-2"></i>XÉT NGHIỆM & CẬN LÂM SÀNG</td></tr>`;
                        nhomCLS.forEach(item => tableHtml += renderRow(item));
                    }
                    if (nhomThuoc.length > 0) {
                        tableHtml += `<tr><td colspan="3" class="bg-light fw-bold text-success px-4 py-2 border-bottom" style="font-size: 0.85rem;"><i class="bi bi-capsule me-2"></i>ĐƠN THUỐC NGOẠI TRÚ</td></tr>`;
                        nhomThuoc.forEach(item => tableHtml += renderRow(item));
                    }

                    tableHtml += `</tbody></table></div>
                            <div class="mt-4 p-4 rounded-4 shadow-sm d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 1px solid #bfdbfe;">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 54px; height: 54px;">
                                        <i class="bi bi-wallet2 text-primary fs-3"></i>
                                    </div>
                                    <span class="text-primary fw-bold fs-6 text-uppercase" style="letter-spacing: 0.5px;">Tổng thu thực tế</span>
                                </div>
                                <strong class="text-primary display-5 fw-black mb-0" style="text-shadow: 1px 1px 0px rgba(255,255,255,0.5);">${total.toLocaleString('vi-VN')} ₫</strong>
                            </div>
                        </div>`;

                    Swal.fire({
                        title: false,
                        html: infoHtml + tableHtml,
                        width: '850px',
                        showCloseButton: true,
                        showConfirmButton: false,
                        customClass: { popup: 'custom-swal-popup' }
                    });
                } else {
                    Swal.fire('Lỗi', 'Không lấy được chi tiết: ' + res.message, 'error');
                }
            });
        }

        // ========================================================
        // HÀM XUẤT BIÊN LAI PDF TỪ MÀN HÌNH LỊCH SỬ
        // ========================================================
        window.inHoaDonLichSu = function(maHD, tenBN, maBN, maPKB, tongTienHD, laHuy) {

            // 1. Gán thông tin Header
            $('#prt-hoten').text(tenBN);
            $('#prt-mabn').text(maBN);
            $('#prt-mahd').text(maHD.replace('#', ''));
            $('#prt-mapkb').text(maPKB ? maPKB.replace('#', '') : '');

            if(laHuy) {
                $('#prt-title').text('HÓA ĐƠN HỦY DỊCH VỤ');
                $('#prt-title').css('color', '#dc3545');
            } else {
                $('#prt-title').text('HÓA ĐƠN THU TIỀN VIỆN PHÍ');
                $('#prt-title').css('color', '#000');
            }

            let tbody = '';
            let stt = 1;

            // 2. Bóc tách dữ liệu từ Popup Chi Tiết hiện tại (Tránh gọi thêm API thừa)
            $('.print-item-row').each(function() {
                let isHuyRow = $(this).data('huy') === '1';

                // Nếu là in hóa đơn thanh toán bình thường -> Bỏ các dòng Hủy đi
                if(!laHuy && isHuyRow) return;

                // Nếu là in hóa đơn HỦY -> Bỏ các dòng đã thu đi
                if(laHuy && !isHuyRow) return;

                let ten = $(this).data('ten');
                let sl = $(this).data('sl');
                let donGia = parseFloat($(this).data('gia') || 0).toLocaleString('vi-VN') + ' ₫';
                let bhyt = parseFloat($(this).data('bhyt') || 0).toLocaleString('vi-VN') + ' ₫';
                let thanhTienText = parseFloat($(this).data('tien') || 0).toLocaleString('vi-VN') + ' ₫';

                tbody += `<tr>
                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">${stt++}</td>
                    <td style="border: 1px solid #000; padding: 6px; font-weight: bold;">${ten}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">${sl}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: right;">${donGia}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: right; color: #000;">${bhyt}</td>
                    <td style="border: 1px solid #000; padding: 6px; text-align: right; font-weight: bold; color: #000;">${thanhTienText}</td>
                </tr>`;
            });

            if(stt === 1) {
                Swal.fire('Chú ý', 'Không có khoản dịch vụ nào hợp lệ để in!', 'warning');
                return;
            }

            $('#prt-tbody').html(tbody);

            // Xử lý Tổng Tiền
            if(laHuy) tongTienHD = 0; // Hóa đơn hủy thì tổng tiền hiển thị 0đ
            $('#prt-tongtien').text(tongTienHD.toLocaleString('vi-VN') + ' ₫');
            $('#prt-bangchu').text(docTienBangChu(tongTienHD));

            let now = new Date();
            $('#prt-ngaylap').text(`TP.HCM, ngày ${now.getDate().toString().padStart(2, '0')} tháng ${(now.getMonth()+1).toString().padStart(2, '0')} năm ${now.getFullYear()}`);

            // 3. Render PDF
            var elementHTML = document.getElementById('print-invoice-section').innerHTML;

            var maBNFormat = maBN.trim();
            var typeStr = laHuy ? 'Huy_' : '';
            var tenFile = 'HoaDon_' + typeStr + maHD + '_' + maBNFormat + '.pdf';

            var opt = {
                margin: [0.1, 0, 0.1, 0],
                filename: tenFile,
                image: { type: 'jpeg', quality: 1 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(elementHTML).save();
        }
    </script>
}