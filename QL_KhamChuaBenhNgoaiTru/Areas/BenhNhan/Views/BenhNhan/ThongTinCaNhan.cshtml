@model QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.BenhNhanProfile
@{
    ViewBag.Title = "Thông tin cá nhân";
}
<div class="row">
    <div class="col-lg-8">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-person-vcard-fill text-primary me-2"></i>Thông tin cá nhân</h5>
            </div>
            @using (Html.BeginForm("ThongTinCaNhan", "BenhNhan", FormMethod.Post, new { @class = "row g-3" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaBN)
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Họ tên <span class="text-danger">*</span></label>
                    @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control", placeholder = "Nhập họ tên" })
                    @Html.ValidationMessageFor(m => m.HoTen, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ngày sinh <span class="text-danger">*</span></label>
                    @Html.TextBoxFor(m => m.NgaySinh, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.NgaySinh, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Giới tính <span class="text-danger">*</span></label>
                    @Html.DropDownListFor(m => m.GioiTinh,
                        new SelectList(new[] {
                            new { Value = "Nam", Text = "Nam" },
                            new { Value = "Nữ", Text = "Nữ" }
                        }, "Value", "Text", Model?.GioiTinh),
                        "-- Chọn giới tính --",
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.GioiTinh, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Số điện thoại</label>
                    @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", placeholder = "Nhập số điện thoại" })
                    @Html.ValidationMessageFor(m => m.SDT, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "Nhập email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">CCCD / CMND</label>
                    @Html.TextBoxFor(m => m.CCCD, new { @class = "form-control", placeholder = "Nhập số CCCD" })
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", placeholder = "Nhập địa chỉ" })
                </div>
                <div class="col-12">
                    <hr />
                    <h6 class="fw-bold mb-3"><i class="bi bi-shield-check text-success me-1"></i>Thông tin BHYT</h6>
                </div>
                <div class="col-md-12">
                    <div class="form-check form-switch mb-3">
                        @Html.CheckBoxFor(m => m.BHYT, new { @class = "form-check-input", role = "switch", id = "BHYToggle" })
                        <label class="form-check-label fw-semibold" for="BHYToggle">Tôi có thẻ BHYT</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Số thẻ BHYT</label>
                    @Html.TextBoxFor(m => m.SoTheBHYT, new { @class = "form-control", placeholder = "VD: DN123456789" })
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Hạn sử dụng BHYT</label>
                    @Html.TextBoxFor(m => m.HanSuDungBHYT, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tuyến khám</label>
                    @Html.DropDownListFor(m => m.TuyenKham,
                        new SelectList(new[] {
                            new { Value = "Đúng tuyến", Text = "Đúng tuyến" },
                            new { Value = "Trái tuyến", Text = "Trái tuyến" }
                        }, "Value", "Text", Model?.TuyenKham),
                        "-- Chọn tuyến --",
                        new { @class = "form-select" })
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i>Lưu thông tin
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-4">
        <div class="stat-card text-center">
            <div class="user-avatar mx-auto mb-3" style="width:80px;height:80px;font-size:2rem;background:linear-gradient(135deg,#0d6efd,#198754);">
                @(Model?.HoTen?.Length > 0 ? Model.HoTen[0].ToString().ToUpper() : "B")
            </div>
            <h5 class="fw-bold">@(Model?.HoTen)</h5>
            <div class="text-muted small mb-3">@(Model?.MaBN)</div>
            <div class="list-group list-group-flush text-start small">
                <div class="list-group-item d-flex justify-content-between px-0 border-0">
                    <span class="text-muted"><i class="bi bi-telephone me-1"></i>Điện thoại</span>
                    <span class="fw-semibold">@(Model?.SDT)</span>
                </div>
                <div class="list-group-item d-flex justify-content-between px-0 border-0">
                    <span class="text-muted"><i class="bi bi-envelope me-1"></i>Email</span>
                    <span class="fw-semibold">@(Model?.Email)</span>
                </div>
                <div class="list-group-item d-flex justify-content-between px-0 border-0">
                    <span class="text-muted"><i class="bi bi-calendar3 me-1"></i>Ngày sinh</span>
                    <span class="fw-semibold">@(Model?.NgaySinh?.ToString("dd/MM/yyyy"))</span>
                </div>
                <div class="list-group-item d-flex justify-content-between px-0 border-0">
                    <span class="text-muted"><i class="bi bi-gender-ambiguous me-1"></i>Giới tính</span>
                    <span class="fw-semibold">@(Model?.GioiTinh)</span>
                </div>
                <div class="list-group-item d-flex justify-content-between px-0 border-0">
                    <span class="text-muted"><i class="bi bi-shield me-1"></i>BHYT</span>
                    <span class="badge @(Model?.BHYT == true ? "bg-success" : "bg-secondary")">
                        @(Model?.BHYT == true ? "Có" : "Không")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
