@model List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.HoaDonItem>
@{
    ViewBag.Title = "Hóa đơn";
    var daThanhToan = Model?.Count(x => x.TrangThaiThanhToan == "Đã thanh toán") ?? 0;
    var chuaThanhToan = Model?.Count(x => x.TrangThaiThanhToan != "Đã thanh toán") ?? 0;
    var tongTien = Model?.Sum(x => x.TongTien) ?? 0;
}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-number">@(Model != null ? Model.Count : 0)</div>
            <div class="stat-label">Tổng hóa đơn</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-number" style="color:#198754;">@daThanhToan</div>
            <div class="stat-label">Đã thanh toán</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-number" style="color:#dc3545;">@chuaThanhToan</div>
            <div class="stat-label">Chưa thanh toán</div>
        </div>
    </div>
</div>

<h5 class="fw-bold mb-3"><i class="bi bi-receipt-cutoff text-primary me-2"></i>Danh sách hóa đơn</h5>

@if (Model == null || !Model.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-receipt text-muted" style="font-size:3rem;"></i>
        <h6 class="text-muted mt-3">Chưa có hóa đơn nào</h6>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom mb-0">
            <thead>
                <tr>
                    <th>Mã HĐ</th>
                    <th>Ngày thanh toán</th>
                    <th>Ngày khám</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Hình thức</th>
                    <th>Trạng thái</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@item.MaHD</td>
                        <td>
                            @(item.NgayThanhToan.HasValue
                                ? item.NgayThanhToan.Value.ToString("dd/MM/yyyy HH:mm")
                                : "—")
                        </td>
                        <td>@(item.NgayKham.HasValue ? item.NgayKham.Value.ToString("dd/MM/yyyy") : "—")</td>
                        <td class="text-end fw-bold text-danger">@item.TongTien.ToString("N0") đ</td>
                        <td>
                            @(string.IsNullOrEmpty(item.HinhThucThanhToan)
                                ? "—"
                                : item.HinhThucThanhToan)
                        </td>
                        <td>
                            @if (item.TrangThaiThanhToan == "Đã thanh toán")
                            {
                                <span class="badge badge-done"><i class="bi bi-check-circle me-1"></i>Đã thanh toán</span>
                            }
                            else if (item.TrangThaiThanhToan == "Chưa thanh toán")
                            {
                                <span class="badge badge-cancelled"><i class="bi bi-clock me-1"></i>Chưa thanh toán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThaiThanhToan</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("ChiTietHoaDon", "BenhNhan", new { area = "BenhNhan", id = item.MaHD })"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>Xem
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-light fw-bold">
                    <td colspan="3" class="text-end">Tổng cộng:</td>
                    <td class="text-end text-danger">@tongTien.ToString("N0") đ</td>
                    <td colspan="3"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}
