@{
    ViewBag.Title = "Đặt lịch khám";
    var phongKham = ViewBag.PhongKham as List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.PhongInfo> ?? new List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.PhongInfo>();
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-calendar-plus-fill text-primary me-2"></i>Đặt lịch khám mới</h5>
                <a href="@Url.Action("LichKham", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại
                </a>
            </div>
            <div class="alert alert-info">
                <i class="bi bi-info-circle-fill me-1"></i>
                Vui lòng điền đầy đủ thông tin bên dưới để đặt lịch khám. Lịch hẹn sẽ được xác nhận trong vòng 24 giờ.
            </div>
            @using (Html.BeginForm("DatLichKham", "BenhNhan", FormMethod.Post, new { @class = "row g-3" }))
            {
                @Html.AntiForgeryToken()
                <div class="col-12">
                    <label class="form-label fw-semibold">Ngày khám <span class="text-danger">*</span></label>
                    <input type="date" name="ngayKham" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Phòng khám / Khoa <span class="text-danger">*</span></label>
                    <select name="maPhong" class="form-select" required>
                        <option value="">-- Chọn phòng khám --</option>
                        @foreach (var p in phongKham)
                        {
                            <option value="@p.MaPhong">@p.TenKhoa - @p.TenPhong</option>
                        }
                    </select>
                    @if (!phongKham.Any())
                    {
                        <div class="form-text text-danger">Chưa có phòng khám nào. Vui lòng liên hệ lễ tân.</div>
                    }
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Lý do khám <span class="text-danger">*</span></label>
                    <textarea name="lyDo" class="form-control" rows="4" placeholder="Mô tả triệu chứng, lý do đến khám..." required></textarea>
                </div>
                <div class="col-12">
                    <div class="alert alert-warning mb-0 small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Lịch hẹn chỉ được xác nhận khi nhân viên y tế kiểm tra và duyệt.
                        Bạn có thể xem / hủy lịch đã đặt trong mục <a href="@Url.Action("LichKham", "BenhNhan", new { area = "BenhNhan" })">Xem lịch</a>.
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary px-4" @(phongKham.Any() ? "" : "disabled")>
                        <i class="bi bi-calendar-check me-1"></i>Gửi yêu cầu đặt lịch
                    </button>
                </div>
            }
        </div>
    </div>
</div>
