@model List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.TrangThaiKhamItem>
@{
    ViewBag.Title = "Trạng thái khám";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-activity text-primary me-2"></i>Trạng thái các lần khám</h5>
    <a href="@Url.Action("LichSuKham", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-clock-history me-1"></i>Lịch sử khám
    </a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-clipboard-x text-muted" style="font-size:3rem;"></i>
        <h6 class="text-muted mt-3">Chưa có lịch sử khám</h6>
    </div>
}
else
{
    foreach (var item in Model)
    {
        <div class="stat-card mb-3">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h6 class="fw-bold mb-1">Phiếu #@item.MaPhieuKhamBenh</h6>
                    <div class="small text-muted">
                        <i class="bi bi-calendar3 me-1"></i>@item.NgayLap.ToString("dd/MM/yyyy")
                        &bull; <i class="bi bi-geo-alt me-1"></i>@(item.TenKhoa ?? "—") / @(item.TenPhong ?? "—")
                        @if (!string.IsNullOrEmpty(item.TenBacSi))
                        {
                            <span>&bull; BS. @item.TenBacSi</span>
                        }
                    </div>
                </div>
                @if (item.TrangThai == "Đang khám")
                {
                    <span class="badge badge-pending fs-6"><i class="bi bi-hourglass-split me-1"></i>Đang khám</span>
                }
                else if (item.TrangThai == "Hoàn thành")
                {
                    <span class="badge badge-done fs-6"><i class="bi bi-check-circle me-1"></i>Hoàn thành</span>
                }
                else
                {
                    <span class="badge bg-secondary">@item.TrangThai</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(item.LyDoDenKham))
            {
                <div class="mb-2">
                    <div class="small fw-semibold text-muted">Lý do đến khám</div>
                    <div>@item.LyDoDenKham</div>
                </div>
            }
            @if (item.STT.HasValue)
            {
                <div class="alert alert-warning py-2 mb-0 small">
                    <i class="bi bi-list-ol me-1"></i>Số thứ tự: <strong>@item.STT</strong>
                </div>
            }
        </div>
    }
}
