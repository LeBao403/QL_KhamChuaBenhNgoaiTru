@model QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.DashboardBenhNhan
@{
    ViewBag.Title = "Trang chủ";
    var profile = ViewBag.Profile as QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.BenhNhanProfile;
}
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto mb-3" style="background: linear-gradient(135deg, #0d6efd, #0a4fd4); color: white;">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div class="stat-number">@Model.SoLichKhamChoDuyet</div>
            <div class="stat-label">Lịch chờ duyệt</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto mb-3" style="background: linear-gradient(135deg, #198754, #16653a); color: white;">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stat-number">@Model.SoLichKhamDaXacNhan</div>
            <div class="stat-label">Lịch đã xác nhận</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto mb-3" style="background: linear-gradient(135deg, #fd7e14, #c5600a); color: white;">
                <i class="bi bi-activity"></i>
            </div>
            <div class="stat-number">@Model.TongSoLanKham</div>
            <div class="stat-label">Tổng lần khám</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto mb-3" style="background: linear-gradient(135deg, #dc3545, #a62b3a); color: white;">
                <i class="bi bi-prescription2"></i>
            </div>
            <div class="stat-number">@Model.TongDonThuoc</div>
            <div class="stat-label">Đơn thuốc đã kê</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto mb-3" style="background: linear-gradient(135deg, #6f42c1, #5a32a0); color: white;">
                <i class="bi bi-receipt-cutoff"></i>
            </div>
            <div class="stat-number">@Model.TongHoaDon</div>
            <div class="stat-label">Hóa đơn</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center" style="background: linear-gradient(135deg, #0d6efd, #0a4fd4); color: white;">
            <div class="stat-icon mx-auto mb-3 bg-white" style="color: #0d6efd;">
                <i class="bi bi-person-vcard-fill"></i>
            </div>
            <div class="stat-number" style="color:white; font-size:1.2rem;">@(profile?.MaBN)</div>
            <div class="stat-label" style="color:rgba(255,255,255,0.8);">Mã bệnh nhân</div>
        </div>
    </div>
</div>

@if (profile != null)
{
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="stat-card">
                <div class="d-flex align-items-center mb-3">
                    <div class="user-avatar me-3" style="width:56px;height:56px;font-size:1.3rem; background: linear-gradient(135deg, #0d6efd, #198754);">
                        @(profile.HoTen?.Length > 0 ? profile.HoTen[0].ToString().ToUpper() : "B")
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@profile.HoTen</h5>
                        <div class="text-muted small">@profile.MaBN</div>
                    </div>
                    <div class="ms-auto">
                        <a href="@Url.Action("ThongTinCaNhan", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil me-1"></i> Cập nhật
                        </a>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="small text-muted">Ngày sinh</div>
                        <div class="fw-semibold">@(profile.NgaySinh?.ToString("dd/MM/yyyy") ?? "—")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Giới tính</div>
                        <div class="fw-semibold">@profile.GioiTinh</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Số điện thoại</div>
                        <div class="fw-semibold">@profile.SDT</div>
                    </div>
                    <div class="col-md-3">
                        <div class="small text-muted">Email</div>
                        <div class="fw-semibold">@profile.Email</div>
                    </div>
                </div>
                @if (profile.BHYT)
                {
                    <div class="alert alert-success mt-3 mb-0 py-2">
                        <i class="bi bi-shield-check me-1"></i>
                        BHYT: @profile.SoTheBHYT
                        @if (profile.HanSuDungBHYT.HasValue)
                        {
                            <span class="ms-2">| Hạn: @profile.HanSuDungBHYT.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <a href="@Url.Action("DatLichKham", "BenhNhan", new { area = "BenhNhan" })" class="text-decoration-none">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#dbeafe; color:#1e40af;">
                    <i class="bi bi-calendar-plus"></i>
                </div>
                <div>
                    <div class="fw-bold text-dark">Đặt lịch khám</div>
                    <div class="small text-muted">Đăng ký khám online</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("TrangThaiKham", "BenhNhan", new { area = "BenhNhan" })" class="text-decoration-none">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#d1fae5; color:#065f46;">
                    <i class="bi bi-activity"></i>
                </div>
                <div>
                    <div class="fw-bold text-dark">Trạng thái khám</div>
                    <div class="small text-muted">Xem tiến trình khám</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("HoaDon", "BenhNhan", new { area = "BenhNhan" })" class="text-decoration-none">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#fef3c7; color:#92400e;">
                    <i class="bi bi-receipt"></i>
                </div>
                <div>
                    <div class="fw-bold text-dark">Hóa đơn</div>
                    <div class="small text-muted">Xem chi tiết viện phí</div>
                </div>
                <i class="bi bi-chevron-right ms-auto text-muted"></i>
            </div>
        </a>
    </div>
</div>
