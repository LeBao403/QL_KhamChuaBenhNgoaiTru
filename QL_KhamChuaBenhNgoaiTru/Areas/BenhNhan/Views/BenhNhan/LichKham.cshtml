@model List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.LichKhamItem>
@{
    ViewBag.Title = "Xem / Hủy lịch khám";
    var cho = Model?.Count(x => x.TrangThai == "Chờ xử lý") ?? 0;
    var xn = Model?.Count(x => x.TrangThai == "Đã xác nhận") ?? 0;
    var huy = Model?.Count(x => x.TrangThai == "Hủy") ?? 0;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-1"><i class="bi bi-calendar-check-fill text-primary me-2"></i>Danh sách lịch khám</h5>
        <div class="small text-muted">Tổng: @(Model != null ? Model.Count : 0) lịch &bull; Chờ: @cho &bull; Đã xác nhận: @xn &bull; Hủy: @huy</div>
    </div>
    <a href="@Url.Action("DatLichKham", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Đặt lịch mới
    </a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
        <h6 class="text-muted mt-3">Chưa có lịch khám nào</h6>
        <a href="@Url.Action("DatLichKham", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-outline-primary btn-sm mt-2">
            Đặt lịch khám ngay
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom mb-0">
            <thead>
                <tr>
                    <th>Mã phiếu</th>
                    <th>Ngày đăng ký</th>
                    <th>Hình thức</th>
                    <th>Trạng thái lịch</th>
                    <th>Trạng thái khám</th>
                    <th>Phòng / Khoa</th>
                    <th>Bác sĩ</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@item.MaPhieuDK</td>
                        <td>@(item.NgayDangKy?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>
                            <span class="badge bg-secondary">@item.HinhThucDangKy</span>
                        </td>
                        <td>
                            @if (item.TrangThai == "Chờ xử lý")
                            {
                                <span class="badge badge-waiting">Chờ xử lý</span>
                            }
                            else if (item.TrangThai == "Đã xác nhận")
                            {
                                <span class="badge badge-confirmed">Đã xác nhận</span>
                            }
                            else if (item.TrangThai == "Hủy")
                            {
                                <span class="badge badge-cancelled">Đã hủy</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.TrangThaiKham))
                            {
                                if (item.TrangThaiKham == "Đang khám")
                                {
                                    <span class="badge badge-pending">Đang khám</span>
                                }
                                else if (item.TrangThaiKham == "Hoàn thành")
                                {
                                    <span class="badge badge-done">Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.TrangThaiKham</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@(string.IsNullOrEmpty(item.TenKhoa) ? "—" : item.TenKhoa)<br /><small class="text-muted">@(item.TenPhong ?? "")</small></td>
                        <td>@(string.IsNullOrEmpty(item.TenBacSi) ? "—" : item.TenBacSi)</td>
                        <td>
                            @if (item.TrangThai == "Chờ xử lý")
                            {
                                <form method="post" action="@Url.Action("HuyLich", "BenhNhan", new { area = "BenhNhan" })" onsubmit="return confirm('Bạn có chắc muốn hủy lịch khám #@item.MaPhieuDK không?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MaPhieuDK" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle me-1"></i>Hủy
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
