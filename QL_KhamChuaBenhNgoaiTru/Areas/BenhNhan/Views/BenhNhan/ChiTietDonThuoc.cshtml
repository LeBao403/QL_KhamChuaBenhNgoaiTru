@model QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.DonThuocChiTiet
@{
    ViewBag.Title = "Chi tiết đơn thuốc";
    var chiTiet = Model?.ChiTiet ?? new List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.ChiTietThuocItem>();
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-prescription2 text-primary me-2"></i>Chi tiết đơn thuốc</h5>
    <a href="@Url.Action("DonThuoc", "BenhNhan", new { area = "BenhNhan" })" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

@if (!chiTiet.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-exclamation-triangle text-muted" style="font-size:3rem;"></i>
        <h6 class="text-muted mt-3">Không có chi tiết đơn thuốc</h6>
    </div>
}
else
{
    <div class="stat-card mb-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-capsule text-success me-1"></i>Danh sách thuốc</h6>
        <div class="table-responsive">
            <table class="table table-custom mb-0">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Tên thuốc</th>
                        <th class="text-center">Sáng</th>
                        <th class="text-center">Trưa</th>
                        <th class="text-center">Chiều</th>
                        <th class="text-center">Tối</th>
                        <th class="text-center">Số ngày</th>
                        <th class="text-center">Tổng SL</th>
                        <th>Đơn vị</th>
                        <th class="text-end">Đơn giá</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                        foreach (var item in chiTiet)
                        {
                            <tr>
                                <td>@stt</td>
                                <td>
                                    <div class="fw-semibold">@item.TenThuoc</div>
                                    <small class="text-muted">@item.MaThuoc</small>
                                </td>
                                <td class="text-center">
                                    @(item.SoLuongSang > 0 ? item.SoLuongSang.ToString("0.##") : "-")
                                </td>
                                <td class="text-center">
                                    @(item.SoLuongTrua > 0 ? item.SoLuongTrua.ToString("0.##") : "-")
                                </td>
                                <td class="text-center">
                                    @(item.SoLuongChieu > 0 ? item.SoLuongChieu.ToString("0.##") : "-")
                                </td>
                                <td class="text-center">
                                    @(item.SoLuongToi > 0 ? item.SoLuongToi.ToString("0.##") : "-")
                                </td>
                                <td class="text-center">@item.SoNgayDung</td>
                                <td class="text-center fw-bold">@item.SoLuong</td>
                                <td>@item.DonViTinh</td>
                                <td class="text-end">@(item.DonGia > 0 ? item.DonGia.ToString("N0") + " đ" : "—")</td>
                                <td class="small text-muted">@(string.IsNullOrEmpty(item.GhiChu) ? "—" : item.GhiChu)</td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="alert alert-warning mb-0">
        <i class="bi bi-exclamation-circle-fill me-1"></i>
        <strong>Lưu ý:</strong> Hãy dùng thuốc đúng theo chỉ dẫn của bác sĩ. Nếu có thắc mắc, hãy liên hệ trực tiếp với cơ sở y tế.
    </div>
}
