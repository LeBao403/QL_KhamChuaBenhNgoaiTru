@model List<QL_KhamChuaBenhNgoaiTru.DBContext.BenhNhanPortalDB.LichSuKhamItem>
@{
    ViewBag.Title = "Lịch sử khám";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Lịch sử khám bệnh</h5>
    <span class="badge bg-primary">@(Model != null ? Model.Count : 0) lần khám</span>
</div>

@if (Model == null || !Model.Any())
{
    <div class="stat-card text-center py-5">
        <i class="bi bi-clock-history text-muted" style="font-size:3rem;"></i>
        <h6 class="text-muted mt-3">Chưa có lịch sử khám</h6>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-custom mb-0">
            <thead>
                <tr>
                    <th>Mã phiếu</th>
                    <th>Ngày khám</th>
                    <th>Khoa / Phòng</th>
                    <th>Bác sĩ</th>
                    <th>Lý do đến khám</th>
                    <th>Triệu chứng</th>
                    <th>Kết luận</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@item.MaPhieuKhamBenh</td>
                        <td>@item.NgayKham.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div>@(item.TenKhoa ?? "—")</div>
                            <small class="text-muted">@(item.TenPhong ?? "")</small>
                        </td>
                        <td>@(string.IsNullOrEmpty(item.TenBacSi) ? "—" : "BS. " + item.TenBacSi)</td>
                        <td style="max-width:150px;">
                            <span class="text-truncate d-block" title="@item.LyDoDenKham">@item.LyDoDenKham</span>
                        </td>
                        <td style="max-width:150px;">
                            <span class="text-truncate d-block text-muted" title="@item.TrieuChung">@(string.IsNullOrEmpty(item.TrieuChung) ? "—" : item.TrieuChung)</span>
                        </td>
                        <td style="max-width:150px;">
                            <span class="text-truncate d-block" title="@item.KetLuan">@(string.IsNullOrEmpty(item.KetLuan) ? "—" : item.KetLuan)</span>
                        </td>
                        <td>
                            @if (item.TrangThai == "Hoàn thành")
                            {
                                <span class="badge badge-done">Hoàn thành</span>
                            }
                            else if (item.TrangThai == "Đang khám")
                            {
                                <span class="badge badge-pending">Đang khám</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
