@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.Khoa>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <tr>
            <td><strong>KHOA-@item.MaKhoa.ToString("D3")</strong></td>

            <td>@item.TenKhoa</td>

            <td>
                @(string.IsNullOrEmpty(item.MoTa) ? "---" : (item.MoTa.Length > 80 ? item.MoTa.Substring(0, 80) + "..." : item.MoTa))
            </td>

            <td class="text-center">
                @if (item.TrangThai == true)
                {
                    <span class="badge bg-success">Hoạt động</span>
                }
                else
                {
                    <span class="badge bg-danger">Đã khóa</span>
                }
            </td>

            <td class="text-center">
                <div class="d-flex justify-content-center align-items-center flex-nowrap">

                    <a href="@Url.Action("Details", "Khoa", new { area = "Admin", id = item.MaKhoa })"
                       class="btn btn-sm btn-info me-1" title="Xem Sơ đồ Khoa">
                        <i class="bi bi-eye text-white"></i>
                    </a>

                    <a href="@Url.Action("Edit", "Khoa", new { area = "Admin", id = item.MaKhoa })"
                       class="btn btn-sm btn-warning me-1" title="Chỉnh sửa">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <form method="post" action="@Url.Action("ToggleStatus", "Khoa", new { area = "Admin" })" class="m-0 p-0 me-1" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.MaKhoa" />
                        <button type="button" class="btn btn-sm btn-lock-khoa @(item.TrangThai == true ? "btn-danger" : "btn-success")"
                                data-isactive="@(item.TrangThai == true ? "True" : "False")" title="@(item.TrangThai == true ? "Khóa Khoa" : "Mở Khoa")">
                            <i class="bi @(item.TrangThai == true ? "bi-lock-fill" : "bi-unlock-fill")"></i>
                        </button>
                    </form>

                    <form method="post" action="@Url.Action("Delete", "Khoa", new { area = "Admin", id = item.MaKhoa })" class="m-0 p-0" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-sm btn-danger btn-delete-khoa" title="Xóa Khoa">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="5" class="text-center text-muted p-4">
            <i class="bi bi-hospital fs-3 d-block mb-2"></i>
            Chưa có Khoa Khám Bệnh nào trên hệ thống.
        </td>
    </tr>
}