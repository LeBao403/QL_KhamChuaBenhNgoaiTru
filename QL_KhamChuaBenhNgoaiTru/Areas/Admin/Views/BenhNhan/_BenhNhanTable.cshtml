@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.BenhNhanManageViewModel>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <tr>
            <td><strong>@item.BenhNhan.MaBN</strong></td>
            <td>@item.BenhNhan.HoTen</td>
            <td>@item.BenhNhan.Email</td>
            <td>@item.BenhNhan.SDT</td>
            <td>
                @if (item.TaiKhoan != null && !string.IsNullOrEmpty(item.TaiKhoan.Username))
                {
                    <span class="badge bg-secondary">@item.TaiKhoan.Username</span>
                }
                else
                {
                    <span class="text-muted fst-italic">N/A</span>
                }
            </td>

            <td>
                @if (item.TaiKhoan != null && !string.IsNullOrEmpty(item.TaiKhoan.PasswordHash))
                {
                    <div class="password-toggle-wrapper">
                        <input type="password" class="form-control-plaintext password-field" value="@item.TaiKhoan.PasswordHash" readonly>
                        <i class="bi bi-eye-slash toggle-password-icon"></i>
                    </div>
                }
                else
                {
                    <span class="text-muted fst-italic">N/A</span>
                }
            </td>

            @* === THÊM CỘT TRẠNG THÁI === *@
            <td class="text-center">
                @if (item.TaiKhoan != null && item.TaiKhoan.MaTK > 0)
                {
                    if (item.TaiKhoan.IsActive)
                    {
                        <span class="badge bg-success">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Đã khóa</span>
                    }
                }
                else
                {
                    <span class="text-muted fst-italic">N/A</span>
                }
            </td>

            <td class="text-center">
                @* CỤM NÀY ÉP CÁC NÚT PHẢI NẰM NGANG, KHÔNG RỚT DÒNG *@
                <div class="d-flex justify-content-center align-items-center flex-nowrap" style="gap: 5px;">

                    <a href="@Url.Action("Details", "BenhNhan", new { area = "Admin", id = item.BenhNhan.MaBN.Trim() })"
                       class="btn btn-sm btn-info" title="Xem chi tiết">
                        <i class="bi bi-eye"></i>
                    </a>

                    <a href="@Url.Action("Edit_KH", "BenhNhan", new { area = "Admin", id = item.BenhNhan.MaBN.Trim() })"
                       class="btn btn-sm btn-warning" title="Chỉnh sửa">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    @* NÚT KHÓA TÀI KHOẢN *@
                    @if (item.TaiKhoan != null && item.TaiKhoan.MaTK > 0)
                    {
                        <form method="post" action="@Url.Action("ToggleLock", "BenhNhan", new { area = "Admin" })" class="m-0 p-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.BenhNhan.MaBN.Trim()" />
                            <button type="button" class="btn btn-sm btn-lock-tk @(item.TaiKhoan.IsActive ? "btn-danger" : "btn-success")"
                                    data-isactive="@item.TaiKhoan.IsActive" title="@(item.TaiKhoan.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                <i class="bi @(item.TaiKhoan.IsActive ? "bi-lock-fill" : "bi-unlock-fill")"></i>
                            </button>
                        </form>
                    }

                    @* NÚT XÓA *@
                    <form method="post" action="@Url.Action("Delete", "BenhNhan", new { area = "Admin", id = item.BenhNhan.MaBN.Trim() })" class="m-0 p-0">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-sm btn-danger btn-delete-kh" title="Xóa">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>

                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="8" class="text-center text-muted p-4">
            <i class="bi bi-person-x fs-3 d-block mb-2"></i>
            Không tìm thấy khách hàng nào.
        </td>
    </tr>
}