@model QL_KhamChuaBenhNgoaiTru.Models.BenhNhanManageViewModel
@{
    ViewBag.Title = "Chỉnh sửa thông tin bệnh nhân";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
}

<style>
    .profile-card {
        background: #ffffff;
        border-radius: 15px;
        padding: 25px 30px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        border: 1px solid #dee2e6;
    }

    .section-title {
        color: #0d6efd;
        font-weight: 600;
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .section-title i {
            margin-right: 8px;
        }

    .form-label {
        font-weight: 500;
    }

    .bg-light-blue {
        background-color: #f8fbff;
        border: 1px dashed #0d6efd;
        border-radius: 10px;
        padding: 20px;
    }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark mb-0">Chỉnh sửa hồ sơ bệnh nhân</h4>
        <span class="text-muted">Mã BN: <strong class="text-primary">@Model.BenhNhan.MaBN</strong></span>
    </div>

    @using (Html.BeginForm("Edit_KH", "BenhNhan", FormMethod.Post, new { @class = "needs-validation" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @* Giữ lại các ID quan trọng để Update *@
        @Html.HiddenFor(m => m.BenhNhan.MaBN)
        @Html.HiddenFor(m => m.TaiKhoan.MaTK)

        <h4 class="section-title"><i class="bi bi-person-badge"></i> Thông tin hành chính</h4>
        <div class="profile-card mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Họ tên</label>
                    @Html.EditorFor(m => m.BenhNhan.HoTen, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.HoTen, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Ngày sinh</label>
                    @Html.EditorFor(m => m.BenhNhan.NgaySinh, new { htmlAttributes = new { @class = "form-control", @type = "date", @Value = Model.BenhNhan.NgaySinh.ToString("yyyy-MM-dd") } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.NgaySinh, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Giới tính</label>
                    @Html.DropDownListFor(m => m.BenhNhan.GioiTinh, new SelectList(new[] { "Nam", "Nữ", "Khác" }), new { @class = "form-select" })
                </div>

                <div class="col-md-4">
                    <label class="form-label">Số CCCD</label>
                    @Html.EditorFor(m => m.BenhNhan.CCCD, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.CCCD, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-4">
                    <label class="form-label">Số điện thoại</label>
                    @Html.EditorFor(m => m.BenhNhan.SDT, new { htmlAttributes = new { @class = "form-control", id = "bn_sdt" } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.SDT, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    @Html.EditorFor(m => m.BenhNhan.Email, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.Email, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-12">
                    <label class="form-label">Địa chỉ</label>
                    @Html.TextAreaFor(m => m.BenhNhan.DiaChi, new { @class = "form-control", @rows = 2 })
                    @Html.ValidationMessageFor(m => m.BenhNhan.DiaChi, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <h4 class="section-title mt-5"><i class="bi bi-shield-check"></i> Bảo hiểm Y tế</h4>
        <div class="profile-card mb-4">
            <div class="form-check form-switch mb-3">
                @Html.CheckBoxFor(m => m.BenhNhan.BHYT, new { @class = "form-check-input", id = "switchBHYT" })
                <label class="form-check-label fw-bold" for="switchBHYT">Sử dụng thẻ BHYT</label>
            </div>
            <div id="areaBHYT" class="row g-3 bg-light-blue p-3 rounded" style="@(Model.BenhNhan.BHYT ? "" : "display:none;")">
                <div class="col-md-4">
                    <label class="form-label">Số thẻ BHYT</label>
                    @Html.EditorFor(m => m.BenhNhan.SoTheBHYT, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.BenhNhan.SoTheBHYT, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-4">
                    <label class="form-label">Hạn dùng thẻ</label>
                    @Html.EditorFor(m => m.BenhNhan.HanSuDungBHYT, new { htmlAttributes = new { @class = "form-control", @type = "date", @Value = Model.BenhNhan.HanSuDungBHYT?.ToString("yyyy-MM-dd") } })
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tuyến khám</label>
                    @Html.DropDownListFor(m => m.BenhNhan.TuyenKham, new SelectList(new[] { "Đúng tuyến", "Trái tuyến" }), new { @class = "form-select" })
                </div>
                <div class="col-md-2">
                    <label class="form-label">Mức hưởng (%)</label>
                    @Html.EditorFor(m => m.BenhNhan.MucHuongBHYT, new { htmlAttributes = new { @class = "form-control", @type = "number" } })
                </div>
            </div>
        </div>

        <h4 class="section-title mt-5"><i class="bi bi-key"></i> Thông tin tài khoản</h4>
        <div class="profile-card mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tên đăng nhập (Username)</label>
                    @Html.TextBoxFor(m => m.TaiKhoan.Username, new { @class = "form-control bg-light", @readonly = "readonly", id = "tk_user" })
                </div>
                <div class="col-md-4">
                    <label class="form-label">Mật khẩu mới (Để trống nếu giữ cũ)</label>
                    @Html.PasswordFor(m => m.TaiKhoan.PasswordHash, new { @class = "form-control", @Value = "" })
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái</label>
                    @Html.DropDownListFor(m => m.TaiKhoan.IsActive, new SelectList(new[] {
                        new { V = true, T = "Hoạt động" },
                        new { V = false, T = "Khóa" }
                    }, "V", "T"), new { @class = "form-select" })
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2 mb-5">
            <a href="@Url.Action("Details", "BenhNhan", new { id = Model.BenhNhan.MaBN.Trim() })" class="btn btn-secondary px-4">Hủy</a>
            <button type="submit" class="btn btn-primary px-5 shadow">
                <i class="bi bi-save me-1"></i> Lưu thay đổi
            </button>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Logic đồng bộ Username
        const sdt = document.getElementById('bn_sdt');
        const user = document.getElementById('tk_user');
        if(sdt && user) {
            sdt.addEventListener('input', () => { user.value = sdt.value; });
        }

        // Logic ẩn hiện BHYT
        const sw = document.getElementById('switchBHYT');
        const area = document.getElementById('areaBHYT');
        if(sw && area) {
            sw.addEventListener('change', () => { area.style.display = sw.checked ? 'flex' : 'none'; });
        }
    });
</script>