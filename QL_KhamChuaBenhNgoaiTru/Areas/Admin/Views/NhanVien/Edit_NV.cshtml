@model QL_KhamChuaBenhNgoaiTru.Models.NhanVienManageViewModel2

@{
    ViewBag.Title = "Chỉnh sửa thông tin nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";

    var currentAvatar = !string.IsNullOrEmpty(Model.NhanVien.HinhAnh)
        ? Url.Content("~/" + Model.NhanVien.HinhAnh)
        : Url.Content("~/Images/nhanvien/default-avatar.png");
}

<style>
    .profile-card {
        background: #ffffff;
        border-radius: 15px;
        padding: 25px 30px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        border: 1px solid #dee2e6;
    }

    .section-title {
        color: #0d6efd;
        font-weight: 600;
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .section-title i {
            margin-right: 8px;
        }

    .form-label {
        font-weight: 500;
    }

    .avatar-upload-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .avatar-preview {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        border: 3px solid #dee2e6;
        object-fit: cover;
        background: #f0f0f0;
    }

    .avatar-upload-label {
        display: inline-block;
        padding: 6px 16px;
        background: #e9ecef;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 500;
        color: #495057;
        transition: all 0.2s;
    }

        .avatar-upload-label:hover {
            background: #0d6efd;
            color: #fff;
        }

    #HinhAnh_File {
        display: none;
    }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark mb-0">Chỉnh sửa hồ sơ nhân viên</h4>
        <span class="text-muted">Mã NV: <strong class="text-primary">@Model.NhanVien.MaNV</strong></span>
    </div>

    @using (Html.BeginForm("Edit_NV", "NhanVien", new { area = "Admin" }, FormMethod.Post, new { @class = "needs-validation", enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @* Giu lai cac ID quan trong *@
        @Html.HiddenFor(m => m.NhanVien.MaNV)
        @Html.HiddenFor(m => m.TaiKhoan.MaTK)
        @Html.HiddenFor(m => m.NhanVien.HinhAnh)

        <h4 class="section-title"><i class="bi bi-person-badge"></i> Thông tin hành chính</h4>
        <div class="profile-card mb-4">
            <div class="row g-3">
                <div class="col-md-2">
                    <div class="avatar-upload-wrapper">
                        <img id="avatarPreview" src="@currentAvatar" alt="Avatar" class="avatar-preview" />
                        <label for="HinhAnh_File" class="avatar-upload-label">
                            <i class="bi bi-camera me-1"></i> Chọn ảnh
                        </label>
                        <input type="file" name="HinhAnh_File" id="HinhAnh_File" accept="image/*" />
                    </div>
                </div>
                <div class="col-md-10">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ tên</label>
                            @Html.EditorFor(m => m.NhanVien.HoTen, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(m => m.NhanVien.HoTen, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Ngày sinh</label>
                            @Html.EditorFor(m => m.NhanVien.NgaySinh, new { htmlAttributes = new { @class = "form-control", @type = "date" } })
                            @Html.ValidationMessageFor(m => m.NhanVien.NgaySinh, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Giới tính</label>
                            @Html.DropDownListFor(m => m.NhanVien.GioiTinh, new SelectList(new[] { "Nam", "Nữ", "Khác" }), new { @class = "form-select" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Số điện thoại</label>
                            @Html.EditorFor(m => m.NhanVien.SDT, new { htmlAttributes = new { @class = "form-control", id = "nv_sdt" } })
                            @Html.ValidationMessageFor(m => m.NhanVien.SDT, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Email</label>
                            @Html.EditorFor(m => m.NhanVien.Email, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(m => m.NhanVien.Email, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Địa chỉ</label>
                            @Html.TextAreaFor(m => m.NhanVien.DiaChi, new { @class = "form-control", @rows = 2 })
                            @Html.ValidationMessageFor(m => m.NhanVien.DiaChi, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h4 class="section-title mt-5"><i class="bi bi-briefcase-fill"></i> Thông tin công tác</h4>
        <div class="profile-card mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Chức vụ</label>
                    @Html.DropDownListFor(m => m.NhanVien.MaChucVu,
                        (SelectList)ViewBag.DsChucVu,
                        "-- Chọn chức vụ --",
                        new { @class = "form-select", id = "NhanVien_MaChucVu" })
                </div>
                <div class="col-md-4">
                    <label class="form-label">Khoa</label>
                    <select name="NhanVien.MaKhoa" id="NhanVien_MaKhoa" class="form-select">
                        <option value="">-- Chọn khoa --</option>
                        @if (ViewBag.DsKhoa != null)
                        {
                            foreach (var k in ViewBag.DsKhoa)
                            {
                                <option value="@k.MaKhoa" @(Model.NhanVien.MaKhoa == k.MaKhoa ? "selected" : "")>@k.TenKhoa</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phòng làm việc</label>
                    <select name="NhanVien.MaPhong" id="NhanVien_MaPhong" class="form-select">
                        <option value="">-- Chọn phòng --</option>
                        @if (ViewBag.DsPhong != null)
                        {
                            foreach (var p in ViewBag.DsPhong)
                            {
                                <option value="@p.MaPhong" @(Model.NhanVien.MaPhong == p.MaPhong ? "selected" : "")>@p.TenPhong</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Trạng thái làm việc</label>
                    <select name="NhanVien.TrangThai" class="form-select">
                        <option value="True" @(Model.NhanVien.TrangThai == true ? "selected" : "")>Đang làm việc</option>
                        <option value="False" @(Model.NhanVien.TrangThai == false ? "selected" : "")>Đã nghỉ</option>
                    </select>
                </div>
            </div>
        </div>

        <h4 class="section-title mt-5"><i class="bi bi-key"></i> Thông tin tài khoản</h4>
        <div class="profile-card mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tên đăng nhập (Username)</label>
                    @Html.TextBoxFor(m => m.TaiKhoan.Username, new { @class = "form-control bg-light", @readonly = "readonly", id = "tk_user" })
                </div>
                <div class="col-md-4">
                    <label class="form-label">Mật khẩu mới (Để trống nếu giữ cũ)</label>
                    @Html.PasswordFor(m => m.TaiKhoan.PasswordHash, new { @class = "form-control", @Value = "" })
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái TK</label>
                    @Html.DropDownListFor(m => m.TaiKhoan.IsActive, new SelectList(new[] {
                        new { V = true, T = "Hoạt động" },
                        new { V = false, T = "Khóa" }
                    }, "V", "T"), new { @class = "form-select" })
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2 mb-5">
            <a href="@Url.Action("Details", "NhanVien", new { id = Model.NhanVien.MaNV.Trim() })" class="btn btn-secondary px-4">Hủy</a>
            <button type="submit" class="btn btn-primary px-5 shadow">
                <i class="bi bi-save me-1"></i> Lưu thay đổi
            </button>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Dong bo Username
        const sdt = document.getElementById('nv_sdt');
        const user = document.getElementById('tk_user');
        if (sdt && user) {
            sdt.addEventListener('input', function () { user.value = sdt.value; });
        }

        // Preview avatar khi chon anh
        document.getElementById('HinhAnh_File').addEventListener('change', function (e) {
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function (event) {
                    document.getElementById('avatarPreview').src = event.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    });
</script>
