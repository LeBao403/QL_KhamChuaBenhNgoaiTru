@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.NhanVienManageViewModel>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        // ==============================================================
        // LOGIC LẤY HÌNH ẢNH THÔNG MINH CHO TỪNG NHÂN VIÊN TRONG BẢNG
        // ==============================================================
        string avatarUrl = "";

        if (!string.IsNullOrEmpty(item.HinhAnh))
        {
            string hinhAnh = item.HinhAnh.Trim();
            if (hinhAnh.Contains("/"))
            {
                avatarUrl = Url.Content("~/" + hinhAnh.TrimStart('/'));
            }
            else
            {
                avatarUrl = Url.Content("~/Images/doctors/" + hinhAnh);
            }
        }
        else
        {
            string gioiTinh = item.GioiTinh ?? "";
            if (gioiTinh.Equals("Nữ", StringComparison.OrdinalIgnoreCase) || gioiTinh.Equals("Nu", StringComparison.OrdinalIgnoreCase))
            {
                avatarUrl = Url.Content("~/Images/doctors/defaultDoctor_Female.png");
            }
            else
            {
                avatarUrl = Url.Content("~/Images/doctors/defaultDoctor_Male.png");
            }
        }

        <tr>
            <td class="align-middle"><strong>@item.MaNV</strong></td>
            <td class="align-middle">
                <div class="d-flex align-items-center gap-2">
                    <div class="nv-avatar">
                        @* Đã gỡ bỏ phần hiển thị chữ, thay bằng ảnh mặc định chuẩn xịn và thêm thẻ onerror *@
                        <img src="@avatarUrl" alt="@item.HoTen"
                             style="width:100%;height:100%;object-fit:cover;border-radius:50%;"
                             onerror="this.src='@Url.Content("~/Images/doctors/defaultDoctor_Male.png")';" />
                    </div>
                    <div>
                        <div class="fw-semibold text-dark">@item.HoTen</div>
                        <small class="text-muted">@item.SDT</small>
                    </div>
                </div>
            </td>
            <td class="align-middle"><span class="badge bg-info text-dark">@item.TenChucVu</span></td>
            <td class="align-middle">@item.Email</td>

            <td class="text-center align-middle">
                @if (item.TrangThai)
                {
                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đang làm</span>
                }
                else
                {
                    <span class="badge bg-secondary"><i class="bi bi-clock"></i> Đã nghỉ</span>
                }
            </td>

            <td class="text-center align-middle">
                <div class="d-flex justify-content-center align-items-center flex-nowrap" style="gap: 5px;">

                    <a href="@Url.Action("Details", "NhanVien", new { area = "Admin", id = item.MaNV.Trim() })"
                       class="btn btn-sm btn-info" title="Xem chi tiết">
                        <i class="bi bi-eye"></i>
                    </a>

                    <a href="@Url.Action("Edit_NV", "NhanVien", new { area = "Admin", id = item.MaNV.Trim() })"
                       class="btn btn-sm btn-warning" title="Chỉnh sửa">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <form method="post" action="@Url.Action("Delete", "NhanVien", new { area = "Admin" })" class="m-0 p-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.MaNV.Trim()" />
                        <button type="button" class="btn btn-sm btn-danger btn-delete-nv" title="Xóa">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>

                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="6" class="text-center text-muted p-4">
            <i class="bi bi-person-x fs-3 d-block mb-2"></i>
            Không tìm thấy nhân viên nào.
        </td>
    </tr>
}