@{
    ViewBag.Title = "Quản lý AI";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
    var config = ViewBag.Config as QL_KhamChuaBenhNgoaiTru.Services.AiManagementConfig;
    string aiServiceUrl = ViewBag.AiServiceUrl as string ?? "http://127.0.0.1:8000";
}

@section Styles {
    <style>
        .ai-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
        }

        .ai-kpi {
            min-height: 116px;
        }

        .metric-value {
            color: #0f172a;
            font-size: 1.8rem;
            font-weight: 800;
            line-height: 1.1;
        }

        .graph-frame {
            width: 100%;
            min-height: 360px;
            object-fit: contain;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 8px;
        }

        .table-models td {
            vertical-align: middle;
        }
    </style>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="h4 mb-1 fw-bold text-dark">
                <i class="bi bi-cpu-fill text-primary me-2"></i>Quản lý AI
            </h2>
            <p class="text-muted mb-0 small">Theo dõi, train lại và chọn model gợi ý thuốc đang dùng.</p>
        </div>
        <button id="btnRefreshAi" class="btn btn-light border fw-semibold">
            <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
        </button>
    </div>

    <div id="aiOfflineAlert" class="alert alert-warning d-none">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Không kết nối được AI service tại <strong>@aiServiceUrl</strong>. Hãy khởi động FastAPI trước khi train hoặc xem model.
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="ai-card ai-kpi p-3">
                <div class="text-muted small fw-semibold mb-2">Trạng thái service</div>
                <div id="kpiService" class="metric-value">...</div>
                <div id="kpiCheckedAt" class="text-muted small mt-2">Đang kiểm tra</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ai-card ai-kpi p-3">
                <div class="text-muted small fw-semibold mb-2">Model đang dùng</div>
                <div id="kpiActiveModel" class="metric-value text-break">...</div>
                <div class="text-muted small mt-2">Dùng cho API gợi ý thuốc</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ai-card ai-kpi p-3">
                <div class="text-muted small fw-semibold mb-2">Lần train gần nhất</div>
                <div id="kpiLastTrain" class="metric-value">...</div>
                <div id="kpiTrainCount" class="text-muted small mt-2">Chưa có dữ liệu</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ai-card ai-kpi p-3">
                <div class="text-muted small fw-semibold mb-2">Số model đã lưu</div>
                <div id="kpiModelCount" class="metric-value">0</div>
                <div class="text-muted small mt-2">Có thể rollback model cũ</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-5">
            <div class="ai-card p-4 h-100">
                <h5 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Train model</h5>
                <p class="text-muted small">Train lại Node2Vec từ dữ liệu đơn thuốc hiện tại. Model mới train thành công sẽ được chọn làm active.</p>

                <button id="btnTrainNow" class="btn btn-primary fw-bold px-4 mb-4">
                    <i class="bi bi-play-circle-fill me-2"></i>Train model ngay
                </button>

                <hr />

                <h6 class="fw-bold mb-3">Train tự động</h6>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="chkAutoTrain" @(config != null && config.IsAutoTrainEnabled ? "checked" : "")>
                    <label class="form-check-label fw-semibold" for="chkAutoTrain">Bật train tự động hằng ngày</label>
                </div>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label fw-semibold text-secondary">Giờ train</label>
                        <input id="timeTrain" type="time" class="form-control" value="@(config != null ? config.TrainTime : "01:00")" />
                    </div>
                    <div class="col-sm-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="chkAutoActivate" @(config == null || config.AutoActivateAfterTrain ? "checked" : "")>
                            <label class="form-check-label" for="chkAutoActivate">Tự động kích hoạt</label>
                        </div>
                    </div>
                </div>
                <div class="text-muted small mt-3">
                    Lần auto train gần nhất:
                    <strong>@(config != null && config.LastTrainDate.HasValue ? config.LastTrainDate.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa có")</strong>
                </div>
                @if (config != null && !string.IsNullOrWhiteSpace(config.LastError))
                {
                    <div class="alert alert-danger small mt-3 mb-0">
                        Lỗi auto train: @config.LastError
                    </div>
                }
                <div class="mt-3">
                    <button id="btnSaveAiSchedule" class="btn btn-outline-primary fw-semibold">
                        <i class="bi bi-check-circle me-1"></i>Lưu cấu hình
                    </button>
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="ai-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow text-success me-2"></i>Độ chính xác</h5>
                    <span id="metricSummary" class="badge bg-light text-secondary border">Chưa có metric</span>
                </div>
                <div style="height: 320px;">
                    <canvas id="accuracyChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-6">
            <div class="ai-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-diagram-3-fill text-info me-2"></i>Sơ đồ phân cụm</h5>
                    <a id="lnkInteractiveGraph" href="#" target="_blank" class="btn btn-sm btn-outline-primary disabled">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Mở 3D
                    </a>
                </div>
                <img id="imgGraph" class="graph-frame" alt="Sơ đồ phân cụm AI" />
            </div>
        </div>
        <div class="col-xl-6">
            <div class="ai-card p-4 h-100">
                <h5 class="fw-bold mb-3"><i class="bi bi-list-check text-primary me-2"></i>Danh sách model</h5>
                <div class="table-responsive">
                    <table class="table table-hover table-models mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Model</th>
                                <th>Ngày tạo</th>
                                <th class="text-center">Hit@10</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="modelsBody">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Đang tải model...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const aiBaseUrl = '@aiServiceUrl'.replace(/\/$/, '');
        let accuracyChart = null;

        $(document).ready(function () {
            loadAiOverview();
            $('#btnRefreshAi').click(loadAiOverview);
            $('#btnTrainNow').click(trainAiNow);
            $('#btnSaveAiSchedule').click(saveAiSchedule);
        });

        function formatDate(value) {
            if (!value) return 'Chưa có';
            const d = new Date(value);
            if (Number.isNaN(d.getTime())) return value;
            return d.toLocaleString('vi-VN');
        }

        function hitRate(model, k) {
            return Number(model?.hit_rates?.[String(k)]?.rate || 0);
        }

        function loadAiOverview() {
            $('#aiOfflineAlert').addClass('d-none');
            $.get('@Url.Action("Overview", "AiManagement", new { area = "Admin" })', function (res) {
                if (!res.success) {
                    $('#aiOfflineAlert').removeClass('d-none');
                    $('#kpiService').html('<span class="text-danger">Offline</span>');
                    $('#modelsBody').html('<tr><td colspan="4" class="text-center text-muted py-4">Không tải được danh sách model.</td></tr>');
                    return;
                }

                const status = res.status || {};
                const modelsPayload = res.models || {};
                const activeModel = status.active_model || {};
                const models = modelsPayload.models || [];
                const activeId = status.active_model_id || modelsPayload.active_model_id || '';

                $('#kpiService').html('<span class="text-success">Online</span>');
                $('#kpiCheckedAt').text('Kiểm tra lúc ' + formatDate(status.checked_at));
                $('#kpiActiveModel').text(activeId || 'Chưa có');
                $('#kpiLastTrain').text(activeModel.created_at ? formatDate(activeModel.created_at) : 'Chưa có');
                $('#kpiTrainCount').text(activeModel.total_prescriptions ? `Đã học ${activeModel.total_prescriptions} toa thuốc` : 'Chưa có dữ liệu train');
                $('#kpiModelCount').text(models.length);

                renderAccuracy(activeModel);
                renderGraph(activeModel);
                renderModels(models, activeId);
            });
        }

        function renderAccuracy(model) {
            const data = [hitRate(model, 10), hitRate(model, 20), hitRate(model, 30)];
            $('#metricSummary').text(model?.valid_tests ? `Tập test hợp lệ: ${model.valid_tests}` : 'Chưa có metric');

            const ctx = document.getElementById('accuracyChart');
            if (accuracyChart) accuracyChart.destroy();
            accuracyChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Hit@10', 'Hit@20', 'Hit@30'],
                    datasets: [{
                        data: data,
                        backgroundColor: ['#2563eb', '#10b981', '#f59e0b'],
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        function renderGraph(model) {
            if (model && model.graph_url_static) {
                $('#imgGraph').attr('src', aiBaseUrl + model.graph_url_static + '?v=' + Date.now());
                $('#lnkInteractiveGraph').attr('href', aiBaseUrl + model.graph_url_interactive).removeClass('disabled');
            } else {
                $('#imgGraph').removeAttr('src');
                $('#lnkInteractiveGraph').attr('href', '#').addClass('disabled');
            }
        }

        function renderModels(models, activeId) {
            if (!models.length) {
                $('#modelsBody').html('<tr><td colspan="4" class="text-center text-muted py-4">Chưa có model nào. Hãy train model đầu tiên.</td></tr>');
                return;
            }

            const rows = models.map(m => {
                const isActive = m.model_id === activeId;
                const action = isActive
                    ? '<span class="badge bg-success">Đang dùng</span>'
                    : `<button class="btn btn-sm btn-outline-primary btn-select-model" data-model="${m.model_id}">Chọn</button>`;

                return `<tr>
                    <td><span class="fw-semibold text-dark">${m.model_id}</span></td>
                    <td>${formatDate(m.created_at)}</td>
                    <td class="text-center fw-bold">${hitRate(m, 10)}%</td>
                    <td class="text-center">${action}</td>
                </tr>`;
            }).join('');

            $('#modelsBody').html(rows);
            $('.btn-select-model').click(function () {
                selectModel($(this).data('model'));
            });
        }

        function trainAiNow() {
            Swal.fire({
                title: 'Đang train model AI',
                html: 'Quá trình này có thể mất vài phút. Vui lòng không đóng trình duyệt.',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            $.post('@Url.Action("TrainNow", "AiManagement", new { area = "Admin" })', function (res) {
                if (res.success) {
                    Swal.fire('Hoàn tất', 'Model AI mới đã được train và kích hoạt.', 'success').then(loadAiOverview);
                } else {
                    Swal.fire('Lỗi train AI', res.message, 'error');
                }
            }).fail(function () {
                Swal.fire('Lỗi kết nối', 'Không gọi được AI service.', 'error');
            });
        }

        function selectModel(modelId) {
            $.post('@Url.Action("SelectModel", "AiManagement", new { area = "Admin" })', { modelId: modelId }, function (res) {
                if (res.success) {
                    Swal.fire({ icon: 'success', title: 'Đã chọn model', timer: 1500, showConfirmButton: false }).then(loadAiOverview);
                } else {
                    Swal.fire('Lỗi', res.message, 'error');
                }
            });
        }

        function saveAiSchedule() {
            $.post('@Url.Action("SaveSchedule", "AiManagement", new { area = "Admin" })', {
                isAutoTrainEnabled: $('#chkAutoTrain').is(':checked'),
                trainTime: $('#timeTrain').val(),
                autoActivateAfterTrain: $('#chkAutoActivate').is(':checked')
            }, function (res) {
                if (res.success) {
                    Swal.fire({ icon: 'success', title: 'Đã lưu cấu hình', timer: 1500, showConfirmButton: false });
                } else {
                    Swal.fire('Lỗi', res.message, 'error');
                }
            });
        }
    </script>
}
