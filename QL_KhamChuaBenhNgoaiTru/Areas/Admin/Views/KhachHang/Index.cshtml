
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
}
@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.KhachHangManageViewModel>

<style>
    .password-toggle-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        max-width: 200px;
    }

    .password-field {
        padding-right: 2.5rem !important;
        background-color: transparent !important;
        border: none !important;
        cursor: default;
        /* Ngăn người dùng chọn văn bản khi bị che */
        user-select: none;
    }

        .password-field:focus {
            box-shadow: none !important;
        }

    .toggle-password-icon {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
    }
</style>


<div class="container-fluid">
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary fw-bold">
                <i class="bi bi-people me-2"></i> Danh sách khách hàng
            </h4>
            <a href="@Url.Action("Create", "KhachHang", new { area = "Admin" })"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Thêm khách hàng
            </a>
        </div>

        <div class="card-body">
            <div class="mb-3">
                <input type="text" class="form-control live-search"
                       data-url="@Url.Action("Search", "KhachHang", new { area = "Admin" })"
                       data-target="#khResult"
                       placeholder="Tìm khách hàng theo Mã, Họ tên hoặc SĐT...">
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped align-middle bg-white">
                    <thead class="table-primary">
                        <tr>
                            <th>Mã KH</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>SĐT</th>
                            <th>Username</th>
                            <th>Password</th>
                            <th class="text-center" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="khResult">
                        @Html.Partial("_KhachHangTable", Model)
                    </tbody>
                </table>
            </div>

            @Html.Partial("_Pagination")
        </div>
    </div>
</div>

@* === THÊM JAVASCRIPT XỬ LÝ CLICK === *@
@section Scripts {
    <script src="~/Scripts/live-search.js"></script>

    <script>
        $(document).ready(function () {
            // Dùng .on() để bắt sự kiện click trên #khResult
            // Code này sẽ hoạt động ngay cả khi bạn tìm kiếm (live-search)
            $('#khResult').on('click', '.toggle-password-icon', function () {

                var icon = $(this);
                // Tìm input 'password-field' nằm bên cạnh icon
                var input = icon.siblings('.password-field');

                // Lấy kiểu (type) hiện tại
                var type = input.attr('type');

                if (type === 'password') {
                    // Nếu là 'password' -> đổi thành 'text'
                    input.attr('type', 'text');
                    // Cho phép chọn văn bản (để copy)
                    input.css('user-select', 'auto');
                    // Đổi icon
                    icon.removeClass('bi-eye-slash').addClass('bi-eye');
                } else {
                    // Nếu là 'text' -> đổi thành 'password'
                    input.attr('type', 'password');
                    // Không cho chọn văn bản
                    input.css('user-select', 'none');
                    // Đổi icon
                    icon.removeClass('bi-eye').addClass('bi-eye-slash');
                }
            });
        });
    </script>
}

