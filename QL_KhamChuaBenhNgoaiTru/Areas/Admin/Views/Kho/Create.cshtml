@{
    ViewBag.Title = "Tạo phiếu nhập kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";

    var dsNCC = ViewBag.DsNhaCungCap as List<QL_KhamChuaBenhNgoaiTru.DBContext.NhaCungCapItem>;
    var dsThuoc = ViewBag.DsThuoc as List<QL_KhamChuaBenhNgoaiTru.DBContext.ThuocItem>;
    var dsKho = ViewBag.DsKho as List<QL_KhamChuaBenhNgoaiTru.DBContext.KhoItem>;
}

@section Styles {
    <style>
        .ct-row {
            background: #f8fbff;
            border: 1px dashed #0d6efd;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 10px;
        }
        .table-scroll { max-height: 400px; overflow-y: auto; }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-dark mb-0">
        <i class="bi bi-file-earmark-plus text-primary me-2"></i>Tạo phiếu nhập kho
    </h4>
    <a href="@Url.Action("DanhSachPhieuNhap", "Kho", new { area = "Admin" })" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-bold">
        <i class="bi bi-info-circle text-primary me-2"></i>Thông tin phiếu nhập
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "Kho", FormMethod.Post, new { id = "frmCreate" }))
        {
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Kho nhập hàng <span class="text-danger">*</span></label>
                    <select name="MaKho" class="form-select" required>
                        <option value="">-- Chọn kho --</option>
                        @if (dsKho != null)
                        {
                            foreach (var k in dsKho)
                            {
                                <option value="@k.MaKho">@k.TenKho</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Nhà cung cấp <span class="text-danger">*</span></label>
                    <select name="MaNSX" class="form-select" required>
                        <option value="">-- Chọn nhà cung cấp --</option>
                        @if (dsNCC != null)
                        {
                            foreach (var ncc in dsNCC)
                            {
                                <option value="@ncc.MaNSX">@ncc.TenNSX</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <input type="text" name="GhiChu" class="form-control" placeholder="VD: Nhập bổ sung thuốc tháng 3" />
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0"><i class="bi bi-list-ul text-primary me-2"></i>Chi tiết phiếu nhập</h5>
                <button type="button" class="btn btn-sm btn-primary" onclick="addRow()">
                    <i class="bi bi-plus-circle me-1"></i> Thêm dòng
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width:40px">#</th>
                            <th>Thuốc <span class="text-danger">*</span></th>
                            <th>Mã lô</th>
                            <th>Ngày sản xuất</th>
                            <th>Hạn sử dụng <span class="text-danger">*</span></th>
                            <th class="text-end">Số lượng <span class="text-danger">*</span></th>
                            <th class="text-end">Đơn giá (VNĐ) <span class="text-danger">*</span></th>
                            <th class="text-end">Thành tiền</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody id="chiTietContainer">
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="7" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold fs-5 text-primary" id="tongTienDisplay">0 đ</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="text-end mt-3">
                <button type="button" class="btn btn-success" onclick="submitForm()">
                    <i class="bi bi-check-circle me-1"></i> Lưu phiếu nhập
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        var rowCount = 0;

        var thuocOptions = '';
        @if (dsThuoc != null)
        {
            foreach (var t in dsThuoc)
            {
                <text>thuocOptions += '<option value="@t.MaThuoc" data-donvi="@t.DonViCoBan">@Html.Raw(System.Web.HttpUtility.HtmlEncode(t.TenThuoc)) (@t.DonViCoBan)</option>';</text>
            }
        }

        function buildThuocOptions() {
            return '<select name="MaThuoc__IDX__" class="form-select form-select-sm" required>' +
                   '<option value="">-- Chọn thuốc --</option>' + thuocOptions +
                   '</select>';
        }

        function addRow() {
            rowCount++;
            var idx = '_' + rowCount;
            var rowIndex = $('#chiTietContainer tr.ct-row').length + 1;
            var html = '<tr class="ct-row" id="row_' + rowCount + '">' +
                '<td class="text-center align-middle"><strong>' + rowIndex + '</strong></td>' +
                '<td>' + buildThuocOptions().replace(/__IDX__/g, idx) + '</td>' +
                '<td><input type="text" name="MaLo' + idx + '" class="form-control form-control-sm" placeholder="VD: LO001" /></td>' +
                '<td><input type="date" name="NgaySanXuat' + idx + '" class="form-control form-control-sm" /></td>' +
                '<td><input type="date" name="HanSuDung' + idx + '" class="form-control form-control-sm" required /></td>' +
                '<td><input type="number" name="SoLuong' + idx + '" class="form-control form-control-sm text-end" min="1" placeholder="0" oninput="updateTongTien()" required /></td>' +
                '<td><input type="number" name="DonGia' + idx + '" class="form-control form-control-sm text-end" min="0" step="100" placeholder="0" oninput="updateTongTien()" required /></td>' +
                '<td class="text-end fw-bold text-primary align-middle thanhTien">0 đ</td>' +
                '<td class="text-center align-middle">' +
                    '<button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(' + rowCount + ')">' +
                        '<i class="bi bi-trash"></i>' +
                    '</button>' +
                '</td>' +
                '</tr>';
            $('#chiTietContainer').append(html);
        }

        function removeRow(id) {
            $('#row_' + id).remove();
            updateSTT();
            updateTongTien();
        }

        function updateSTT() {
            $('#chiTietContainer tr.ct-row').each(function(i) {
                $(this).find('strong').first().text(i + 1);
            });
        }

        function updateTongTien() {
            var tong = 0;
            $('#chiTietContainer tr.ct-row').each(function() {
                var sl = parseFloat($(this).find('[name*="SoLuong"]').val()) || 0;
                var dg = parseFloat($(this).find('[name*="DonGia"]').val()) || 0;
                var tt = sl * dg;
                $(this).find('.thanhTien').text(tt.toLocaleString('vi-VN') + ' đ');
                tong += tt;
            });
            $('#tongTienDisplay').text(tong.toLocaleString('vi-VN') + ' đ');
        }

        function submitForm() {
            var container = document.getElementById('chiTietContainer');
            var rows = container.querySelectorAll('tr.ct-row');
            var valid = true;

            if (rows.length === 0) {
                alert('Vui lòng thêm ít nhất một dòng chi tiết!');
                return;
            }

            var maKho = document.querySelector('select[name="MaKho"]').value;
            if (!maKho) {
                alert('Vui lòng chọn kho nhập hàng!');
                return;
            }

            var maNCC = document.querySelector('select[name="MaNSX"]').value;
            if (!maNCC) {
                alert('Vui lòng chọn nhà cung cấp!');
                return;
            }

            rows.forEach(function(row) {
                var maThuoc = row.querySelector('select[name*="MaThuoc"]').value;
                var hanSD = row.querySelector('input[name*="HanSuDung"]').value;
                var soLuong = row.querySelector('input[name*="SoLuong"]').value;
                var donGia = row.querySelector('input[name*="DonGia"]').value;

                if (!maThuoc) { valid = false; alert('Vui lòng chọn thuốc!'); return; }
                if (!hanSD) { valid = false; alert('Vui lòng nhập hạn sử dụng!'); return; }
                if (!soLuong || parseFloat(soLuong) <= 0) { valid = false; alert('Số lượng phải lớn hơn 0!'); return; }
                if (!donGia || parseFloat(donGia) < 0) { valid = false; alert('Đơn giá không hợp lệ!'); return; }
            });

            if (valid) {
                document.getElementById('frmCreate').submit();
            }
        }

        $(document).ready(function() {
            addRow();
        });
    </script>
}
