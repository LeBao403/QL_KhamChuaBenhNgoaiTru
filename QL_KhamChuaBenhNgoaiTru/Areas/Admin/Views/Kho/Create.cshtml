@{
    ViewBag.Title = "Tạo phiếu nhập kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";

    var dsThuoc = ViewBag.DsThuoc as List<QL_KhamChuaBenhNgoaiTru.DBContext.ThuocItem>;
    var dsNCC = ViewBag.DsNhaCungCap as List<QL_KhamChuaBenhNgoaiTru.DBContext.NhaCungCapItem>;
    var dsPhong = ViewBag.DsPhong as List<QL_KhamChuaBenhNgoaiTru.DBContext.PhongItem>;
}

@section Styles {
    <style>
        .ct-row {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #e2e8f0;
            transition: border-color 0.2s;
        }
        .ct-row:hover {
            border-color: #3b82f6;
        }
        .table-container {
            max-height: 400px;
            overflow-y: auto;
        }
        .don-gia-input {
            max-width: 150px;
        }
    </style>
}

<!-- THÔNG BÁO -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- FORM TẠO PHIẾU NHẬP -->
<div class="row">
    <!-- Thông tin phiếu nhập -->
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-header bg-white" style="border-radius: 16px 16px 0 0; padding: 16px 20px;">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-file-earmark-plus text-primary me-2"></i>Thông tin phiếu nhập
                </h5>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Create", "Kho", FormMethod.Post, new { id = "frmPhieuNhap" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nhà cung cấp <span class="text-danger">*</span></label>
                        <select name="MaNSX" class="form-select" required>
                            <option value="">-- Chọn nhà cung cấp --</option>
                            @if (dsNCC != null)
                            {
                                foreach (var ncc in dsNCC)
                                {
                                    <option value="@ncc.MaNSX">@ncc.TenNSX</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ghi chú</label>
                        <textarea name="GhiChu" class="form-control" rows="3" placeholder="Thông tin bổ sung (nếu có)"></textarea>
                    </div>

                    <hr />

                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-list-ul text-secondary me-1"></i>Chi tiết thuốc nhập
                        <button type="button" class="btn btn-sm btn-outline-primary float-end" onclick="addRow()">
                            <i class="bi bi-plus"></i> Thêm dòng
                        </button>
                    </h6>

                    <div id="chiTietContainer" class="table-container">
                        <!-- Các dòng chi tiết sẽ được thêm vào đây bằng JS -->
                    </div>

                    <div class="d-none" id="templateRow">
                        <div class="ct-row" id="row_template">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong class="text-muted" style="font-size: 12px;">#</strong>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="removeRow('row_template')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small">Thuốc</label>
                                    <select name="MaThuoc_template" class="form-select form-select-sm" onchange="onThuocChange(this)" required>
                                        <option value="">-- Chọn thuốc --</option>
                                        @if (dsThuoc != null)
                                        {
                                            foreach (var t in dsThuoc)
                                            {
                                                <option value="@t.MaThuoc" data-donvi="@t.DonViCoBan">@t.TenThuoc (@t.MaThuoc)</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">Số lô</label>
                                    <input type="text" name="MaLo_template" class="form-control form-control-sm" placeholder="Số lô" required />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Ngày SX</label>
                                    <input type="date" name="NgaySanXuat_template" class="form-control form-control-sm" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Hạn SD <span class="text-danger">*</span></label>
                                    <input type="date" name="HanSuDung_template" class="form-control form-control-sm" required />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Đơn vị</label>
                                    <input type="text" class="form-control form-control-sm" id="donvi_template" readonly />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Số lượng <span class="text-danger">*</span></label>
                                    <input type="number" name="SoLuong_template" class="form-control form-control-sm" min="1" value="1" onchange="calcThanhTien(this)" required />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Đơn giá <span class="text-danger">*</span></label>
                                    <input type="number" name="DonGia_template" class="form-control form-control-sm" min="0" step="100" onchange="calcThanhTien(this)" required />
                                </div>
                                <div class="col-4">
                                    <label class="form-label small">Thành tiền</label>
                                    <input type="text" class="form-control form-control-sm bg-light" id="thanhtien_template" readonly />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 p-3 bg-primary bg-opacity-10 rounded-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Tổng tiền:</span>
                            <h4 class="mb-0 text-primary fw-bold" id="lblTongTien">0 đ</h4>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer bg-white" style="border-radius: 0 0 16px 16px;">
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Index", "Kho")" class="btn btn-secondary flex-fill">
                        <i class="bi bi-x-circle me-1"></i>Hủy
                    </a>
                    <button type="submit" form="frmPhieuNhap" class="btn btn-primary flex-fill">
                        <i class="bi bi-check-circle me-1"></i>Tạo phiếu nhập
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Hướng dẫn -->
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-header bg-white" style="border-radius: 16px 16px 0 0; padding: 16px 20px;">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-info-circle text-info me-2"></i>Hướng dẫn tạo phiếu nhập kho
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 24px; font-size: 14px;">1</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Chọn nhà cung cấp</h6>
                                <p class="text-muted small mb-0">Chọn nhà cung cấp (nhà sản xuất) từ danh sách đã có trong hệ thống.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 24px; font-size: 14px;">2</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Thêm chi tiết thuốc</h6>
                                <p class="text-muted small mb-0">Nhấn "Thêm dòng" để thêm từng thuốc cần nhập, điền đầy đủ thông tin lô, hạn dùng.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 24px; font-size: 14px;">3</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Nhập số lượng & đơn giá</h6>
                                <p class="text-muted small mb-0">Số lượng tính theo đơn vị cơ bản (viên, chai, lọ...). Đơn giá nhập cho mỗi đơn vị.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <div class="flex-shrink-0">
                                <span class="badge bg-primary rounded-circle" style="width: 32px; height: 32px; line-height: 24px; font-size: 14px;">4</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Chờ duyệt</h6>
                                <p class="text-muted small mb-0">Sau khi tạo, phiếu sẽ có trạng thái "Chờ duyệt". Quản lý sẽ duyệt để nhập kho thực tế.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>Lưu ý:</strong> Phiếu nhập kho sau khi tạo sẽ ở trạng thái <strong>"Chờ duyệt"</strong>.
                    Vui lòng liên hệ Quản lý để duyệt phiếu và cập nhật số lượng vào kho.
                </div>
            </div>
        </div>

        <!-- Preview -->
        <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px;">
            <div class="card-header bg-white" style="border-radius: 16px 16px 0 0; padding: 16px 20px;">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-eye text-secondary me-2"></i>Xem trước phiếu nhập
                </h5>
            </div>
            <div class="card-body">
                <table class="table table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Mã thuốc</th>
                            <th>Tên thuốc</th>
                            <th>Số lô</th>
                            <th>Hạn SD</th>
                            <th class="text-end">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="previewBody">
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-clipboard" style="font-size: 32px; opacity: 0.3;"></i>
                                <p class="mb-0 mt-2">Chưa có thuốc nào được thêm</p>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr class="table-primary">
                            <td colspan="7" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold" id="previewTongTien">0 đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let rowCount = 0;
        const ThuocList = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(dsThuoc != null ? dsThuoc.Select(x => new { x.MaThuoc, x.TenThuoc, x.DonViCoBan }).ToList() : new List<object>()));

        function addRow() {
            rowCount++;
            var html = $('#templateRow').html();
            html = html.replace(/_template/g, '_' + rowCount);
            html = html.replace(/id="row_template"/g, 'id="row_' + rowCount + '"');
            html = html.replace(/"#"/g, '"#' + rowCount + '"');
            html = '<div id="ct_row_' + rowCount + '">' + html + '</div>';
            $('#chiTietContainer').append(html);

            // Đánh số thứ tự
            updateRowNumbers();
        }

        function removeRow(id) {
            $('#ct_' + id).remove();
            updateRowNumbers();
            updatePreview();
            updateTongTien();
        }

        function updateRowNumbers() {
            $('#chiTietContainer .ct-row').each(function (i) {
                $(this).find('strong').first().text('#' + (i + 1));
            });
        }

        function onThuocChange(el) {
            var id = el.id.replace('MaThuoc_', '');
            var selected = el.options[el.selectedIndex];
            var donVi = selected.getAttribute('data-donvi') || '';
            $('#donvi_' + id).val(donVi);
            updatePreview();
        }

        function calcThanhTien(el) {
            var id = el.name.replace('SoLuong_', '').replace('DonGia_', '');
            var soLuong = parseFloat($('input[name="SoLuong_' + id + '"]').val()) || 0;
            var donGia = parseFloat($('input[name="DonGia_' + id + '"]').val()) || 0;
            var thanhTien = soLuong * donGia;
            $('#thanhtien_' + id).val(thanhTien.toLocaleString('vi-VN') + ' đ');
            updatePreview();
            updateTongTien();
        }

        function updatePreview() {
            var tbody = $('#previewBody');
            tbody.empty();

            var rows = [];
            $('#chiTietContainer .ct-row').each(function () {
                var id = $(this).attr('id').replace('ct_row_', '');
                var maThuoc = $('select[name="MaThuoc_' + id + '"]').val();
                if (!maThuoc) return;

                var tenThuoc = $('select[name="MaThuoc_' + id + '"] option:selected').text().split('(')[0].trim();
                var maLo = $('input[name="MaLo_' + id + '"]').val() || '';
                var hanSD = $('input[name="HanSuDung_' + id + '"]').val() || '';
                var soLuong = parseFloat($('input[name="SoLuong_' + id + '"]').val()) || 0;
                var donGia = parseFloat($('input[name="DonGia_' + id + '"]').val()) || 0;
                var thanhTien = soLuong * donGia;

                rows.push({
                    maThuoc: maThuoc,
                    tenThuoc: tenThuoc,
                    maLo: maLo,
                    hanSD: hanSD,
                    soLuong: soLuong,
                    donGia: donGia,
                    thanhTien: thanhTien
                });
            });

            if (rows.length === 0) {
                tbody.html('<tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-clipboard" style="font-size: 32px; opacity: 0.3;"></i><p class="mb-0 mt-2">Chưa có thuốc nào được thêm</p></td></tr>');
                return;
            }

            rows.forEach(function (r, i) {
                tbody.append('<tr>' +
                    '<td>' + (i + 1) + '</td>' +
                    '<td><code>' + r.maThuoc + '</code></td>' +
                    '<td>' + r.tenThuoc + '</td>' +
                    '<td>' + r.maLo + '</td>' +
                    '<td>' + r.hanSD + '</td>' +
                    '<td class="text-end">' + r.soLuong.toLocaleString('vi-VN') + '</td>' +
                    '<td class="text-end">' + r.donGia.toLocaleString('vi-VN') + ' đ</td>' +
                    '<td class="text-end fw-semibold">' + r.thanhTien.toLocaleString('vi-VN') + ' đ</td>' +
                    '</tr>');
            });
        }

        function updateTongTien() {
            var total = 0;
            $('#chiTietContainer .ct-row').each(function () {
                var id = $(this).attr('id').replace('ct_row_', '');
                var soLuong = parseFloat($('input[name="SoLuong_' + id + '"]').val()) || 0;
                var donGia = parseFloat($('input[name="DonGia_' + id + '"]').val()) || 0;
                total += soLuong * donGia;
            });
            $('#lblTongTien').text(total.toLocaleString('vi-VN') + ' đ');
            $('#previewTongTien').text(total.toLocaleString('vi-VN') + ' đ');
        }

        // Validate form
        $('#frmPhieuNhap').on('submit', function () {
            if (rowCount === 0) {
                alert('Vui lòng thêm ít nhất 1 thuốc vào phiếu nhập!');
                return false;
            }

            var hasValidRow = false;
            $('#chiTietContainer .ct-row').each(function () {
                var id = $(this).attr('id').replace('ct_row_', '');
                var maThuoc = $('select[name="MaThuoc_' + id + '"]').val();
                if (maThuoc) hasValidRow = true;
            });

            if (!hasValidRow) {
                alert('Vui lòng thêm ít nhất 1 thuốc vào phiếu nhập!');
                return false;
            }

            return true;
        });
    </script>
}
