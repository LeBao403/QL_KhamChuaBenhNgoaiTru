@{
    ViewBag.Title = "Kho Dược - Vật tư";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";

    var tongQuan = ViewBag.TongQuan as QL_KhamChuaBenhNgoaiTru.DBContext.KhoTongQuan;
    var dsTonKho = ViewBag.DsTonKho as List<QL_KhamChuaBenhNgoaiTru.DBContext.TonKhoViewModel>;
    var dsKho = ViewBag.DsKho as List<QL_KhamChuaBenhNgoaiTru.DBContext.KhoItem>;

    int page = ViewBag.Page;
    int pageSize = ViewBag.PageSize;
    int totalCount = ViewBag.TotalCount;
    int totalPages = ViewBag.TotalPages;
}

<!-- CSS riêng -->
@section Styles {
    <style>
        .stat-mini {
            border-radius: 12px;
            padding: 16px;
            background: white;
            border: 1px solid #e2e8f0;
        }

        .stat-mini .number {
            font-size: 22px;
            font-weight: 800;
            line-height: 1;
        }

        .stat-mini .label {
            font-size: 12px;
            color: #64748b;
            margin-top: 4px;
        }

        .filter-section {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 20px;
        }

        .badge-hsd {
            font-size: 11px;
            padding: 4px 8px;
            border-radius: 6px;
        }

        .table-modern tbody tr:hover {
            background-color: #f8fafc;
        }

        .quick-actions .btn {
            border-radius: 10px;
            padding: 10px 16px;
        }

        .pagination-custom .page-link {
            border-radius: 8px;
            margin: 0 2px;
            border: none;
            color: #475569;
        }

        .pagination-custom .page-item.active .page-link {
            background-color: #3b82f6;
            color: white;
        }

        .alert-canh-bao {
            border-radius: 12px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .trang-thai-badge {
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
        }
    </style>
}

<!-- ===================== THÔNG BÁO ===================== -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ===================== 1. TỔNG QUAN ===================== -->
<div class="row g-3 mb-4">
    <div class="col-xl-2 col-md-4 col-6">
        <div class="stat-mini">
            <div class="number" style="color: #2563eb;">@(tongQuan?.SoKho.ToString("N0") ?? "0")</div>
            <div class="label">Kho / Nhà thuốc</div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="stat-mini">
            <div class="number" style="color: #d97706;">@(tongQuan?.TongSoLuongTon.ToString("N0") ?? "0")</div>
            <div class="label">Tổng số lượng</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 col-6">
        <div class="stat-mini">
            <div class="number" style="color: #059669;">@(tongQuan?.TongGiaTriTon.ToString("N0") ?? "0")</div>
            <div class="label">Giá trị tồn kho (VNĐ)</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-12">
        <div class="row g-2 h-100">
            <div class="col-6">
                @if (tongQuan?.SoHetHan > 0)
                {
                    <div class="alert-canh-bao alert-warning h-100 mb-0" style="background: #fef3c7;">
                        <i class="bi bi-clock-history text-warning fs-5"></i>
                        <div>
                            <strong class="d-block">@tongQuan.SoHetHan</strong>
                            <small class="text-muted">Sắp hết hạn</small>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert-canh-bao h-100 mb-0" style="background: #f0fdf4; border: 1px solid #bbf7d0;">
                        <i class="bi bi-check-circle text-success fs-5"></i>
                        <div>
                            <strong class="d-block text-success">0</strong>
                            <small class="text-muted">Hết hạn</small>
                        </div>
                    </div>
                }
            </div>
            <div class="col-6">
                @if (tongQuan?.SoItHang > 0)
                {
                    <div class="alert-canh-bao alert-danger h-100 mb-0" style="background: #fef2f2;">
                        <i class="bi bi-box-seam text-danger fs-5"></i>
                        <div>
                            <strong class="d-block">@tongQuan.SoItHang</strong>
                            <small class="text-muted">Sắp hết hàng</small>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert-canh-bao h-100 mb-0" style="background: #f0fdf4; border: 1px solid #bbf7d0;">
                        <i class="bi bi-check-circle text-success fs-5"></i>
                        <div>
                            <strong class="d-block text-success">0</strong>
                            <small class="text-muted">Hết hàng</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ===================== 2. HÀNH ĐỘNG NHANH ===================== -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-box-seam-fill text-primary me-2"></i>Danh sách tồn kho
    </h5>
    <div class="quick-actions d-flex gap-2">
        <a href="@Url.Action("DanhSachPhieuNhap", "Kho")" class="btn btn-outline-secondary">
            <i class="bi bi-file-earmark-text me-1"></i>Danh sách phiếu nhập
        </a>
    </div>
</div>

<!-- ===================== 3. BỘ LỌC ===================== -->
<div class="filter-section" id="filterSection">
    <form id="filterForm" method="get" action="@Url.Action("Index", "Kho")">
        <input type="hidden" name="page" id="hdnPage" value="1" />

        <div class="row g-3">
            <div class="col-xl-4 col-md-6">
                <label class="form-label small fw-semibold">Tìm kiếm</label>
                <input type="text" name="keyword" class="form-control" placeholder="Tên thuốc, mã thuốc, số lô..." value="@ViewBag.Keyword" />
            </div>
            <div class="col-xl-2 col-md-3">
                <label class="form-label small fw-semibold">Kho</label>
                <select name="maKho" class="form-select" id="ddlKho">
                    <option value="">-- Tất cả kho --</option>
                    @if (dsKho != null)
                    {
                        foreach (var k in dsKho)
                        {
                            <option value="@k.MaKho" @(ViewBag.MaKho == k.MaKho.ToString() ? "selected" : "")>@k.TenKho</option>
                        }
                    }
                </select>
            </div>
            <div class="col-xl-3 col-md-3">
                <label class="form-label small fw-semibold">Trạng thái tồn kho</label>
                <select name="trangThaiTon" class="form-select" id="ddlTrangThaiTon">
                    <option value="">-- Tất cả --</option>
                    <option value="con_han" @(ViewBag.TrangThaiTon == "con_han" ? "selected" : "")>Còn hạn / Còn hàng</option>
                    <option value="sap_het_han" @(ViewBag.TrangThaiTon == "sap_het_han" ? "selected" : "")>Sắp hết hạn (&lt;30 ngày)</option>
                    <option value="het_han" @(ViewBag.TrangThaiTon == "het_han" ? "selected" : "")>Đã hết hạn</option>
                    <option value="sap_het_hang" @(ViewBag.TrangThaiTon == "sap_het_hang" ? "selected" : "")>Sắp hết hàng (&lt;10)</option>
                </select>
            </div>
            <div class="col-xl-2 col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-search me-1"></i>Lọc
                </button>
                <a href="@Url.Action("Index", "Kho")" class="btn btn-outline-secondary" title="Xóa lọc">
                    <i class="bi bi-x-circle"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- ===================== 4. BẢNG DỮ LIỆU ===================== -->
<div class="card border-0 shadow-sm" style="border-radius: 16px;">
    <div class="card-body p-0">
        <div class="table-responsive" id="tableContainer">
            <table class="table table-modern table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th>Mã thuốc</th>
                        <th>Tên thuốc</th>
                        <th>Số lô</th>
                        <th>Hạn sử dụng</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Giá trị tồn</th>
                        <th>Kho</th>
                        <th class="text-center">Trạng thái</th>
                        <th style="width: 80px;"></th>
                    </tr>
                </thead>
                <tbody id="tbodyTonKho">
                    @if (dsTonKho == null || dsTonKho.Count == 0)
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="bi bi-inbox" style="font-size: 48px; opacity: 0.3;"></i>
                                <p class="mt-2 mb-0">Không có dữ liệu tồn kho</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        int stt = (page - 1) * pageSize + 1;
                        foreach (var item in dsTonKho)
                        {
                            // Badge trạng thái HSD
                            string hsdBadge = item.TrangThaiHSD switch
                            {
                                "hết_han" => "bg-danger",
                                "sap_het" => "bg-warning text-dark",
                                _ => "bg-success"
                            };
                            string hsdText = item.TrangThaiHSD switch
                            {
                                "hết_han" => "Hết hạn",
                                "sap_het" => $"{item.SoNgayConLai} ngày",
                                _ => "Còn hạn"
                            };

                            // Badge trạng thái tồn kho
                            string tonBadge = item.TrangThaiTonKho switch
                            {
                                "het_hang" => "bg-secondary",
                                "sap_het_hang" => "bg-danger",
                                _ => "bg-info"
                            };
                            string tonText = item.TrangThaiTonKho switch
                            {
                                "het_hang" => "Hết hàng",
                                "sap_het_hang" => $"{item.SoLuongTon} {item.DonViCoBan}",
                                _ => $"{item.SoLuongTon} {item.DonViCoBan}"
                            };

                            <tr>
                                <td class="text-center text-muted">@stt</td>
                                <td><code>@item.MaThuoc</code></td>
                                <td>
                                    <div class="fw-semibold">@item.TenThuoc</div>
                                    <small class="text-muted">@item.DonViCoBan</small>
                                </td>
                                <td><code>@item.MaLo</code></td>
                                <td>
                                    <span class="badge @hsdBadge badge-hsd">@hsdText</span>
                                    <div class="small text-muted">@item.HanSuDungDisplay</div>
                                </td>
                                <td class="text-center">
                                    <strong>@item.SoLuongTon.ToString("N0")</strong>
                                    <div class="small text-muted">@item.DonViCoBan</div>
                                </td>
                                <td class="text-end fw-semibold">@item.GiaTriTon.ToString("N0") đ</td>
                                <td><span class="badge bg-primary">@item.TenKho</span></td>
                                <td class="text-center">
                                    @if (item.CoBHYT)
                                    {
                                        <span class="badge bg-primary badge-hsd">BHYT</span>
                                    }
                                    <span class="badge @tonBadge badge-hsd">@tonText</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="showEditSoLuong(@item.MaTonKho, @item.SoLuongTon)" title="Sửa số lượng">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- ===================== PHÂN TRANG ===================== -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                <div class="small text-muted">
                    Hiển thị @(((page - 1) * pageSize) + 1) - @Math.Min(page * pageSize, totalCount) trong @totalCount kết quả
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-custom mb-0">
                        @if (page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="#" onclick="goToPage(@(page - 1)); return false;">&laquo;</a>
                            </li>
                        }

                        @{
                            int startPage = Math.Max(1, page - 2);
                            int endPage = Math.Min(totalPages, page + 2);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == page ? "active" : "")">
                                <a class="page-link" href="#" onclick="goToPage(@i); return false;">@i</a>
                            </li>
                        }

                        @if (page < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="#" onclick="goToPage(@(page + 1)); return false;">&raquo;</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- ===================== MODAL SỬA SỐ LƯỢNG ===================== -->
<div class="modal fade" id="modalEditSoLuong" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square text-primary me-2"></i>Cập nhật số lượng tồn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hdnMaTonKho" />
                <div class="mb-3">
                    <label class="form-label">Số lượng mới</label>
                    <input type="number" id="txtSoLuongMoi" class="form-control" min="0" value="0" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" onclick="saveSoLuong()">
                    <i class="bi bi-check me-1"></i>Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
@section Scripts {
    <script>
        // Phân trang
        function goToPage(p) {
            $('#hdnPage').val(p);
            $('#filterForm').submit();
        }

        // Sửa số lượng
        let editModal;
        $(document).ready(function () {
            editModal = new bootstrap.Modal(document.getElementById('modalEditSoLuong'));
        });

        function showEditSoLuong(maTonKho, soLuongHienTai) {
            $('#hdnMaTonKho').val(maTonKho);
            $('#txtSoLuongMoi').val(soLuongHienTai);
            editModal.show();
        }

        function saveSoLuong() {
            var maTonKho = $('#hdnMaTonKho').val();
            var soLuongMoi = parseInt($('#txtSoLuongMoi').val());

            if (isNaN(soLuongMoi) || soLuongMoi < 0) {
                alert('Số lượng không hợp lệ!');
                return;
            }

            $.ajax({
                url: '@Url.Action("CapNhatSoLuong", "Kho")',
                type: 'POST',
                data: { maTonKho: maTonKho, soLuongMoi: soLuongMoi },
                success: function (res) {
                    if (res.success) {
                        editModal.hide();
                        location.reload();
                    } else {
                        alert('Lỗi: ' + res.message);
                    }
                },
                error: function () {
                    alert('Đã xảy ra lỗi khi lưu!');
                }
            });
        }
    </script>
}
