@{
    ViewBag.Title = "Danh sách phiếu nhập kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";

    var dsPhieuNhap = ViewBag.DsPhieuNhap as List<QL_KhamChuaBenhNgoaiTru.DBContext.PhieuNhapViewModel>;
    int page = ViewBag.Page;
    int pageSize = ViewBag.PageSize;
    int totalCount = ViewBag.TotalCount;
    int totalPages = ViewBag.TotalPages;
}

<!-- CSS riêng -->
@section Styles {
    <style>
        .filter-section {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 20px;
        }
        .badge-trangthai {
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
        }
        .table-modern tbody tr:hover {
            background-color: #f8fafc;
        }
        .pagination-custom .page-link {
            border-radius: 8px;
            margin: 0 2px;
            border: none;
            color: #475569;
        }
        .pagination-custom .page-item.active .page-link {
            background-color: #3b82f6;
            color: white;
        }
    </style>
}

<!-- Thông báo -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ===================== 1. TIÊU ĐỀ ===================== -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-file-earmark-text text-primary me-2"></i>Danh sách phiếu nhập kho
    </h5>
    <a href="@Url.Action("Create", "Kho")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Tạo phiếu nhập mới
    </a>
</div>

<!-- ===================== 2. BỘ LỌC ===================== -->
<div class="filter-section" id="filterSection">
    <form id="filterForm" method="get" action="@Url.Action("DanhSachPhieuNhap", "Kho")">
        <input type="hidden" name="page" id="hdnPage" value="1" />

        <div class="row g-3">
            <div class="col-xl-6 col-md-6">
                <label class="form-label small fw-semibold">Tìm kiếm</label>
                <input type="text" name="keyword" class="form-control" placeholder="Mã phiếu, nhà cung cấp..." value="@ViewBag.Keyword" />
            </div>
            <div class="col-xl-3 col-md-3">
                <label class="form-label small fw-semibold">Trạng thái</label>
                <select name="trangThai" class="form-select" id="ddlTrangThai">
                    <option value="">-- Tất cả --</option>
                    <option value="Chờ duyệt" @(ViewBag.TrangThai == "Chờ duyệt" ? "selected" : "")>Chờ duyệt</option>
                    <option value="Đã duyệt" @(ViewBag.TrangThai == "Đã duyệt" ? "selected" : "")>Đã duyệt</option>
                    <option value="Đã hủy" @(ViewBag.TrangThai == "Đã hủy" ? "selected" : "")>Đã hủy</option>
                </select>
            </div>
            <div class="col-xl-3 col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-search me-1"></i>Lọc
                </button>
                <a href="@Url.Action("DanhSachPhieuNhap", "Kho")" class="btn btn-outline-secondary" title="Xóa lọc">
                    <i class="bi bi-x-circle"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- ===================== 3. BẢNG DỮ LIỆU ===================== -->
<div class="card border-0 shadow-sm" style="border-radius: 16px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-modern table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>Mã phiếu</th>
                        <th>Ngày lập</th>
                        <th>Nhà cung cấp</th>
                        <th>Người lập</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th style="width: 100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (dsPhieuNhap == null || dsPhieuNhap.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-inbox" style="font-size: 48px; opacity: 0.3;"></i>
                                <p class="mt-2 mb-0">Không có phiếu nhập nào</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        int stt = (page - 1) * pageSize + 1;
                        foreach (var item in dsPhieuNhap)
                        {
                            string badgeClass = item.TrangThai switch
                            {
                                "Chờ duyệt" => "bg-warning text-dark",
                                "Đã duyệt" => "bg-success",
                                "Đã hủy" => "bg-secondary",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td class="text-center text-muted">@stt</td>
                                <td><strong>#@item.MaPhieuNhap</strong></td>
                                <td>
                                    <div>@item.NgayLapDisplay</div>
                                    @if (!string.IsNullOrEmpty(item.TenNguoiDuyet))
                                    {
                                        <small class="text-muted">Duyệt bởi @item.TenNguoiDuyet</small>
                                    }
                                </td>
                                <td class="text-truncate" style="max-width: 150px;">@item.TenNSX</td>
                                <td>@item.TenNguoiLap</td>
                                <td class="text-end fw-bold">@item.TongTienNhap.ToString("N0") đ</td>
                                <td class="text-center">
                                    <span class="badge @badgeClass badge-trangthai">@item.TrangThai</span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("ChiTietPhieuNhap", "Kho", new { id = item.MaPhieuNhap })" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- ===================== PHÂN TRANG ===================== -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                <div class="small text-muted">
                    Hiển thị @(((page - 1) * pageSize) + 1) - @Math.Min(page * pageSize, totalCount) trong @totalCount kết quả
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-custom mb-0">
                        @if (page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="#" onclick="goToPage(@(page - 1)); return false;">&laquo;</a>
                            </li>
                        }

                        @{
                            int startPage = Math.Max(1, page - 2);
                            int endPage = Math.Min(totalPages, page + 2);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == page ? "active" : "")">
                                <a class="page-link" href="#" onclick="goToPage(@i); return false;">@i</a>
                            </li>
                        }

                        @if (page < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="#" onclick="goToPage(@(page + 1)); return false;">&raquo;</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function goToPage(p) {
            $('#hdnPage').val(p);
            $('#filterForm').submit();
        }
    </script>
}
