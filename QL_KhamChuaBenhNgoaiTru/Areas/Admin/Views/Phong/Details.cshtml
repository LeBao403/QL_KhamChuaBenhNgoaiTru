@model QL_KhamChuaBenhNgoaiTru.Models.PhongDetailsViewModel

@{
    ViewBag.Title = "Chi tiết Phòng - " + Model.Phong.TenPhong;
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary mb-1">
                <i class="bi bi-door-open me-2"></i>@Model.Phong.TenPhong
            </h3>
            <div class="text-muted">
                <span class="me-3">Mã Phòng: <strong class="text-dark">PH-@Model.Phong.MaPhong.ToString("D3")</strong></span>
                @if (Model.Phong.TrangThai)
                {
                    <span class="badge bg-success">Đang mở cửa</span>
                }
                else
                {
                    <span class="badge bg-danger">Đã đóng cửa</span>
                }
            </div>
        </div>
        <div>
            <a href="@Url.Action("Index", "Phong", new { area = "Admin" })" class="btn btn-secondary me-2">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a href="@Url.Action("Edit", "Phong", new { area = "Admin", id = Model.Phong.MaPhong })" class="btn btn-warning">
                <i class="bi bi-pencil-square me-1 text-white"></i> <span class="text-white">Chỉnh sửa</span>
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 text-dark fw-bold"><i class="bi bi-info-circle text-primary me-2"></i>Thông tin chung</h5>
        </div>
        <div class="card-body">
            <div class="row text-center text-md-start">
                <div class="col-md-4 border-end">
                    <span class="text-muted d-block mb-1">Loại phòng:</span>
                    <span class="fw-bold text-dark fs-5">@Model.Phong.TenLoaiPhong</span>
                </div>
                <div class="col-md-4 border-end">
                    <span class="text-muted d-block mb-1">Khoa chủ quản:</span>
                    @if (Model.Phong.MaKhoa.HasValue)
                    {
                        <span class="fw-bold text-primary fs-5">@Model.Phong.TenKhoa</span>
                    }
                    else
                    {
                        <span class="fst-italic text-muted fs-5">Độc lập (Không thuộc khoa)</span>
                    }
                </div>
                <div class="col-md-4">
                    <span class="text-muted d-block mb-1">Số lượng nhân sự:</span>
                    <span class="badge bg-info text-dark rounded-pill fs-6 px-3">@Model.DanhSachNhanVien.Count người</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark fw-bold"><i class="bi bi-person-lines-fill text-success me-2"></i>Nhân sự trực thuộc</h5>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAddNhanVien">
                <i class="bi bi-person-plus-fill me-1"></i> Thêm nhân sự
            </button>
        </div>

        <div class="card-body bg-light border-bottom py-3">
            <div class="input-group" style="max-width: 400px;">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" id="searchNhanVien" class="form-control" placeholder="Tìm nhân viên trong phòng...">
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped align-middle mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th class="ps-4" style="width: 120px;">Mã NV</th>
                            <th>Họ và Tên</th>
                            <th>Chức vụ</th>
                            <th>Liên hệ</th>
                            <th class="text-center" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyNhanVien">
                        @if (Model.DanhSachNhanVien.Count > 0)
                        {
                            foreach (var nv in Model.DanhSachNhanVien)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@nv.MaNV</strong></td>
                                    <td class="fw-bold text-dark">
                                        <a href="@Url.Action("Details", "NhanVien", new { area = "Admin", id = nv.MaNV.Trim() })" class="text-decoration-none text-primary" title="Xem hồ sơ">
                                            @nv.HoTen
                                        </a>
                                        <div class="small fw-normal text-muted mt-1">@nv.GioiTinh</div>
                                    </td>
                                    <td><span class="badge bg-secondary">@nv.TenChucVu</span></td>
                                    <td>
                                        <div class="small"><i class="bi bi-telephone text-muted me-1"></i> @nv.SDT</div>
                                    </td>
                                    <td class="text-center">
                                        <form method="post" action="@Url.Action("RemoveNhanVien", "Phong", new { area = "Admin" })" class="m-0 p-0 form-remove-nv">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maNV" value="@nv.MaNV" />
                                            <input type="hidden" name="maPhong" value="@Model.Phong.MaPhong" />
                                            <button type="button" class="btn btn-sm btn-danger btn-remove" title="Rút khỏi phòng">
                                                <i class="bi bi-person-dash me-1"></i> Xóa khỏi phòng
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-person-x fs-2 d-block mb-3 text-secondary"></i>
                                    <h5>Chưa có nhân sự</h5>
                                    <p class="mb-0">Phòng này hiện chưa có nhân sự nào trực thuộc. Bấm "Thêm nhân sự" để phân bổ.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAddNhanVien" tabindex="-1" aria-labelledby="modalAddNhanVienLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="modalAddNhanVienLabel">
                    <i class="bi bi-person-plus-fill me-2"></i> Phân bổ nhân sự vào phòng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-3 bg-light border-bottom">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchKhaDung" class="form-control" placeholder="Tìm kiếm nhân viên khả dụng...">
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-light position-sticky top-0 shadow-sm" style="z-index: 1;">
                            <tr>
                                <th class="ps-3" style="width: 100px;">Mã NV</th>
                                <th>Họ và Tên</th>
                                <th>Chức vụ</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyKhaDung">
                            @if (Model.DanhSachNhanVienKhaDung.Count > 0)
                            {
                                foreach (var nv in Model.DanhSachNhanVienKhaDung)
                                {
                                    <tr>
                                        <td class="ps-3"><strong>@nv.MaNV</strong></td>
                                        <td class="fw-bold text-dark">@nv.HoTen</td>
                                        <td><span class="badge bg-secondary">@nv.TenChucVu</span></td>
                                        <td class="text-center">
                                            <form method="post" action="@Url.Action("AddNhanVien", "Phong", new { area = "Admin" })" class="m-0 p-0 form-add-nv">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="maNV" value="@nv.MaNV" />
                                                <input type="hidden" name="maPhong" value="@Model.Phong.MaPhong" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-plus-circle me-1"></i> Thêm
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        Không có nhân viên nào (cùng khoa) đang rảnh để thêm vào phòng này.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // 1. JS Lọc cho Bảng Nhân sự đang ở trong phòng
            $("#searchNhanVien").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#tbodyNhanVien tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // 2. JS Lọc cho Bảng Modal (Nhân sự khả dụng)
            $("#searchKhaDung").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#tbodyKhaDung tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // 3. Cảnh báo SweetAlert2 khi Rút nhân sự khỏi phòng
            $('.btn-remove').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');

                Swal.fire({
                    title: 'Rút nhân sự?',
                    text: "Nhân viên này sẽ được đưa ra khỏi phòng và trở về trạng thái chưa phân bổ.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý rút',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) form.submit();
                });
            });

            // 4. Đóng Modal mượt mà khi bấm Thêm
            $('.form-add-nv').on('submit', function () {
                var myModalEl = document.getElementById('modalAddNhanVien');
                var modal = bootstrap.Modal.getInstance(myModalEl);
                if (modal) {
                    modal.hide();
                }
            });
        });
    </script>
}