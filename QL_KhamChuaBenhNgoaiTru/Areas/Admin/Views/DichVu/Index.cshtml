@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.DichVuViewModel>
@using QL_KhamChuaBenhNgoaiTru.Models
@{
    ViewBag.Title = "Quản lý Dịch vụ Viện phí";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_admin.cshtml";
    var listLoai = ViewBag.ListLoaiDV as List<QL_KhamChuaBenhNgoaiTru.Models.LoaiDichVu>;
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary fw-bold">
                <i class="bi bi-clipboard2-pulse me-2"></i> Danh sách Dịch vụ
            </h4>
            <a href="@Url.Action("Create", "DichVu", new { area = "Admin" })" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Thêm Dịch vụ
            </a>
        </div>

        <div class="card-body">
            @* --- Thống kê nhanh --- *@
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white border-0 shadow-sm rounded-3">
                        <div class="card-body d-flex align-items-center p-2 px-3">
                            <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                <i class="bi bi-clipboard-data fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-white-50 fw-bold text-uppercase" style="font-size: 0.7rem;">Tổng số kết quả</p>
                                <h5 class="mb-0 fw-bold">@ViewBag.TotalCount <span class="fw-normal" style="font-size: 0.8rem;">dịch vụ</span></h5>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-success text-white border-0 shadow-sm rounded-3">
                        <div class="card-body d-flex align-items-center p-2 px-3">
                            <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                <i class="bi bi-shield-check fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-white-50 fw-bold text-uppercase" style="font-size: 0.7rem;">Hỗ trợ BHYT (Trang này)</p>
                                <h5 class="mb-0 fw-bold">@Model.Count(x => x.CoBHYT) / @Model.Count()</h5>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-warning text-dark border-0 shadow-sm rounded-3">
                        <div class="card-body d-flex align-items-center p-2 px-3">
                            <div class="bg-white bg-opacity-50 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                <i class="bi bi-cash-coin fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-dark opacity-75 fw-bold text-uppercase" style="font-size: 0.7rem;">Giá TB (Trang này)</p>
                                <h5 class="mb-0 fw-bold">@(Model.Any() ? Model.Average(x => x.GiaDichVu).ToString("N0") : "0") <span class="fw-normal" style="font-size: 0.8rem;">đ</span></h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* --- Bộ lọc --- *@
            <form method="get" action="@Url.Action("Index", "DichVu", new { area = "Admin" })" id="filterForm" class="bg-light p-3 rounded-3 mb-4 border">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted">Tìm kiếm nhanh</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="keyword" id="txtKeyword" value="@ViewBag.Keyword" class="form-control border-start-0 ps-0"
                                   data-url="@Url.Action("Search", "DichVu", new { area = "Admin" })" data-target="#dvResult"
                                   placeholder="Mã, tên dịch vụ...">
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted">Danh mục</label>
                        <select name="maLoai" id="cbMaLoai" class="form-select filter-trigger">
                            <option value="">-- Tất cả danh mục --</option>
                            @if (listLoai != null)
                            {
                                foreach (var l in listLoai)
                                {
                                    <option value="@l.MaLoaiDV" @(ViewBag.MaLoai == l.MaLoaiDV ? "selected" : "")>@l.TenLoaiDV</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold small text-muted">Khoảng giá (VNĐ)</label>
                        <div class="input-group">
                            <input type="number" name="minPrice" id="txtMin" value="@ViewBag.MinPrice" class="form-control filter-trigger" placeholder="Từ...">
                            <span class="input-group-text border-0 bg-transparent">-</span>
                            <input type="number" name="maxPrice" id="txtMax" value="@ViewBag.MaxPrice" class="form-control filter-trigger" placeholder="Đến...">
                        </div>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold small text-muted">Sắp xếp giá</label>
                        <select name="sortPrice" id="cbSort" class="form-select filter-trigger">
                            <option value="">Mới nhất</option>
                            <option value="asc" @(ViewBag.SortPrice == "asc" ? "selected" : "")>Thấp đến cao</option>
                            <option value="desc" @(ViewBag.SortPrice == "desc" ? "selected" : "")>Cao đến thấp</option>
                        </select>
                    </div>
                </div>
            </form>

            @* --- Bảng dữ liệu --- *@
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle bg-white">
                    <thead class="table-light">
                        <tr>
                            <th width="8%" class="text-center">Mã DV</th>
                            <th width="22%">Tên Dịch Vụ</th>
                            <th width="15%">Danh Mục</th>
                            <th width="15%" class="text-end">Giá Tiền</th>
                            <th width="15%" class="text-center">Hỗ trợ BHYT</th>
                            <th width="10%" class="text-center">Trạng thái</th>
                            <th width="15%" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="dvResult">
                        @Html.Partial("_DichVuTable", Model)
                    </tbody>
                </table>
            </div>

            @* --- Phân trang --- *@
            <div class="mt-4">
                @Html.Partial("~/Views/Shared/_Layout_Pagination.cshtml", new PagerViewModel
                {
                    Page = ViewBag.Page,
                    PageSize = ViewBag.PageSize,
                    TotalCount = ViewBag.TotalCount,
                    DisplayPages = 5,
                    ActionName = "Index",
                    RouteValues = new
                    {
                        area = "Admin",
                        keyword = ViewBag.Keyword,
                        maLoai = ViewBag.MaLoai,
                        minPrice = ViewBag.MinPrice,
                        maxPrice = ViewBag.MaxPrice,
                        sortPrice = ViewBag.SortPrice
                    }
                })
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {

            // 1. AJAX LIVE SEARCH
            function fireAjaxSearch() {
                var url = $('#txtKeyword').data('url');
                var target = $('#txtKeyword').data('target');

                var filterData = {
                    keyword: $('#txtKeyword').val(),
                    maLoai: $('#cbMaLoai').val(),
                    minPrice: $('#txtMin').val(),
                    maxPrice: $('#txtMax').val(),
                    sortPrice: $('#cbSort').val()
                };

                $(target).html('<tr><td colspan="7" class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Đang tìm kiếm...</p></td></tr>');

                $.ajax({
                    url: url,
                    type: 'GET',
                    data: filterData,
                    success: function (res) { $(target).html(res); },
                    error: function() { $(target).html('<tr><td colspan="7" class="text-center text-danger py-4">Lỗi kết nối máy chủ!</td></tr>'); }
                });
            }

            var typingTimer;
            $('#txtKeyword').on('input', function () {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(fireAjaxSearch, 400);
            });

            $('.filter-trigger').change(function() {
                $('#filterForm').submit();
            });

            // 2. XÓA VĨNH VIỄN (Ajax xử lý) 
            $('#dvResult').on('click', '.btn-delete-dv', function (e) {
                e.preventDefault();
                // Lấy mã DV từ thuộc tính data-id của chính nút bấm
                var maDV = $(this).data('id');

                Swal.fire({
                    title: 'Xác nhận xóa vĩnh viễn?',
                    text: "Hệ thống sẽ xóa hẳn nếu dịch vụ chưa từng phát sinh hóa đơn. Hành động này không thể hoàn tác!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="bi bi-trash"></i> Xóa ngay',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete", "DichVu", new { area = "Admin" })',
                            type: 'POST',
                            data: { id: maDV },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire('Thành công', res.message, 'success').then(() => {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Không thể xóa',
                                        text: res.message,
                                        confirmButtonColor: '#0d6efd'
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire('Lỗi', 'Không thể kết nối máy chủ!', 'error');
                            }
                        });
                    }
                });
            });

            // 3. ĐỔI TRẠNG THÁI (Khóa/Mở)
            $('#dvResult').on('click', '.btn-toggle-status', function (e) {
                e.preventDefault();
                var btn = $(this);
                var maDV = btn.data('id');
                var currentStatus = btn.data('status') === true || btn.data('status') === 'True' || btn.data('status') === 'true';
                var newStatus = !currentStatus;

                var titleText = currentStatus ? 'Khóa dịch vụ này?' : 'Mở khóa dịch vụ?';
                var confirmColor = currentStatus ? '#6c757d' : '#198754';

                Swal.fire({
                    title: titleText,
                    text: currentStatus ? 'Dịch vụ này sẽ bị tạm ngưng sử dụng.' : 'Dịch vụ sẽ được phép hoạt động trở lại.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: confirmColor,
                    cancelButtonColor: '#dc3545',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("ToggleStatus", "DichVu", new { area = "Admin" })',
                            type: 'POST',
                            data: { id: maDV, status: newStatus },
                            success: function (res) {
                                if (res.success) {
                                    var tr = btn.closest('tr');
                                    var statusCell = tr.find('td:nth-child(6)');

                                    if (newStatus) {
                                        statusCell.html('<span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">Đang HĐ</span>');
                                        btn.removeClass('btn-outline-success').addClass('btn-outline-secondary').html('<i class="bi bi-lock"></i>').attr('title', 'Khóa dịch vụ');
                                    } else {
                                        statusCell.html('<span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2 py-1">Đã khóa</span>');
                                        btn.removeClass('btn-outline-secondary').addClass('btn-outline-success').html('<i class="bi bi-unlock"></i>').attr('title', 'Mở khóa dịch vụ');
                                    }
                                    btn.data('status', newStatus);
                                } else {
                                    Swal.fire('Lỗi', res.message, 'error');
                                }
                            }
                        });
                    }
                });
            });

        });
    </script>
}