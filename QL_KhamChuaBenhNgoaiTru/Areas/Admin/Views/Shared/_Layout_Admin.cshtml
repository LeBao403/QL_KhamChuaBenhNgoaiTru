@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - QL KCB Nội Trú</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Styles/_Layout_admin.css")" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(2px);
            z-index: 1029;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease-in-out;
        }

        .sidebar.show + .sidebar-overlay {
            opacity: 1;
            visibility: visible;
        }

        /* Chút CSS cho Dropdown Avatar */
        .user-dropdown-toggle::after {
            display: none; /* Ẩn cái mũi tên mặc định của Bootstrap cho đẹp */
        }

        .user-info:hover {
            background-color: #f8f9fa;
            border-radius: 50px;
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <i class="bi bi-heart-pulse-fill"></i>
            </div>
            <h6 class="sidebar-title">MedicHub Admin</h6>
        </div>

        <nav class="nav flex-column sidebar-nav">
            @{
                int chucVu = (Session["MaChucVu"] != null) ? (int)Session["MaChucVu"] : 0;
            }

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Dashboard" ? "active" : "")" href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                <i class="bi bi-grid-1x2-fill"></i> <span>Tổng quan</span>
            </a>

            <div class="nav-section-title"><span>Quản lý Bệnh viện</span></div>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "BenhNhan" ? "active" : "")" href="@Url.Action("Index", "BenhNhan", new { area = "Admin" })">
                <i class="bi bi-people-fill"></i> <span>Bệnh nhân nội trú</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Khoa" ? "active" : "")" href="@Url.Action("Index", "Khoa", new { area = "Admin" })">
                <i class="bi bi-hospital-fill"></i> <span>Quản lý Khoa - Phòng</span>
            </a>

            <div class="nav-section-title"><span>Vật tư & Tài chính</span></div>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Kho" ? "active" : "")" href="@Url.Action("Index", "Kho", new { area = "Admin" })">
                <i class="bi bi-box-seam-fill"></i> <span>Kho Dược - Vật tư</span>
            </a>

            <a class="nav-link" href="@Url.Action("DanhSachPhieuNhap", "Kho", new { area = "Admin" })">
                <i class="bi bi-file-earmark-arrow-down-fill"></i> <span>Phiếu nhập kho</span>
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "HoaDon" ? "active" : "")" href="@Url.Action("Index", "HoaDon", new { area = "Admin" })">
                <i class="bi bi-receipt-cutoff"></i> <span>Thu ngân - Viện phí</span>
            </a>

            <div class="nav-section-title"><span>Hệ thống</span></div>

            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "NhanVien" ? "active" : "")" href="@Url.Action("DanhSachNhanVien", "NhanVien", new { area = "Admin" })">
                <i class="bi bi-person-badge-fill"></i> <span>Hồ sơ Nhân viên</span>
            </a>

            <div class="mt-auto"></div>

            <a class="nav-link logout-link text-danger fw-bold" href="@Url.Action("Logout", "TaiKhoan", new { area = "" })">
                <i class="bi bi-box-arrow-right"></i> <span>Đăng xuất</span>
            </a>
        </nav>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main-content" id="main-content">
        <header class="admin-header d-flex justify-content-between align-items-center px-4 py-2 bg-white shadow-sm">
            <div class="d-flex align-items-center flex-shrink-0">
                <button class="toggle-btn me-3 btn btn-light border-0" id="toggleSidebar"><i class="bi bi-list fs-4"></i></button>
                <h5 class="header-title mb-0 fw-bold text-dark">@ViewBag.Title</h5>
            </div>

            <div class="user-info flex-shrink-0 dropdown p-1 transition" style="cursor: pointer;">
                @{
                    // Lấy Tên hiển thị từ Session, nếu chưa có thì dùng "Admin"
                    string tenHienThi = Session["HoTenNV"] as string ?? Session["Username"] as string ?? "Quản trị viên";

                    // Xác định chức danh hiển thị
                    string tenChucVu = "Nhân viên y tế";
                    if (chucVu == 1) { tenChucVu = "Giám đốc"; }
                    else if (chucVu == 2) { tenChucVu = "Quản trị hệ thống (Admin)"; }
                }

                <div class="d-flex align-items-center user-dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="https://ui-avatars.com/api/?name=@tenHienThi&background=0d6efd&color=fff&rounded=true&bold=true" alt="Avatar" class="rounded-circle shadow-sm" width="40" height="40">

                    <div class="d-none d-md-block ms-3 me-2 text-start">
                        <div class="fw-bold text-dark" style="font-size: 0.95rem;">@tenHienThi</div>
                        <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-shield-check text-success me-1"></i>@tenChucVu</div>
                    </div>
                    <i class="bi bi-chevron-down text-muted ms-2 d-none d-md-block" style="font-size: 0.8rem;"></i>
                </div>

                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" style="border-radius: 12px; min-width: 220px;">
                    <li>
                        <div class="px-3 py-2">
                            <span class="d-block fw-bold text-dark">@tenHienThi</span>
                            <small class="text-muted">Đang trực tuyến</small>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item py-2" href="#"><i class="bi bi-person-vcard me-2 text-primary"></i>Hồ sơ cá nhân</a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2 text-secondary"></i>Đổi mật khẩu</a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item py-2 text-danger fw-bold bg-danger-subtle" href="@Url.Action("Logout", "TaiKhoan", new { area = "" })">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất ngay
                        </a>
                    </li>
                </ul>
            </div>
        </header>

        <main class="page-content p-4">
            @RenderBody()
            <div class="notifications"></div>
        </main>

        <footer class="admin-footer text-center py-3 text-muted">
            <p class="mb-1">&copy; @DateTime.Now.Year <strong>Hệ thống Quản lý Khám chữa bệnh Nội trú - MedicHub</strong>.</p>
            <p class="mb-0">Phát triển bởi <a href="#" class="text-decoration-none">Nhóm Kỹ sư Phần mềm</a></p>
        </footer>

        <div aria-live="polite" aria-atomic="true" style="position: fixed; top: 1rem; right: 1rem; z-index: 2000;">
            <div id="toast-container" class="toast-container"></div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/toast-utility.js"></script>

    <script>
        $(document).ready(function () {
            const toggleBtn = $('#toggleSidebar');
            const sidebar = $('#sidebar');
            const mainContent = $('#main-content');
            const sidebarOverlay = $('#sidebarOverlay');
            const sidebarStateKey = 'sidebarCollapsed';

            function applySidebarState() {
                const isCollapsed = localStorage.getItem(sidebarStateKey) === 'true';
                if ($(window).width() > 992) {
                    sidebar.removeClass('show');
                    if (isCollapsed) {
                        sidebar.addClass('collapsed');
                        mainContent.addClass('expanded');
                    } else {
                        sidebar.removeClass('collapsed');
                        mainContent.removeClass('expanded');
                    }
                } else {
                    sidebar.removeClass('collapsed');
                    mainContent.removeClass('expanded');
                }
            }

            function toggleSidebar() {
                if ($(window).width() > 992) {
                    sidebar.toggleClass('collapsed');
                    mainContent.toggleClass('expanded');
                    localStorage.setItem(sidebarStateKey, sidebar.hasClass('collapsed'));
                } else {
                    sidebar.toggleClass('show');
                    if (sidebar.hasClass('show')) {
                        $('body').append(sidebarOverlay);
                        sidebarOverlay.show();
                    } else {
                        sidebarOverlay.hide();
                    }
                }
            }

            toggleBtn.on('click', toggleSidebar);

            sidebarOverlay.on('click', function () {
                sidebar.removeClass('show');
                $(this).hide();
            });

            $(window).on('resize', applySidebarState);
            applySidebarState();
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>