@{
    ViewBag.Title = "Trung tâm điều khiển";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
}

@section Styles {
    <link href="~/Styles/dashboard.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <div>
        <h2 class="h4 mb-0 fw-bold" style="color: #1e293b;">Trung tâm điều khiển</h2>
        <p class="text-muted mb-0 small">Dữ liệu được cập nhật theo thời gian thực</p>
    </div>
    <div class="dashboard-selector">
        <select id="dashboardType" class="form-select form-select-lg shadow-sm border-0 fw-semibold" style="border-radius: 12px; background-color: #f8fafc; color: #3b82f6; cursor: pointer;">
            <option value="tong-quan" selected>📊 Dashboard Tổng Quan</option>
            <option value="doanh-thu">💰 Phân tích Doanh Thu</option>
            <option value="benh-nhan">👥 Thống kê Bệnh Nhân</option>
            <option value="kho-duoc">💊 Quản lý Kho Dược</option>
        </select>
    </div>
</div>

<div id="dashboard-loader" class="text-center py-5" style="display: none;">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    <p class="mt-3 fw-semibold text-muted">Đang phân tích dữ liệu...</p>
</div>

<div id="dashboard-content" class="mb-4">
</div>

<div class="row g-4 mt-2">
    <div class="col-12">
        <div class="card card-modern">
            <div class="card-header card-header-modern">
                <h6 class="section-title mb-0">
                    <i class="bi bi-lightning text-primary me-1"></i> Thao tác nhanh
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Create", "Thuoc")" class="quick-action-btn">
                            <div class="icon" style="background: #dbeafe;">
                                <i class="bi bi-plus-circle-fill" style="color: #2563eb;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Thêm thuốc mới</div>
                        </a>
                    </div>
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Create", "NhanVien")" class="quick-action-btn">
                            <div class="icon" style="background: #dcfce7;">
                                <i class="bi bi-person-plus-fill" style="color: #16a34a;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Thêm nhân viên</div>
                        </a>
                    </div>
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Create", "Kho")" class="quick-action-btn">
                            <div class="icon" style="background: #fef3c7;">
                                <i class="bi bi-box-seam-fill" style="color: #d97706;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Nhập kho</div>
                        </a>
                    </div>
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Create", "BenhNhan")" class="quick-action-btn">
                            <div class="icon" style="background: #fce7f3;">
                                <i class="bi bi-person-vcard-fill" style="color: #db2777;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Tiếp nhận BN</div>
                        </a>
                    </div>
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Index", "DichVu")" class="quick-action-btn">
                            <div class="icon" style="background: #e0e7ff;">
                                <i class="bi bi-clipboard2-pulse" style="color: #4f46e5;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Dịch vụ</div>
                        </a>
                    </div>
                    <div class="col-xl-2 col-md-4 col-6">
                        <a href="@Url.Action("Index", "Kho")" class="quick-action-btn">
                            <div class="icon" style="background: #fee2e2;">
                                <i class="bi bi-bar-chart-fill" style="color: #dc2626;"></i>
                            </div>
                            <div class="fw-semibold" style="font-size: 13px;">Báo cáo kho</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>

    <script src="~/Scripts/admin/dashboard.js"></script>
}



