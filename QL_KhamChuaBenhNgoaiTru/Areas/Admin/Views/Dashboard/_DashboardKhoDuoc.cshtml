@model QL_KhamChuaBenhNgoaiTru.DBContext.KhoDuocThongKeViewModel
@{
    Func<decimal, string> fmt = (m) => m.ToString("N0");
}
<style>
    /* ÉP CSS ĐỂ HIỆN RÕ THÁNG VÀ NĂM TRÊN LỊCH FLATPICKR */
    .flatpickr-months .flatpickr-month {
        height: 45px !important;
    }

    .flatpickr-current-month {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 0 !important;
    }

        .flatpickr-current-month .numInputWrapper {
            width: 70px !important;
            display: block !important;
        }

        .flatpickr-current-month input.cur-year {
            display: block !important;
            font-weight: 700 !important;
            color: #1e293b !important;
        }

        .flatpickr-current-month .flatpickr-monthDropdown-months {
            font-weight: 700 !important;
            background: transparent !important;
        }

    .card-modern {
        border-radius: 12px;
        transition: all 0.3s ease;
    }
</style>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-primary text-uppercase" style="font-size: 1.2rem;">
            <i class="bi bi-box-seam-fill me-2"></i>Quản trị Kho Dược
        </h4>
        <small class="text-muted">Kiểm soát dòng chảy vật tư y tế và vốn tồn kho</small>
    </div>

    <div class="d-flex gap-2 align-items-center bg-white p-2 rounded-3 shadow-sm border">
        <div class="border-end pe-2">
            <select id="cbKhoDuoc" class="form-select form-select-sm border-0 fw-bold text-primary bg-transparent" style="width: 150px; cursor: pointer; box-shadow: none;">
                <option value="0" selected>Tất cả các Kho</option>
                <option value="1">Kho Tổng (Chính)</option>
                <option value="2">Kho Ngoại trú (Quầy)</option>
                <option value="3">Kho BHYT</option>
            </select>
        </div>
        <div class="input-group input-group-sm border-0" style="width: 135px;">
            <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-calendar"></i></span>
            <input type="text" id="kdTuNgay" class="form-control bg-transparent border-0 fw-bold text-dark px-1" readonly style="cursor: pointer;">
        </div>
        <div class="text-muted"><i class="bi bi-arrow-right"></i></div>
        <div class="input-group input-group-sm border-0" style="width: 135px;">
            <span class="input-group-text bg-transparent border-0 text-muted"><i class="bi bi-calendar-check"></i></span>
            <input type="text" id="kdDenNgay" class="form-control bg-transparent border-0 fw-bold text-dark px-1" readonly style="cursor: pointer;">
        </div>
    </div>
</div>

<input type="hidden" id="kdHdnTuNgay" value="@ViewBag.TuNgay" />
<input type="hidden" id="kdHdnDenNgay" value="@ViewBag.DenNgay" />

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card h-100 border-start border-4 border-primary shadow-sm">
            <div class="card-body p-3">
                <p class="text-muted mb-1 small fw-bold text-uppercase">Vốn tồn kho hiện tại</p>
                <h4 class="fw-bold mb-0 text-dark" id="kpiTonKho">@fmt(Model.TongGiaTriTon) <small>đ</small></h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card h-100 border-start border-4 border-info shadow-sm">
            <div class="card-body p-3">
                <p class="text-muted mb-1 small fw-bold text-uppercase">Tổng nhập trong kỳ</p>
                <h4 class="fw-bold mb-0 text-info" id="kpiNhapKho">@fmt(Model.GiaTriNhapThang) <small>đ</small></h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card h-100 border-start border-4 border-danger shadow-sm bg-danger text-white" style="border: none !important; opacity: 0.95;">
            <div class="card-body p-3">
                <p class="text-white-50 mb-1 small fw-bold text-uppercase"><i class="bi bi-exclamation-triangle-fill me-1"></i>Sắp hết hạn (< 90 ngày)</p>
                <h4 class="fw-bold mb-0 text-white" id="kpiHetHan">@fmt(Model.ThuocSapHetHan) <small>lô thuốc</small></h4>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card h-100 border-start border-4 border-warning shadow-sm">
            <div class="card-body p-3">
                <p class="text-muted mb-1 small fw-bold text-uppercase"><i class="bi bi-box-seam me-1"></i>Sắp hết hàng (< 50 đv)</p>
                <h4 class="fw-bold mb-0 text-warning" id="kpiHetHang">@fmt(Model.ThuocSapHetHang) <small>loại thuốc</small></h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="card card-modern h-100 shadow-sm border-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-truck text-primary me-2"></i>Biến động chi phí nhập kho</h6>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height: 300px;">
                    <canvas id="chartNhapKho"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card card-modern h-100 shadow-sm border-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-pie-chart-fill text-success me-2"></i>Vốn tồn kho theo nhóm</h6>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <div class="chart-container" style="height: 250px; width: 100%;">
                    <canvas id="chartDanhMuc"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-modern h-100 shadow-sm border-0">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-capsule text-danger me-2"></i>Top 7 thuốc tiêu thụ mạnh nhất</h6>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height: 250px;">
                    <canvas id="chartTopThuoc"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-modern h-100 shadow-sm border-0 border-top border-danger border-4">
            <div class="card-header bg-white py-3 border-0">
                <h6 class="fw-bold mb-0 text-danger"><i class="bi bi-calendar-x text-danger me-2"></i>Danh sách thuốc cận Date (Cần xử lý)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0" id="tbCanhBao">
                        <thead class="table-light">
                            <tr>
                                <th>Tên thuốc</th>
                                <th>Số lô</th>
                                <th>Hạn sử dụng</th>
                                <th>Tồn</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DanhSachCanhBao.Count == 0)
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Kho dược an toàn, không có thuốc cận date!</td></tr>
                            }
                            else
                            {
                                foreach (var item in Model.DanhSachCanhBao)
                                {
                                    <tr>
                                        <td class="fw-semibold text-dark">@item.TenThuoc</td>
                                        <td><span class="badge bg-light text-secondary border">@item.MaLo</span></td>
                                        <td class="text-danger fw-bold">@item.HanSuDung</td>
                                        <td>@item.SoLuongTon</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var dataNhapKho = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BieuDoNhapKho));
    var dataDanhMuc = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TyTrongDanhMuc));
    var dataTopThuoc = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TopThuocXuat));

    if (typeof renderKhoDuocCharts === 'function') {
        renderKhoDuocCharts(dataNhapKho, dataDanhMuc, dataTopThuoc);
        initKhoDuocFilter();
    }
</script>
