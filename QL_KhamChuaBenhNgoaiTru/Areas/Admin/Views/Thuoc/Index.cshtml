@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.ThuocManageViewModel>
@using QL_KhamChuaBenhNgoaiTru.Models
@{
    ViewBag.Title = "Quản lý thuốc";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
    var listLoai = ViewBag.DsLoaiThuoc as List<QL_KhamChuaBenhNgoaiTru.DBContext.KhoNhapDB.LoaiThuocItem>;
    var listDD = ViewBag.DsDuongDung as List<string>;
}

<style>
    .filter-card {
        background: #ffffff;
        border-radius: 10px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        border: 1px solid #e9ecef;
        margin-bottom: 16px;
    }

    .filter-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.85rem;
        margin-bottom: 4px;
    }
</style>

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary fw-bold">
                <i class="bi bi-capsule me-2"></i> Danh sách thuốc
            </h4>
            <a href="@Url.Action("Create", "Thuoc", new { area = "Admin" })"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Thêm thuốc
            </a>
        </div>

        <div class="card-body">
            @* ======= PHẦN FILTER ======= *@
            <div class="filter-card">
                <form id="filterForm" method="get" action="@Url.Action("Index", "Thuoc", new { area = "Admin" })">
                    <input type="hidden" name="page" id="filterPage" value="1" />
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="filter-label">Tìm kiếm</label>
                            <input type="text" name="keyword" id="txtKeyword" class="form-control live-search"
                                   data-url="@Url.Action("Search", "Thuoc", new { area = "Admin" })"
                                   data-target="#thuocResult"
                                   value="@ViewBag.Keyword"
                                   placeholder="Mã thuốc, tên thuốc...">
                        </div>
                        <div class="col-md-2">
                            <label class="filter-label">Loại thuốc</label>
                            <select name="maLoaiThuoc" id="cbLoaiThuoc" class="form-select">
                                <option value="">Tất cả</option>
                                @if (listLoai != null)
                                {
                                    foreach (var l in listLoai)
                                    {
                                        <option value="@l.MaLoaiThuoc" @(ViewBag.MaLoaiThuoc == l.MaLoaiThuoc ? "selected" : "")>@l.TenLoaiThuoc</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="filter-label">Đường dùng</label>
                            <select name="duongDung" id="cbDuongDung" class="form-select">
                                <option value="">Tất cả</option>
                                @if (listDD != null)
                                {
                                    foreach (var d in listDD)
                                    {
                                        <option value="@d" @(ViewBag.DuongDung == d ? "selected" : "")>@d</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="filter-label">BHYT</label>
                            <select name="coBHYT" id="cbBHYT" class="form-select">
                                <option value="">Tất cả</option>
                                <option value="true" @(ViewBag.CoBHYT != null && ViewBag.CoBHYT == true ? "selected" : "")>Có BHYT</option>
                                <option value="false" @(ViewBag.CoBHYT != null && ViewBag.CoBHYT == false ? "selected" : "")>Không BHYT</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="filter-label">Trạng thái</label>
                            <select name="trangThai" id="cbTrangThai" class="form-select">
                                <option value="">Tất cả</option>
                                <option value="true" @(ViewBag.TrangThai != null && ViewBag.TrangThai == true ? "selected" : "")>Đang sử dụng</option>
                                <option value="false" @(ViewBag.TrangThai != null && ViewBag.TrangThai == false ? "selected" : "")>Ngừng sử dụng</option>
                            </select>
                        </div>
                        <div class="col-md-1">
                            <button type="button" id="btnResetFilter" class="btn btn-outline-secondary w-100" title="Xóa bộ lọc">
                                <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            @* ======= THÔNG TIN PHÂN TRANG ======= *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">
                    Tổng cộng: <strong class="text-dark">@ViewBag.TotalCount</strong> thuốc
                </span>
            </div>

            @* ======= BẢNG DANH SÁCH ======= *@
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped align-middle bg-white">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-center" style="width: 90px;">Mã thuốc</th>
                            <th>Tên thuốc</th>
                            <th>Quy cách</th>
                            <th>Đơn vị</th>
                            <th>Đường dùng</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-center">BHYT</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="thuocResult">
                        @Html.Partial("_ThuocTable", Model)
                    </tbody>
                </table>
            </div>

            @Html.Partial("_Pagination")
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {

            // =========================================================
            // 1. CHỨC NĂNG LIVE SEARCH & LỌC TRỰC TIẾP
            // =========================================================
            var typingTimer;
            var doneTypingInterval = 400; // Đợi 0.4s sau khi ngừng gõ mới gọi AJAX

            function fireAjaxSearch() {
                var url = $('#txtKeyword').data('url'); // Link tới hàm Search
                var target = $('#txtKeyword').data('target'); // Mục tiêu là bảng #thuocResult

                // Gom tất cả dữ liệu từ các ô filter
                var filterData = {
                    q: $('#txtKeyword').val(),
                    maLoaiThuoc: $('#cbLoaiThuoc').val(),
                    duongDung: $('#cbDuongDung').val(),
                    coBHYT: $('#cbBHYT').val(),
                    trangThai: $('#cbTrangThai').val()
                };

                // Hiển thị loading cho đẹp trong lúc đợi dữ liệu
                $(target).html('<tr><td colspan="9" class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Đang tìm kiếm...</p></td></tr>');

                // Bắn AJAX
                $.ajax({
                    url: url,
                    type: 'GET',
                    data: filterData,
                    success: function (res) {
                        $(target).html(res); // Đổ Partial View trả về vào bảng
                    },
                    error: function () {
                        $(target).html('<tr><td colspan="9" class="text-center text-danger py-4"><i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>Lỗi kết nối máy chủ!</td></tr>');
                    }
                });
            }

            // A. Bắt sự kiện khi gõ vào ô TÌM KIẾM
            $('#txtKeyword').on('input', function () {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(fireAjaxSearch, doneTypingInterval);
            });

            // B. Bắt sự kiện khi thay đổi các nút DROPDOWN
            $('#cbLoaiThuoc, #cbDuongDung, #cbBHYT, #cbTrangThai').on('change', function () {
                fireAjaxSearch();
            });

            // C. Chặn hành động tải lại trang khi Enter trong ô Text
            $('#filterForm').on('submit', function (e) {
                e.preventDefault();
            });

            // D. SỰ KIỆN XÓA BỘ LỌC (RESET)
            $('#btnResetFilter').on('click', function () {
                // Xóa trắng tất cả giá trị
                $('#txtKeyword').val('');
                $('#cbLoaiThuoc').val('');
                $('#cbDuongDung').val('');
                $('#cbBHYT').val('');
                $('#cbTrangThai').val('');

                // Trả về trang 1
                $('#filterPage').val(1);

                // Gọi lại AJAX để tải danh sách gốc
                fireAjaxSearch();
            });


            // =========================================================
            // 2. XÁC NHẬN XÓA THUỐC
            // =========================================================
            $('#thuocResult').on('click', '.btn-delete-thuoc', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');

                Swal.fire({
                    title: 'Bạn chắc chắn muốn xóa?',
                    text: "Thuốc này sẽ bị xóa vĩnh viễn khỏi hệ thống!",
                    icon: 'error',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xóa ngay',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // =========================================================
            // 3. ĐỔI TRẠNG THÁI NHANH
            // =========================================================
            $('#thuocResult').on('click', '.btn-toggle-status', function (e) {
                e.preventDefault();
                var btn = $(this);
                var maThuoc = btn.data('id');
                var currentStatus = btn.data('status') === true || btn.data('status') === 'True';
                var newStatus = !currentStatus;

                Swal.fire({
                    title: currentStatus ? 'Ngừng sử dụng thuốc này?' : 'Kích hoạt thuốc này?',
                    text: currentStatus ? 'Thuốc sẽ không hiển thị trong danh sách kê đơn.' : 'Thuốc sẽ được phép sử dụng trở lại.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: currentStatus ? '#6c757d' : '#198754',
                    cancelButtonColor: '#dc3545',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("ToggleStatus", "Thuoc", new { area = "Admin" })',
                            type: 'POST',
                            data: { id: maThuoc, status: newStatus },
                            success: function (res) {
                                if (res.success) {
                                    var tr = btn.closest('tr');
                                    var statusCell = tr.find('td:nth-child(8)'); // Update index if your table column differs

                                    if (newStatus) {
                                        statusCell.html('<span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">Đang dùng</span>');
                                        btn.removeClass('btn-outline-secondary').addClass('btn-outline-success').html('<i class="bi bi-unlock"></i>').attr('title', 'Ngừng sử dụng');
                                    } else {
                                        statusCell.html('<span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">Ngừng dùng</span>');
                                        btn.removeClass('btn-outline-success').addClass('btn-outline-secondary').html('<i class="bi bi-lock"></i>').attr('title', 'Kích hoạt');
                                    }
                                    btn.data('status', newStatus);
                                } else {
                                    Swal.fire('Lỗi', res.message, 'error');
                                }
                            }
                        });
                    }
                });
            });

            // =========================================================
            // 4. THÔNG BÁO TỪ SERVER
            // =========================================================
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Success"])',
                    timer: 3000,
                    showConfirmButton: true
                });
                </text>
            }
            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi!',
                    text: '@Html.Raw(TempData["Error"])',
                    showConfirmButton: true
                });
                </text>
            }
        });
    </script>
}
