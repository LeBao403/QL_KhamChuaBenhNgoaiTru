@model IEnumerable<QL_KhamChuaBenhNgoaiTru.Models.ThuocManageViewModel>

@{
    ViewBag.Title = "Danh mục Thuốc - Vật tư";
    Layout = "~/Areas/Admin/Views/Shared/_Layout_Admin.cshtml";
}

<div class="container-fluid mt-4 px-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary fw-bold">
                <i class="bi bi-capsule me-2"></i> Danh mục Thuốc - Vật tư y tế
            </h4>
            <a href="@Url.Action("Create", "Thuoc", new { area = "Admin" })" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Thêm thuốc mới
            </a>
        </div>

        <div class="card-body">
            <div class="mb-3">
                <input type="text" class="form-control live-search"
                       data-url="@Url.Action("Search", "Thuoc", new { area = "Admin" })"
                       data-target="#thuocResult"
                       placeholder="Tìm kiếm thuốc theo Mã hoặc Tên thuốc...">
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped align-middle bg-white">
                    <thead class="table-primary text-center">
                        <tr>
                            <th width="10%">Mã Thuốc</th>
                            <th width="25%" class="text-start">Tên Thuốc & Quy cách</th>
                            <th width="15%" class="text-start">Nhóm Thuốc</th>
                            <th width="10%">ĐVT</th>
                            <th width="12%" class="text-end">Giá Bán</th>
                            <th width="13%">Trạng thái</th>
                            <th width="15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="thuocResult">
                        @Html.Partial("_ThuocTable", Model)
                    </tbody>
                </table>
            </div>

            @Html.Partial("_Pagination")
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/Scripts/live-search.js"></script>

    <script>
        $(document).ready(function () {
            // Xử lý xác nhận trước khi Xóa
            // Lưu ý: class 'btn-delete-kh' là class nút xóa ở trong file _ThuocTable.cshtml mà tôi đã cung cấp ở câu trước
            $('#thuocResult').on('click', '.btn-delete-kh', function (e) {
                e.preventDefault();
                var form = $(this).closest('form');

                Swal.fire({
                    title: 'Bạn chắc chắn muốn xóa?',
                    text: "Dữ liệu thuốc sẽ bị xóa. (Lưu ý: Chỉ có thể xóa những loại thuốc chưa từng được kê đơn hoặc xuất/nhập kho!)",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xóa ngay',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}